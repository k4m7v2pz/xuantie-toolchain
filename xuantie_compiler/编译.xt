// xuantie_compiler/编译.xt
// 玄铁自举编译器 - LLVM IR 生成模块 (v0.15.5)

函 检测循环引用(self, 程序节点) { 返 空 }
函 推导程序类型(self, 程序节点) { 若 程序节点 == 空 { 返 空 } }
函 推导语句类型(self, 语句) { 若 语句 == 空 { 返 空 } }
函 推导表达式类型(self, 节点) { 若 节点 == 空 { 返 "" } 返 "判" }

型 编译器 {
    设 结果输出列表
    设 结果输出
    设 寄存器数
    设 标签数
    设 字符串映射
    设 作用域栈
    设 符号表
    
    // 运行时需要的状态
    设 循环深度栈
    设 断标签栈
    设 续标签栈
    设 函数输出列表
    设 外部函数输出列表 // 用于存储外部函数声明
    设 函数输出
    设 类型表
    设 当前函数已返回
    设 是全局
    设 当前型名称 // 用于访问控制检查
    设 变量类型表 // 用于跟踪变量类型
    设 函数返回类型表 // 函数名 → 内部返回类型（"raw_i64"/"double"/"i1"），调用处自动脱壳
    设 arena池变量 // 集合，记录哪些 alloca 寄存器是 Arena 池，出作用域时最后释放
    设 弱引用变量集 // 集合，记录哪些变量是弱引用，用于赋值时跳过ARC
    设 弱引用字段表 // 型名 -> {字段名: 真}，用于编译实例化和成员赋值时判断弱引用
    设 已访引入 // 用于防止重复引入
    设 已定义全局 // 用于多趟编译中的定义追踪
    设 程序缓存 // 用于多趟编译共享 AST
    设 函数表 // 用于多趟编译中的函数追踪
    设 已访语义 // 用于防止语义分析死循环
    设 已访别名 // 用于追踪模块别名，防止被误当作函数使用

    设 查到可见性
    设 查到定义类
    设 主文件路径
    设 警告列表
    设 严格度
    设 已用变量 // 追踪已引用的变量名，用于W101检测
    设 全局声明列表 // 闭包捕获等场景需要的额外全局变量声明
    设 入口alloca列表 // 函数入口处延迟写入的 alloca 行，确保 LLVM 支配性

    函 造() {
        此.结果输出列表 = []
        此.结果输出 = ""
        此.函数输出列表 = []
        此.外部函数输出列表 = [] // 初始化
         此.函数输出 = ""
         此.寄存器数 = 0
         此.标签数 = 0
        此.字符串映射 = {}
        此.作用域栈 = []
        此.符号表 = {}
        此.变量类型表 = {}
        此.函数返回类型表 = {}
        此.arena池变量 = {}
        此.弱引用变量集 = {}
        此.弱引用字段表 = {}
        此.已访引入 = {}
        此.已定义全局 = {}
        此.程序缓存 = {}
        此.函数表 = {}
        此.主文件路径 = ""
        此.已访语义 = {}
        此.已访别名 = {}
        此.循环深度栈 = []
        此.断标签栈 = []
        此.续标签栈 = []
        此.类型表 = {}
        此.当前函数已返回 = 假
        此.是全局 = 真
        此.警告列表 = []
        此.严格度 = "默认"
        此.已用变量 = {}
        此.全局声明列表 = []
        此.入口alloca列表 = []

        // 初始化内置全局符号映射
        此.符号表["文件.读"] = "@\"xt_file_read\""
        此.函数表["文件.读"] = 真
        此.符号表["文件.写"] = "@\"xt_file_write\""
        此.函数表["文件.写"] = 真
        此.符号表["文件.存在?"] = "@\"xt_file_exists\""
        此.函数表["文件.存在?"] = 真
        此.符号表["数学.随机"] = "@\"xt_math_random\""
        此.函数表["数学.随机"] = 真
        此.符号表["数学.绝对值"] = "@\"xt_math_abs\""
        此.函数表["数学.绝对值"] = 真
        此.符号表["数学.正弦"] = "@\"xt_math_sin\""
        此.函数表["数学.正弦"] = 真
        此.符号表["数学.余弦"] = "@\"xt_math_cos\""
        此.函数表["数学.余弦"] = 真
        此.符号表["数学.平方根"] = "@\"xt_math_sqrt\""
        此.函数表["数学.平方根"] = 真
        此.符号表["数学.取整"] = "@\"xt_math_floor\""
        此.函数表["数学.取整"] = 真
        此.符号表["数学.进一"] = "@\"xt_math_ceil\""
        此.函数表["数学.进一"] = 真
        此.符号表["数学.四舍五入"] = "@\"xt_math_round\""
        此.函数表["数学.四舍五入"] = 真
        此.符号表["数学.幂"] = "@\"xt_math_pow\""
        此.函数表["数学.幂"] = 真
        此.符号表["数学.设随机种子"] = "@\"xt_math_srand\""
        此.函数表["数学.设随机种子"] = 真
        此.符号表["数学.最大值"] = "@\"xt_math_max\""
        此.函数表["数学.最大值"] = 真
        此.符号表["数学.最小值"] = "@\"xt_math_min\""
        此.函数表["数学.最小值"] = 真
        此.符号表["数学.PI"] = "@\"xt_math_pi\""
        此.函数表["数学.PI"] = 真
        此.符号表["数学.E"] = "@\"xt_math_e\""
        此.函数表["数学.E"] = 真
        此.符号表["时.现"] = "@\"xt_time_now\""
        此.函数表["时.现"] = 真
        此.符号表["时.毫秒"] = "@\"xt_time_ms\""
        此.函数表["时.毫秒"] = 真
        此.符号表["时.微秒"] = "@\"xt_time_micro\""
        此.函数表["时.微秒"] = 真
        此.符号表["时.睡"] = "@\"xt_time_sleep\""
        此.函数表["时.睡"] = 真
        此.符号表["化"] = "@\"xt_json_serialize\""
        此.函数表["化"] = 真
        此.符号表["解"] = "@\"xt_json_deserialize\""
        此.函数表["解"] = 真
        此.符号表["求"] = "@\"xt_http_request\""
        此.函数表["求"] = 真
        此.符号表["执"] = "@\"xt_execute\""
        此.函数表["执"] = 真
        此.符号表["输"] = "@\"xt_input\""
        此.函数表["输"] = 真
        此.符号表["听"] = "@\"xt_listen\""
        此.函数表["听"] = 真
        此.符号表["连"] = "@\"xt_connect\""
        此.函数表["连"] = 真
        此.符号表["等待"] = "@\"xt_wait\""
        此.函数表["等待"] = 真
        此.当前型名称 = ""
        此.查到可见性 = "公"
        此.查到定义类 = ""
    }

    函 获取目录(路径) {
        设 n = 路径.字节数
        设 i = n - 1
        当 i >= 0 {
            设 c = 路径.截取(i, i + 1)
            若 c == "\\" 或 c == "/" {
                返 路径.截取(0, i + 1)
            }
            i = i - 1
        }
        返 ""
    }

    函 是绝对路径(路径) {
        若 路径.字节数 < 1 { 返 假 }
        设 c1 = 路径.截取(0, 1)
        若 c1 == "\\" 或 c1 == "/" { 返 真 }
        若 路径.字节数 >= 2 {
            设 c2 = 路径.截取(1, 2)
            若 c2 == ":" { 返 真 }
        }
        返 假
    }

    函 合并路径(目录, 相对路径) {
        若 目录 == "" { 返 相对路径 }
        设 末尾 = 目录.截取(目录.字节数 - 1, 目录.字节数)
        若 末尾 == "\\" 或 末尾 == "/" {
            返 目录 & 相对路径
        }
        返 目录 & "\\" & 相对路径
    }

    函 解析完整路径(基础路径, 相对路径) {
        若 此.是绝对路径(相对路径) { 返 相对路径 }
        设 目录 = 此.获取目录(基础路径)
        返 此.合并路径(目录, 相对路径)
    }

    // 检查入口 alloca 列表中是否已存在某变量的 alloca
    // 防止同函数内多个同名循环变量重复 emit alloca（LLVM 不允许重名）
    函 入口alloca已存在(变量名) {
        设 前缀 = "  %\"" & 变量名 & "\" = alloca"
        遍历 行 于 此.入口alloca列表 {
            若 行.截取(0, 前缀.字节数) == 前缀 { 返 真 }
        }
        返 假
    }

    // 检测是否为裸包名（无路径分隔符、无盘符、无扩展名点号）
    // 裸包名用于铁铺包引用，如 引 "数组工具"
    // 含 "." 的是文件名（如 "tiedata.xt"），不走铁铺解析
    函 是裸包名(路径) {
        若 路径.字节数 < 1 { 返 假 }
        若 路径.截取(0, 1) == "." { 返 假 }
        设 i = 0
        当 i < 路径.字节数 {
            设 c = 路径.截取(i, i + 1)
            若 c == "\\" 或 c == "/" 或 c == ":" 或 c == "." { 返 假 }
            i = i + 1
        }
        返 真
    }

    // 获取铁铺包安装根目录 (~/.tiepm/已安装)
    函 获取铁铺安装目录() {
        设 环境结果 = 执("cmd /c echo %TIEPM_HOME%")
        设 环境路径 = 环境结果.值.替换("\r", "").替换("\n", "").替换(" ", "")
        若 环境路径 != "" 且 非 环境路径.包含?("%") {
            返 环境路径 & "\\已安装"
        }
        设 用户结果 = 执("cmd /c echo %USERPROFILE%")
        设 用户目录 = 用户结果.值.替换("\r", "").替换("\n", "")
        返 用户目录 & "\\.tiepm\\已安装"
    }

    // 从铁铺安装目录解析包的 .xt 入口文件
    函 解析铁铺包路径(包名) {
        设 安装根目录 = 此.获取铁铺安装目录()
        设 候选1 = 安装根目录 & "\\" & 包名 & "\\" & 包名 & ".xt"
        设 读结果1 = 文件.读(候选1)
        若 读结果1.成功 { 返 候选1 }

        // GitHub archive 会包裹一层 <名>-<版本>/ 目录
        设 包目录 = 安装根目录 & "\\" & 包名
        设 dir结果 = 执("cmd /c dir /b /ad \"" & 包目录 & "\" 2>nul")
        若 dir结果.成功 {
            设 子目录名 = dir结果.值.替换("\r", "").替换("\n", "").替换(" ", "")
            若 子目录名 != "" {
                设 候选2 = 包目录 & "\\" & 子目录名 & "\\" & 包名 & ".xt"
                设 读结果2 = 文件.读(候选2)
                若 读结果2.成功 { 返 候选2 }
            }
        }
        返 ""
    }

    函 写出(行) {
        // 防御性检查：防止编译器内部状态错误（如将 空 对象错误地序列化为字符串）
        若 行.包含?("i64 空") 或 行.包含?("%空") 或 行.包含?("label %空") {
            示("警告: 编译器内部状态异常，IR 中发现非法标记 -> " & 行)
        }
        此.结果输出列表.追加(行 & "\n")
    }

    函 取新寄存器() {
        此.寄存器数 = 此.寄存器数 + 1
        返 "%t" & 此.寄存器数
    }

    函 取新标签(前缀) {
        此.标签数 = 此.标签数 + 1
        返 前缀 & "." & 此.标签数
    }

    // 将任何值转为安全的 IR 符号串，防止“空”字污染
    函 符(值) {
        若 值 == 空 { 示("致命: 符() 收到空值，编译器内部状态异常"); 终 1 }
        设 s = "" & 值
        返 s
    }

    // 将任何值转为安全的 IR 标签串
    函 标(值) {
        若 值 == 空 { 示("致命: 标() 收到空值，编译器内部状态异常"); 终 1 }
        设 s = "" & 值
        返 s
    }

    函 转义字符串(内容) {
        若 内容 == "" { 返 "" }
        返 内容.转为十六进制
    }



    函 取十六进制位(n) {
        匹配 n {
            0 -> { 返 "0" }
            1 -> { 返 "1" }
            2 -> { 返 "2" }
            3 -> { 返 "3" }
            4 -> { 返 "4" }
            5 -> { 返 "5" }
            6 -> { 返 "6" }
            7 -> { 返 "7" }
            8 -> { 返 "8" }
            9 -> { 返 "9" }
            10 -> { 返 "A" }
            11 -> { 返 "B" }
            12 -> { 返 "C" }
            13 -> { 返 "D" }
            14 -> { 返 "E" }
            15 -> { 返 "F" }
            _ -> { 返 "0" }
        }
    }

    函 加字符串(内容) {
        若 此.字符串映射.含?(内容) {
            返 此.字符串映射[内容]
        }
        设 别名 = "str." & 此.字符串映射.大小
        此.字符串映射[内容] = 别名
        返 别名
    }

    // --- 编译主干 ---

    函 全局预扫描(程序节点, 前缀, 当前文件路径) {
        若 程序节点 == 空 { 返 空 }
        设 p列表 = 程序节点.程序语句列表
        遍历 语句 于 p列表 {
            匹配 语句.节点类别 {
                "函数定义" -> {
                    设 完整名 = 语句.函数名
                    若 前缀 != "" { 完整名 = 前缀 & "." & 完整名 }
                    语句.函数名 = 完整名
                    此.符号表[完整名] = "@\"" & 完整名 & "\""
                    此.函数表[完整名] = 真
                }
                "型定义" -> {
                    设 完整名 = 语句.类型名称
                    若 前缀 != "" { 完整名 = 前缀 & "." & 完整名 }
                    语句.类型名称 = 完整名
                    此.类型表[完整名] = 语句
                    // 预扫描时也处理方法名，以便前向引用
                    遍历 方法 于 语句.方法列表 {
                        设 方法完整名 = 完整名 & "." & 方法.原始函数名
                        此.函数表[方法完整名] = 真
                        此.符号表[方法完整名] = "@\"" & 方法完整名 & "\""
                    }
                }
                "接口定义" -> {
                    设 完整名 = 语句.接口名称
                    若 前缀 != "" { 完整名 = 前缀 & "." & 完整名 }
                    语句.接口名称 = 完整名
                    此.类型表[完整名] = 语句
                }
                "外部函数" -> {
                    此.编译外部函数定义(语句)
                }
                "表达式语句" -> {
                    若 语句.语句表达式.节点类别 == "引入" {
                        此.预扫描引入(语句.语句表达式, 前缀, 当前文件路径)
                    }
                }
                "变量声明" -> {
                    设 完整名 = 语句.声明名称
                    若 前缀 != "" { 完整名 = 前缀 & "." & 完整名 }
                    若 此.是全局 {
                        此.符号表[完整名] = "@\"" & 完整名 & "\""
                    }
                }
            }
        }
    }

    函 预扫描引入(节点, 基础前缀, 父文件路径) {
        设 原始路径 = 节点.路径
        设 实际路径 = 原始路径

        // 铁铺裸包名检测：如 引 "数组工具" 自动解析到 ~/.tiepm/已安装/
        若 此.是裸包名(原始路径) {
            设 铁铺路径 = 此.解析铁铺包路径(原始路径)
            若 铁铺路径 != "" {
                实际路径 = 铁铺路径
                节点.路径 = 实际路径
            } 否 {
                示("编译错误: 无法解析铁铺包引用 '" & 原始路径 & "'")
                示("  来源文件: " & 父文件路径)
                示("  提示: 请先执行 '铁铺 安装 " & 原始路径 & "' 安装此包")
                示("  如果已安装，请检查 " & 此.获取铁铺安装目录() & "\\" & 原始路径 & " 目录")
                终 1
            }
        } 抑 非 此.是绝对路径(原始路径) {
            实际路径 = 此.解析完整路径(父文件路径, 原始路径)
            节点.路径 = 实际路径
        }

        // 防止自引用：若引入路径与当前文件相同，跳过
        若 实际路径 == 父文件路径 {
            示("编译错误: 检测到自引用 -> 文件 '" & 实际路径 & "' 试图引用自身，这没有意义。请移除该引用语句。")
            终 1
        }

        设 程序 = 空
        若 此.程序缓存.含?(实际路径) {
            程序 = 此.程序缓存[实际路径]
        } 否 {
            设 读结果 = 文件.读(实际路径)
            若 非 读结果.成功 {
                示("编译错误: 无法预扫描模块文件")
                示("  来源文件: " & 父文件路径)
                示("  引入路径: " & 原始路径)
                示("  解析为:   " & 实际路径 & "（文件不存在）")
                示("  提示：请检查 '引' 路径是否正确（相对路径以源文件所在目录为基准）")
                终 1
            }
            设 代码 = 读结果.值
            设 子词法 = 造 词法分析器(代码)
            设 子解析 = 造 语法分析器(子词法)
            程序 = 子解析.解析程序()
            若 程序 == 空 { 返 空 }
            此.程序缓存[实际路径] = 程序
        }
        
        设 完整前缀 = 基础前缀
        若 节点.别名 != "" {
            若 完整前缀 != "" { 完整前缀 = 完整前缀 & "." & 节点.别名 } 否 { 完整前缀 = 节点.别名 }
        }
        
        此.全局预扫描(程序, 完整前缀, 实际路径)
    }

    函 语义分析(程序节点) {
        若 程序节点 == 空 { 返 空 }
        设 p列表 = 程序节点.程序语句列表
        
        // 1. 递归处理引入
        遍历 语句1 于 p列表 {
            若 语句1.节点类别 == "表达式语句" {
                若 语句1.语句表达式.节点类别 == "引入" {
                    此.语义分析引入(语句1.语句表达式)
                }
            }
        }

        // 2. 拓扑排序解析类型成员
        设 发生变化 = 真
        当 发生变化 {
            发生变化 = 假
            遍历 语句 于 p列表 {
                若 语句.节点类别 == "型定义" {
                    若 非 语句.已解析 {
                        设 能处理 = 真
                        若 语句.父类名称 != "" {
                            若 此.类型表.含?(语句.父类名称) {
                                设 父类 = 此.类型表[语句.父类名称]
                                若 非 父类.已解析 { 能处理 = 假 }
                            } 否 {
                                示("编译错误: 未定义的父类 '" & 语句.父类名称 & "'")
                                终 1
                            }
                        }
                        
                        若 能处理 {
                            此.解析型成员(语句)
                            发生变化 = 真
                        }
                    }
                }
            }
        }
    }

    函 语义分析引入(节点) {
        设 路径 = 节点.路径
        若 此.已访语义.含?(路径) { 返 空 }
        // 防止自引用
        若 路径 == 此.主文件路径 { 返 空 }
        此.已访语义[路径] = 真
        
        若 此.程序缓存.含?(路径) {
            此.语义分析(此.程序缓存[路径])
        }
    }

    函 解析型成员(节点) {
        若 节点.已解析 { 返 空 } // 防止重复解析

        若 节点.父类名称 != "" 且 此.类型表.含?(节点.父类名称) {
            设 父类信息 = 此.类型表[节点.父类名称]
            // 确保父类已经解析
            若 非 父类信息.已解析 { 此.解析型成员(父类信息) }
            
            遍历 p1 于 父类信息.最终属性列表 { 节点.最终属性列表.追加(p1) }
            遍历 m1 于 父类信息.最终方法列表 { 节点.最终方法列表.追加(m1) }
        }
        
        遍历 p2 于 节点.属性列表 { 节点.最终属性列表.追加(p2) }
        
        遍历 方法 于 节点.方法列表 {
            设 原始名 = 方法.原始函数名
            方法.函数名 = 节点.类型名称 & "." & 原始名
            
            // 检查是否已经添加了 "此" 参数
            设 已有此 = 假
            遍历 param 于 方法.参数列表 {
                若 param.标识符名称 == "此" { 已有此 = 真 ; 断 }
            }
            
            若 非 已有此 {
                设 此参数 = 造 标识符节点(造 标记("标识符", "此", 0, 0))
                设 新参数 = [此参数]
                遍历 p3 于 方法.参数列表 { 新参数.追加(p3) }
                方法.参数列表 = 新参数
            }
            
            设 已覆盖 = 假
            设 midx = 0
            当 midx < 节点.最终方法列表.长度 {
                若 节点.最终方法列表[midx].原始函数名 == 原始名 {
                    节点.最终方法列表[midx] = 方法
                    已覆盖 = 真
                    断
                }
                midx = midx + 1
            }
            若 非 已覆盖 { 节点.最终方法列表.追加(方法) }
        }
        节点.已解析 = 真
    }

    函 编译程序(程序节点, 源文件路径) {
        若 程序节点 == 空 { 返 空 }
        此.主文件路径 = 源文件路径

        // 第一趟：全局预扫描 (收集符号)
        示("MEM:1预扫描开始")
        此.全局预扫描(程序节点, "", 源文件路径)
        示("MEM:1预扫描完成")
        此.已访引入 = {}
        此.已访语义 = {}

        // 第二趟：语义分析
        示("MEM:2语义分析开始")
        此.语义分析(程序节点)
        示("MEM:2语义分析完成")

        // W401：循环引用风险检测（暂时跳过以隔离 Phase 5 崩溃）
        示("MEM:3W401开始 (SKIPPED)")
        示("MEM:3W401完成 (SKIPPED)")

        // 第三趟：类型推导（暂时跳过以隔离 Phase 5 崩溃）
        示("MEM:4类型推导开始 (SKIPPED)")
        示("MEM:4类型推导完成 (SKIPPED)")

        // 第四趟：代码生成 (IR Emit)
        示("MEM:5代码生成开始")
        示("[P5A] 即将访问 此.结果输出列表")
        设 _tmpList = 此.结果输出列表
        示("[P5B] 访问成功 len=" & _tmpList.长度)
        设 之前的输出列表 = _tmpList
        此.结果输出列表 = []

        此.进作用域()
        示("[P5C]")
        设 p列表 = 程序节点.程序语句列表
        示("[P5D] n=" & p列表.长度)
        设 n = p列表.长度
        设 idx = 0
        当 idx < n {
            设 语句 = p列表[idx]
            示("[P5E] " & idx & ":" & 语句.节点类别)
            // 跳过已经预处理过的声明类语句，或者让它们支持重复调用
            匹配 语句.节点类别 {
                "外部函数" -> { idx = idx + 1 ; 续 }
                "表达式语句" -> {
                    // 跳过解析器在文件末尾产生的垃圾语句（token为空值导致）
                    若 语句.语句表达式 == 空 { idx = idx + 1 ; 续 }
                    若 语句.语句表达式.节点类别 == "标识符" {
                        设 _name = 语句.语句表达式.标识符名称
                        若 _name == "" 或 _name.长度 > 10 { idx = idx + 1 ; 续 }
                    }
                }
            }
            此.编译语句(语句)
            示("[P5F]")
            idx = idx + 1
        }
        示("[P5G]")
        此.出作用域(假)
        
        // 拼接主体（入口 alloca 提前）
        示("[P5H]")
        设 _主alloca文本 = 此.入口alloca列表.连接("")
        示("[P5I]")
        设 主体 = _主alloca文本 & 此.结果输出列表.连接("")
        示("[P5J]")
        此.入口alloca列表 = []

        // 现在拼装完整的 IR
        此.结果输出列表 = 之前的输出列表
        示("[P5K]")
        此.写出("; XuanTie LLVM IR (Self-Hosted)")
        此.写出("target datalayout = \"e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128\"")
        此.写出("target triple = \"x86_64-w64-windows-gnu\"")
        此.写出("")
        此.写出("%XTObject = type { i32, i32, i32 }")
        此.写出("%XTString = type { i32, i32, i32, i8*, i64, i32 }")
        此.写出("%XTArray = type { i32, i32, i32, i8**, i64, i64, i8 }")
        此.写出("%XTDict = type { i32, i32, i32, i8***, i64, i64 }")
        此.写出("%XTFunction = type { i32, i32, i32, i8* }")
        此.写出("%XTResult = type { i32, i32, i32, i32, i32, i64, i64 }")
        此.写出("declare void @\"xt_init\"()")
        此.写出("declare void @\"xt_print_value\"(i64)")
        此.写出("declare void @\"xt_retain\"(i64)")
        此.写出("declare void @\"xt_release\"(i64)")
        此.写出("declare i64 @\"xt_convert_to_int\"(i64)")
        此.写出("declare i64 @\"xt_convert_to_float\"(i64)")
        此.写出("declare i64 @\"xt_convert_to_string\"(i64)")
        此.写出("declare i64 @\"xt_func_new\"(i8*)")
        此.写出("declare %XTString* @\"xt_string_new\"(i8*)")
        此.写出("declare %XTString* @\"xt_obj_to_string\"(i64)")
        此.写出("declare %XTString* @\"xt_string_concat\"(%XTString*, %XTString*)")
        此.写出("declare %XTString* @\"xt_string_substring\"(%XTString*, i64, i64)")
        此.写出("declare i64 @\"xt_string_split\"(i64, i64)")
        此.写出("declare i64 @\"xt_string_replace\"(i64, i64, i64)")
        此.写出("declare i32 @\"xt_string_contains\"(%XTString*, %XTString*)")
        此.写出("declare i64 @\"xt_string_get_char\"(i64, i64)")
        此.写出("declare i64 @\"xt_string_get_byte\"(i64, i64)")
        此.写出("declare i64 @\"xt_string_byte_length\"(i64)")
        此.写出("declare i64 @\"xt_string_char_count\"(i64)")
        此.写出("declare i64 @\"xt_array_new\"(i64)")
        此.写出("declare void @\"xt_array_append\"(i64, i64)")
        此.写出("declare i64 @\"xt_array_slice\"(i64, i64)")
        此.写出("declare i64 @\"xt_array_range\"(i64, i64)")
        此.写出("declare void @\"xt_array_set\"(i64, i64, i64)")
        此.写出("declare void @\"xt_array_remove\"(i64, i64)")
        此.写出("declare void @\"xt_array_insert\"(i64, i64, i64)")
        此.写出("declare i64 @\"xt_array_contains\"(i64, i64)")
        此.写出("declare i64 @\"xt_array_find\"(i64, i64)")
        此.写出("declare i64 @\"xt_array_get\"(i64, i64)")
        此.写出("declare %XTString* @\"xt_array_join\"(i64, %XTString*)")
        此.写出("declare i64 @\"xt_dict_new\"(i64)")
        此.写出("declare void @\"xt_dict_set\"(i64, i64, i64)")
        此.写出("declare void @\"xt_dict_remove\"(i64, i64)")
        此.写出("declare i64 @\"xt_dict_keys\"(i64)")
        此.写出("declare i64 @\"xt_dict_values\"(i64)")
        此.写出("declare i64 @\"xt_dict_get\"(i64, i64)")
        此.写出("declare i32 @\"xt_dict_contains\"(i64, i64)")
        此.写出("declare void @\"xt_dict_set_weak\"(i64, i64, i64)")
        此.写出("declare void @\"xt_dict_weak_init\"(i64, i64, i64)")
        此.写出("declare i64 @\"xt_bytes_new\"(i64)")
        此.写出("declare void @\"xt_bytes_append\"(i64, i8)")
        此.写出("declare i64 @\"xt_task_new\"(i64)")
        此.写出("declare i64 @\"xt_channel_new\"(i64)")
        此.写出("declare void @\"xt_channel_send\"(i64, i64)")
        此.写出("declare i64 @\"xt_channel_receive\"(i64)")
        此.写出("declare i64 @\"xt_dict_size\"(i64)")
        此.写出("declare i64 @\"xt_array_length\"(i64)")
        此.写出("declare i64 @\"xt_get_member\"(i64, i64)")
        此.写出("declare i32 @\"xt_eq\"(i8*, i8*)")
        此.写出("declare i32 @\"xt_compare\"(i8*, i8*)")
        此.写出("declare void @\"exit\"(i32)")
        此.写出("declare i64 @\"xt_to_int\"(i64)")
        此.写出("declare i8* @\"xt_result_new\"(i32, i8*, i8*)")
        此.写出("declare i8* @\"xt_float_new\"(double)")
        此.写出("declare %XTString* @\"xt_json_serialize\"(i64)")
        此.写出("declare i64 @\"xt_json_deserialize\"(%XTString*)")
        此.写出("declare void @\"xt_init_args\"(i32, i8**)")
        此.写出("declare void @\"xt_weak_init\"(i64*, i64)")
        此.写出("declare i64 @\"xt_file_read\"(i64)")
        此.写出("declare i64 @\"xt_file_write\"(i64, i64)")
        此.写出("declare i64 @\"xt_file_exists\"(i64)")
        此.写出("declare i64 @\"xt_http_request\"(i64)")
        此.写出("declare i64 @\"xt_math_random\"(i64)")
        此.写出("declare i64 @\"xt_math_abs\"(i64)")
        此.写出("declare i64 @\"xt_math_sin\"(i64)")
        此.写出("declare i64 @\"xt_math_cos\"(i64)")
        此.写出("declare i64 @\"xt_math_sqrt\"(i64)")
        此.写出("declare i64 @\"xt_math_floor\"(i64)")
        此.写出("declare i64 @\"xt_math_ceil\"(i64)")
        此.写出("declare i64 @\"xt_math_round\"(i64)")
        此.写出("declare i64 @\"xt_math_pow\"(i64, i64)")
        此.写出("declare i64 @\"xt_math_srand\"(i64)")
        此.写出("declare i64 @\"xt_math_max\"(i64)")
        此.写出("declare i64 @\"xt_math_min\"(i64)")
        此.写出("declare i64 @\"xt_math_pi\"()")
        此.写出("declare i64 @\"xt_math_e\"()")
        此.写出("declare i64 @\"xt_time_now\"()")
        此.写出("declare i64 @\"xt_time_ms\"()")
        此.写出("declare i64 @\"xt_time_micro\"()")
        此.写出("declare i64 @\"xt_time_sleep\"(i64)")
        此.写出("declare i64 @\"xt_listen\"(i64, i64)")
        此.写出("declare i64 @\"xt_connect\"(i64)")
        此.写出("declare i64 @\"xt_execute\"(i64)")
        此.写出("declare i64 @\"xt_input\"(i64)")
        此.写出("")
        
        // 输出外部函数声明
        遍历 外部 于 此.外部函数输出列表 {
            此.写出(外部)
        }
        此.写出("")
        
        遍历 内容 于 此.字符串映射 {
            设 别名 = 此.符(此.字符串映射[内容])
            设 转义内容 = 此.转义字符串(内容)
            // hex格式: 每字节对应3字符(\XX)，故原始字节数 = 转义长度/3
            设 字节数 = 转义内容.字节数 / 3
            设 长度 = 字节数 + 1
            此.写出("@" & 别名 & " = private unnamed_addr constant [" & 长度 & " x i8] c\"" & 转义内容 & "\\00\", align 1")
        }
        此.写出("")

        // 输出额外全局变量声明（闭包捕获等场景）
        遍历 _全局声明项 于 此.全局声明列表 { 此.写出(_全局声明项) }

        遍历 _每函数体 于 此.函数输出列表 {
            此.写出(此.符(_每函数体))
        }

        此.写出("define i32 @main(i32 %argc, i8** %argv) {")
        此.写出("entry:")
        此.写出("  call void @xt_init()")
        此.写出("  call void @xt_init_args(i32 %argc, i8** %argv)")
        此.写出(此.符(主体))
        此.写出("  ret i32 0")
        此.写出("}")

        // 最终拼接
        示("[P5L] 输出列表长度=" & 此.结果输出列表.长度)
         此.结果输出 = 此.结果输出列表.连接("")
        示("[P5M] 最终拼接完成")

        若 此.警告列表.长度 > 0 {
            示("编译警告:")
            遍历 警 于 此.警告列表 { 示(警) }
        }
     }

    // --- 作用域与内存管理 (ARC) ---

    函 进作用域() {
        此.作用域栈.追加([])
    }

    函 追踪对象(地址寄存器) {
        若 此.作用域栈.长度 > 0 {
            设 顶层 = 此.作用域栈.长度 - 1
            此.作用域栈[顶层].追加(地址寄存器)
        }
    }

    // 检测表达式是否是 xt_arena_new() 调用，标记为 Arena 池变量
    函 标记arena池(语句, 变量名) {
        若 语句.声明值 == 空 { 返 空 }
        若 语句.声明值.节点类别 == "调用表达式" {
            设 调用 = 语句.声明值
            若 调用.函数表达式.节点类别 == "标识符" {
                若 调用.函数表达式.标识符名称 == "xt_arena_new" {
                    若 此.符号表.含?(变量名) {
                        设 存址 = 此.符号表[变量名]
                        若 存址 != 空 且 存址.字节数 > 0 {
                            此.arena池变量[存址] = 真
                        }
                    }
                }
            }
        }
    }

    函 出作用域(是返回) {
        若 此.作用域栈.长度 == 0 { 返 空 }
        
        设 顶层 = 此.作用域栈.长度 - 1
        设 遍历终点 = 顶层
        若 是返回 { 遍历终点 = 0 }
        
        设 游标 = 顶层
        当 游标 >= 遍历终点 {
            设 变量组 = 此.作用域栈[游标]
            遍历 存址 于 变量组 {
                设 值寄存器 = 此.取新寄存器()
                此.写出("  " & 值寄存器 & " = load i64, i64* " & 存址)
                此.写出("  call void @xt_release(i64 " & 值寄存器 & ")")
            }
            // 重要：清空已处理的作用域，防止重复释放
            此.作用域栈[游标] = []
            游标 = 游标 - 1
        }
        
        // 将局部变量转移，只弹出顶层
        若 非 是返回 {
            设 新栈 = []
            设 新长度 = 顶层
            设 idx = 0
            当 idx < 新长度 {
                新栈.追加(此.作用域栈[idx])
                idx = idx + 1
            }
            此.作用域栈 = 新栈
        }
    }

    // --- 语句与表达式编译 ---

    函 编译语句(节点) {
        若 节点 == 空 { 返 空 }
        匹配 节点.节点类别 {
            "显示语句" -> { 此.编译显示语句(节点) }
            "表达式语句" -> { 此.编译表达式语句(节点) }
            "变量声明" -> { 此.编译变量声明语句(节点) }
            "若语句" -> { 此.编译若语句(节点) }
            "当语句" -> { 此.编译当语句(节点) }
            "无限循环" -> { 此.编译无限循环(节点) }
            "遍历循环" -> { 此.编译遍历循环(节点) }
            "中断语句" -> { 此.编译中断语句(节点) }
            "继续语句" -> { 此.编译继续语句(节点) }
            "终止语句" -> { 此.编译终止语句(节点) }
            "匹配语句" -> { 此.编译匹配语句(节点) }
            "返回语句" -> { 此.编译返回语句(节点) }
            "函数定义" -> { 此.编译函数定义(节点) }
            "型定义" -> { 此.编译型定义(节点) }
            "接口定义" -> { 此.编译接口定义(节点) }
            "外部函数" -> { 此.编译外部函数定义(节点) }
            "尝试捕捉" -> { 此.编译尝试捕捉(节点) }
            "块" -> {
                此.进作用域()
                设 b_len = 节点.块语句列表.长度
                设 b_i = 0
                当 b_i < b_len {
                    设 子语句 = 节点.块语句列表[b_i]
                    此.编译语句(子语句)
                    b_i = b_i + 1
                }
                此.出作用域(假)
            }
            _ -> { 
                示("暂不支持编译该语句类别: " & 节点.节点类别) 
            }
        }
    }

    函 编译接口定义(节点) {
        // 目前接口仅作为编译时约束，暂不生成 IR 代码
        // 类型表已在预扫描阶段填充
    }

    函 编译外部函数定义(节点) {
        若 节点 == 空 { 返 空 }
        设 名 = 节点.函数名
        
        // 针对 printf 特殊处理：使用运行时包装器以确保 MinGW 兼容性
        若 名 == "printf" {
            此.外部函数输出列表.追加("declare i32 @xt_ffi_printf(%XTString*, ...)\n")
            此.函数表[名] = 真
            此.符号表[名] = "@xt_ffi_printf"
            返 空
        }

        设 参数列表 = 节点.参数列表
        设 返回类型 = 节点.返回类型
        
        此.函数表[名] = 真
        此.符号表[名] = "@\"" & 名 & "\""

        设 llvm返回类型 = "i64" // 默认玄铁对象都是 i64
        若 返回类型 == "整" { llvm返回类型 = "i64" }
        抑 返回类型 == "字" { llvm返回类型 = "i8*" }
        // 注: "空" 类型映射已移除（字面量在产物中有字节数bug）
        
        设 llvm参数列表 = ""
        设 i = 0
        当 i < 参数列表.长度 {
            llvm参数列表 = llvm参数列表 & "i64"
            若 i < 参数列表.长度 - 1 { llvm参数列表 = llvm参数列表 & ", " }
            i = i + 1
        }
        
        此.外部函数输出列表.追加("declare " & llvm返回类型 & " @\"" & 名 & "\"(" & llvm参数列表 & ")\n")
    }

    函 编译终止语句(节点) {
        设 码 = 0
        若 节点.状态码 != 空 {
            设 res = 此.编译表达式(节点.状态码)
            设 raw = 此.确保RawI64(res[0], res[1])
            设 i32Reg = 此.取新寄存器()
            此.写出("  " & i32Reg & " = trunc i64 " & raw & " to i32")
            此.写出("  call void @exit(i32 " & i32Reg & ")")
        } 否 {
            此.写出("  call void @exit(i32 0)")
        }
        此.写出("  unreachable")
        此.当前函数已返回 = 真
    }

    函 编译匹配语句(节点) {
        设 翻译目标 = 此.编译表达式(节点.匹配目标)
        设 目标寄存器 = 翻译目标[0]
        设 目标类型 = 翻译目标[1]
        
        设 结束标签 = 此.取新标签("match.end")
        设 目标Xt = 此.确保I64(目标寄存器, 目标类型)
        
        设 i = 0
        当 i < 节点.分支列表.长度 {
            设 分支 = 节点.分支列表[i]
            设 模式 = 分支[0]
            设 块 = 分支[1]
            
            设 下一分支标签 = 此.取新标签("match.next")
            设 命中标签 = 此.取新标签("match.case")
            
            若 模式.节点类别 == "标识符" 且 模式.标识符名称 == "_" {
                // 默认分支
                此.写出("  br label %" & 命中标签)
            } 抑 模式.节点类别 == "前缀" 且 模式.操作符 == "是" {
                // 类型匹配: 是 类型
                设 目标类型 = 模式.右节点.标识符名称
                
                // 获取目标对象的 type_id
                设 objPtr = 此.取新寄存器()
                此.写出("  " & objPtr & " = inttoptr i64 " & 目标Xt & " to %XTObject*")
                设 typeIdPtr = 此.取新寄存器()
                此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & objPtr & ", i32 0, i32 2")
                设 typeId = 此.取新寄存器()
                此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
                
                // 映射类型名称到 ID
                设 目标Id = "0"
                匹配 目标类型 {
                    "整" -> { 目标Id = "1" }
                    "小数" -> { 目标Id = "2" }
                    "字" -> { 目标Id = "3" }
                    "判" -> { 目标Id = "4" }
                    "数组" -> { 目标Id = "5" }
                    "字典" -> { 目标Id = "6" }
                    "实例" -> { 目标Id = "7" }
                    "结果" -> { 目标Id = "8" }
                    // "空" 字面量已移除（见上述注释）
                }
                
                设 isMatch = 此.取新寄存器()
                此.写出("  " & isMatch & " = icmp eq i32 " & typeId & ", " & 目标Id)
                此.写出("  br i1 " & isMatch & ", label %" & 命中标签 & ", label %" & 下一分支标签)
            } 否 {
                设 翻译模式 = 此.编译表达式(模式)
                设 模式寄存器 = 翻译模式[0]
                设 模式类型 = 翻译模式[1]
                
                设 模式Xt = 此.确保I64(模式寄存器, 模式类型)
                
                // 比较目标和模式 (简单使用 xt_eq)
                设 目标Obj = 此.取新寄存器()
                设 模式Obj = 此.取新寄存器()
                此.写出("  " & 目标Obj & " = inttoptr i64 " & 目标Xt & " to i8*")
                此.写出("  " & 模式Obj & " = inttoptr i64 " & 模式Xt & " to i8*")
                
                设 eqRes = 此.取新寄存器()
                此.写出("  " & eqRes & " = call i32 @xt_eq(i8* " & 目标Obj & ", i8* " & 模式Obj & ")")
                
                设 cond = 此.取新寄存器()
                此.写出("  " & cond & " = icmp ne i32 " & eqRes & ", 0")
                此.写出("  call void @xt_release(i64 " & 模式Xt & ")")
                
                此.写出("  br i1 " & cond & ", label %" & 命中标签 & ", label %" & 下一分支标签)
            }
            
            此.写出(命中标签 & ":")
            此.编译语句(块)
            若 非 此.最后是返回() { 此.写出("  br label %" & 结束标签) }
            
            此.写出(下一分支标签 & ":")
            i = i + 1
        }
        
        此.写出("  br label %" & 结束标签) // 兜底
        此.写出(结束标签 & ":")
        此.写出("  call void @xt_release(i64 " & 目标Xt & ")")
    }

    函 编译遍历循环(节点) {
        设 翻译目标 = 此.编译表达式(节点.迭代目标)
        设 目标寄存器 = 此.符(翻译目标[0])
        设 目标类型 = 翻译目标[1]
        设 目标Xt = 此.符(此.确保I64(目标寄存器, 目标类型))
        
        // 0. 将迭代变量和索引变量 alloca 提升到函数入口块
        设 变量名 = 此.符(节点.迭代变量名)
        若 非 此.符号表.含?(变量名) {
            设 varAddr = "%\"" & 变量名 & "\""
            若 非 此.入口alloca已存在(变量名) {
                此.入口alloca列表.追加("  " & varAddr & " = alloca i64\n")
                此.入口alloca列表.追加("  store i64 0, i64* " & varAddr & "\n")
                此.追踪对象(varAddr)
            }
            此.符号表[变量名] = varAddr
        }

        若 节点.迭代索引名 != "" {
            设 索名 = 此.符(节点.迭代索引名)
            若 非 此.符号表.含?(索名) {
                设 idxAddr = "%\"" & 索名 & "\""
                若 非 此.入口alloca已存在(索名) {
                    此.入口alloca列表.追加("  " & idxAddr & " = alloca i64\n")
                    此.入口alloca列表.追加("  store i64 0, i64* " & idxAddr & "\n")
                    此.追踪对象(idxAddr)
                }
                此.符号表[索名] = idxAddr
            }
        }

        // 1. 获取目标类型 ID
        设 typePtr = 此.取新寄存器()
        此.写出("  " & typePtr & " = inttoptr i64 " & 目标Xt & " to %XTObject*")
        设 typeIdPtr = 此.取新寄存器()
        此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & typePtr & ", i32 0, i32 2")
        设 typeId = 此.取新寄存器()
        此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
        
        // 2. 根据类型选择遍历策略
        设 arrayLabel = 此.标(此.取新标签("for.array"))
        设 stringLabel = 此.标(此.取新标签("for.string"))
        设 dictLabel = 此.标(此.取新标签("for.dict"))
        设 endLabel = 此.标(此.取新标签("for.end"))
        
        设 isArray = 此.取新寄存器()
        此.写出("  " & isArray & " = icmp eq i32 " & typeId & ", 5") // XT_TYPE_ARRAY = 5
        
        设 isDict = 此.取新寄存器()
        此.写出("  " & isDict & " = icmp eq i32 " & typeId & ", 6") // XT_TYPE_DICT = 6
        
        设 isString = 此.取新寄存器()
        此.写出("  " & isString & " = icmp eq i32 " & typeId & ", 3") // XT_TYPE_STRING = 3

        设 checkDictLabel = 此.标(此.取新标签("for.check_dict"))
        设 checkStringLabel = 此.标(此.取新标签("for.check_string"))
        此.写出("  br i1 " & isArray & ", label %" & arrayLabel & ", label %" & checkDictLabel)
        
        此.写出(checkDictLabel & ":")
        此.写出("  br i1 " & isDict & ", label %" & dictLabel & ", label %" & checkStringLabel)
        
        此.写出(checkStringLabel & ":")
        此.写出("  br i1 " & isString & ", label %" & stringLabel & ", label %" & endLabel)

        // 数组遍历实现
        此.写出(arrayLabel & ":")
        设 aPtr = 此.取新寄存器()
        设 aLen = 此.取新寄存器()
        此.写出("  " & aLen & " = call i64 @xt_array_length(i64 " & 目标Xt & ")")
        此.生成循环逻辑(节点, 目标Xt, aLen, 假, "数组")
        此.写出("  br label %" & endLabel)

        // 字符串遍历实现
        此.写出(stringLabel & ":")
        设 sPtr = 此.取新寄存器()
        设 sLen = 此.取新寄存器()
        此.写出("  " & sLen & " = call i64 @xt_string_byte_length(i64 " & 目标Xt & ")")
        此.生成循环逻辑(节点, 目标Xt, sLen, 假, "字符串")
        此.写出("  br label %" & endLabel)
        
        // 字典遍历实现 (获取所有键并遍历)
        此.写出(dictLabel & ":")
        设 keysArr = 此.取新寄存器()
        此.写出("  " & keysArr & " = call i64 @xt_dict_keys(i64 " & 目标Xt & ")")
        设 akPtr = 此.取新寄存器()
        设 akLen = 此.取新寄存器()
        此.写出("  " & akLen & " = call i64 @xt_array_length(i64 " & keysArr & ")")
        此.生成循环逻辑(节点, keysArr, akLen, 真, "数组")
        此.写出("  br label %" & endLabel)
        
        此.写出(endLabel & ":")
        此.写出("  call void @xt_release(i64 " & 目标Xt & ")")
    }

    函 生成循环逻辑(节点, 目标Xt, 长度Raw, 是字典, 类别) {
        设 检查标签 = 此.标(此.取新标签("loop.cond"))
        设 循环体标签 = 此.标(此.取新标签("loop.body"))
        设 步进标签 = 此.标(此.取新标签("loop.step"))
        设 结束标签 = 此.标(此.取新标签("loop.end"))
        
        设 索引Addr = 此.符(此.取新寄存器())
        此.写出("  " & 索引Addr & " = alloca i64")
        此.写出("  store i64 0, i64* " & 索引Addr)
        
        此.断标签栈.追加(结束标签)
            此.循环深度栈.追加(此.作用域栈.长度)
        此.续标签栈.追加(步进标签)
        
        此.写出("  br label %" & 检查标签)
        此.写出(检查标签 & ":")
        
        设 当前索引 = 此.符(此.取新寄存器())
        此.写出("  " & 当前索引 & " = load i64, i64* " & 索引Addr)
        设 cond = 此.符(此.取新寄存器())
        此.写出("  " & cond & " = icmp slt i64 " & 当前索引 & ", " & 此.符(长度Raw))
        此.写出("  br i1 " & cond & ", label %" & 循环体标签 & ", label %" & 结束标签)
        
        此.写出(循环体标签 & ":")

        // 获取元素并存入迭代变量
        设 元素Xt = 此.符(此.取新寄存器())
        设 索引Tagged = 此.符(此.取新寄存器())
        此.写出("  " & 索引Tagged & " = shl i64 " & 当前索引 & ", 1")
        设 索引Tagged2 = 此.符(此.取新寄存器())
        此.写出("  " & 索引Tagged2 & " = or i64 " & 索引Tagged & ", 1")
        
        若 类别 == "数组" {
            此.写出("  " & 元素Xt & " = call i64 @xt_array_get(i64 " & 此.符(目标Xt) & ", i64 " & 索引Tagged2 & ")")
        } 否 {
            此.写出("  " & 元素Xt & " = call i64 @xt_string_get_char(i64 " & 此.符(目标Xt) & ", i64 " & 当前索引 & ")")
        }
        
        此.写出("  call void @xt_retain(i64 " & 元素Xt & ")")
        
        设 变量名 = 此.符(节点.迭代变量名)
        设 存址 = 此.符(此.符号表[变量名])
        此.写出("  store i64 " & 元素Xt & ", i64* " & 存址)
        
        // 如果有索引变量
        若 节点.迭代索引名 != "" {
            设 索名 = 此.符(节点.迭代索引名)
            设 索址 = 此.符(此.符号表[索名])
            此.写出("  store i64 " & 索引Tagged2 & ", i64* " & 索址)
        }

        此.编译语句(节点.循环块)
        此.写出("  br label %" & 步进标签)
        
        此.写出(步进标签 & ":")
        设 下一索引 = 此.符(此.取新寄存器())
        此.写出("  " & 下一索引 & " = add i64 " & 当前索引 & ", 1")
        此.写出("  store i64 " & 下一索引 & ", i64* " & 索引Addr)
        此.写出("  br label %" & 检查标签)
        
        此.写出(结束标签 & ":")
        若 是字典 { 此.写出("  call void @xt_release(i64 " & 此.符(目标Xt) & ")") }
        
        此.断标签栈.弹出()
            此.循环深度栈.弹出()
        此.续标签栈.弹出()
    }

    函 编译返回语句(节点) {
        设 翻译结果 = ["0", "i64"]
        若 节点.返回值 != 空 {
            翻译结果 = 此.编译表达式(节点.返回值)
        }
        
        // 性能优化：如果推导类型是"整"，直接进行标记位包装并返回
        若 节点.推导类型 == "整" 且 翻译结果[1] == "raw_i64" {
             此.出作用域(真)
             设 val = 此.符(翻译结果[0])
             设 shifted = 此.取新寄存器()
             此.写出("  " & shifted & " = shl i64 " & val & ", 1")
             设 tagged = 此.取新寄存器()
             此.写出("  " & tagged & " = or i64 " & shifted & ", 1")
             此.写出("  ret i64 " & tagged)
        } 否 {
            设 xt_val = 此.确保I64(翻译结果[0], 翻译结果[1])
            此.出作用域(真)
            
            若 此.是全局 {
                设 raw = 此.确保RawI64(翻译结果[0], 翻译结果[1])
                设 i32Reg = 此.取新寄存器()
                此.写出("  " & i32Reg & " = trunc i64 " & raw & " to i32")
                此.写出("  ret i32 " & i32Reg)
            } 否 {
                此.写出("  ret i64 " & xt_val)
            }
        }
        此.当前函数已返回 = 真
    }

    函 编译若语句(节点) {
        设 结束标签 = 此.标(此.取新标签("if.end"))
        
        // 1. 处理初始 "若" 分支
        设 翻译条件 = 此.编译表达式(节点.若条件)
        设 cond = 此.符(此.生成布尔条件(翻译条件[0], 翻译条件[1]))
        
        设 真分支标签 = 此.标(此.取新标签("if.true"))
        设 下一尝试标签 = 此.标(此.取新标签("if.next"))
        
        若 节点.抑分支列表.长度 == 0 且 节点.若否则块 == 空 {
            下一尝试标签 = 结束标签
        }

        此.写出("  br i1 " & cond & ", label %" & 真分支标签 & ", label %" & 下一尝试标签)
        
        此.写出(真分支标签 & ":")
        此.编译语句(节点.若结果块)
        若 非 此.最后是返回() { 此.写出("  br label %" & 结束标签) }
        
        // 2. 处理 "抑" 分支
        设 idx = 0
        当 idx < 节点.抑分支列表.长度 {
            此.写出(下一尝试标签 & ":")
            设 抑分支 = 节点.抑分支列表[idx]
            设 抑条件 = 抑分支[0]
            设 抑块 = 抑分支[1]
            
            设 翻译抑条件 = 此.编译表达式(抑条件)
            设 抑cond = 此.符(此.生成布尔条件(翻译抑条件[0], 翻译抑条件[1]))
            
            真分支标签 = 此.标(此.取新标签("if.true"))
            下一尝试标签 = 此.标(此.取新标签("if.next"))
            若 idx == 节点.抑分支列表.长度 - 1 且 节点.若否则块 == 空 {
                下一尝试标签 = 结束标签
            }
            
            此.写出("  br i1 " & 抑cond & ", label %" & 真分支标签 & ", label %" & 下一尝试标签)
            
            此.写出(真分支标签 & ":")
            此.编译语句(抑块)
            若 非 此.最后是返回() { 此.写出("  br label %" & 结束标签) }
            
            idx = idx + 1
        }
        
        // 3. 处理 "否" 分支
        若 节点.若否则块 != 空 {
            此.写出(下一尝试标签 & ":")
            此.编译语句(节点.若否则块)
            若 非 此.最后是返回() { 此.写出("  br label %" & 结束标签) }
        }
        
        此.写出(结束标签 & ":")
    }

    函 生成布尔条件(寄存器, 类型) {
        设 regStr = 此.符(寄存器)
        设 cond = regStr
        若 类型 == "i64" 或 类型 == "整" {
            cond = 此.符(此.取新寄存器())
            此.写出("  " & cond & " = icmp eq i64 " & regStr & ", 4")
        } 抑 类型 == "raw_i64" {
            cond = 此.符(此.取新寄存器())
            此.写出("  " & cond & " = icmp ne i64 " & regStr & ", 0")
        }
        若 类型 != "raw_i64" 且 类型 != "i1" 且 类型 != "整" {
            设 xt = 此.符(此.确保I64(regStr, 类型))
            此.写出("  call void @xt_release(i64 " & xt & ")")
        }
        返 cond
    }

    函 最后是返回() {
        设 n = 此.结果输出列表.长度
        若 n == 0 { 返 假 }
        设 lastLine = 此.结果输出列表[n - 1]
        若 lastLine.包含?("ret i64 ") { 返 真 }
        若 lastLine.包含?("ret i32 ") { 返 真 }
        若 lastLine.包含?("ret void") { 返 真 }
        若 lastLine.包含?("br label ") { 返 真 }
        若 lastLine.包含?("br i1 ") { 返 真 }
        若 lastLine.包含?("unreachable") { 返 真 }
        返 假
    }

    函 编译当语句(节点) {
        设 检查标签 = 此.标(此.取新标签("while.cond"))
        设 循环体标签 = 此.标(此.取新标签("while.body"))
        设 结束标签 = 此.标(此.取新标签("while.end"))
        
        此.断标签栈.追加(结束标签)
            此.循环深度栈.追加(此.作用域栈.长度)
        此.续标签栈.追加(检查标签)
        
        此.写出("  br label %" & 检查标签)
        此.写出(检查标签 & ":")
        
        设 翻译条件 = 此.编译表达式(节点.循环条件)
        设 cond = 此.符(此.生成布尔条件(翻译条件[0], 翻译条件[1]))
        
        此.写出("  br i1 " & cond & ", label %" & 循环体标签 & ", label %" & 结束标签)
        
        此.写出(循环体标签 & ":")
        此.编译语句(节点.循环块)
        此.写出("  br label %" & 检查标签)
        
        此.写出(结束标签 & ":")
        
        此.断标签栈.弹出()
            此.循环深度栈.弹出()
        此.续标签栈.弹出()
    }

    函 编译无限循环(节点) {
        设 循环体标签 = 此.标(此.取新标签("loop.body"))
        设 结束标签 = 此.标(此.取新标签("loop.end"))
        
        此.断标签栈.追加(结束标签)
            此.循环深度栈.追加(此.作用域栈.长度)
        此.续标签栈.追加(循环体标签)
        
        此.写出("  br label %" & 循环体标签)
        此.写出(循环体标签 & ":")
        此.编译语句(节点.循环块)
        此.写出("  br label %" & 循环体标签)
        
        此.写出(结束标签 & ":")
        
        此.断标签栈.弹出()
            此.循环深度栈.弹出()
        此.续标签栈.弹出()
    }

    函 编译中断语句(节点) {
        若 此.断标签栈.长度 == 0 {
            示("编译错误: [" & 节点.节点行 & ":" & 节点.节点列 & "] '断' 只能在循环中使用")
            终 1
        }
        设 标签 = 此.标(此.断标签栈[此.断标签栈.长度 - 1])
        // 弹出作用域到循环进入时的深度
        若 此.循环深度栈.长度 > 0 {
            设 目标深度 = 此.循环深度栈[此.循环深度栈.长度 - 1]
            当 此.作用域栈.长度 > 目标深度 {
                此.出作用域(假)
            }
        } 否 {
            此.出作用域(假)
        }
        此.出作用域(假)
        此.写出("  br label %" & 标签)
    }

    函 编译继续语句(节点) {
        若 此.续标签栈.长度 == 0 {
            示("编译错误: [" & 节点.节点行 & ":" & 节点.节点列 & "] '续' 只能在循环中使用")
            终 1
        }
        设 标签 = 此.标(此.续标签栈[此.续标签栈.长度 - 1])
        // 弹出作用域到循环进入时的深度
        若 此.循环深度栈.长度 > 0 {
            设 目标深度 = 此.循环深度栈[此.循环深度栈.长度 - 1]
            当 此.作用域栈.长度 > 目标深度 {
                此.出作用域(假)
            }
        } 否 {
            此.出作用域(假)
        }
        此.出作用域(假)
        此.写出("  br label %" & 标签)
    }

    函 编译函数定义(节点) {
        设 之前的输出列表 = 此.结果输出列表
        设 之前的符号表 = 此.符号表
        设 之前的类型表 = 此.变量类型表
        设 之前的作用域栈 = 此.作用域栈
        设 之前的寄存器计数 = 此.寄存器数
        设 之前的全局状态 = 此.是全局
        设 之前的入口alloca列表 = 此.入口alloca列表
        
        此.结果输出列表 = []
        此.符号表 = {}
        此.变量类型表 = {}
        // 复制全局变量
        遍历 键 于 之前的符号表 {
            设 存址 = 之前的符号表[键]
            若 存址 != 空 且 存址.字节数 > 0 {
                若 存址.截取(0, 1) == "@" {
                    此.符号表[键] = 存址
                    若 之前的类型表.含?(键) {
                        此.变量类型表[键] = 之前的类型表[键]
                    }
                }
            }
        }
        此.作用域栈 = []
        此.寄存器数 = 0
        此.是全局 = 假
        
        设 函数名 = "@\"" & 节点.函数名 & "\""
        设 参数声明 = []
        设 p参数数量 = 节点.参数列表.长度
        设 j = 0
        当 j < p参数数量 {
            设 arg节点 = 节点.参数列表[j]
            参数声明.追加("i64 %\"" & 此.符(arg节点.标识符名称) & "_arg\"")
            j = j + 1
        }
        
        设 参数拼接 = 参数声明.连接(", ")
        
        此.写出("define i64 " & 函数名 & "(" & 参数拼接 & ") {")
        此.写出("entry:")
        此.进作用域()
        此.入口alloca列表 = []

        设 k = 0
        当 k < p参数数量 {
            设 arg节点2 = 节点.参数列表[k]
            设 变量名 = 此.符(arg节点2.标识符名称)
            设 varAddr = "%\"" & 变量名 & "\""
            设 argReg = "%\"" & 变量名 & "_arg\""
            此.写出("  " & varAddr & " = alloca i64")
            此.写出("  store i64 0, i64* " & varAddr)

            // 读取类型注解（解析器存在 推导类型 字段，如 "整"、"字"）
            设 注解 = ""
            若 arg节点2.推导类型 != "" 且 arg节点2.推导类型 != "未知" {
                注解 = arg节点2.推导类型
             }
            设 内部类型 = 此.映射类型注解(注解)
            
            // 标量参数：传入值为标记 i64，先脱壳再存 raw 值
            若 此.是标量类型(内部类型) {
                设 unboxed = 此.确保RawI64(argReg, "i64")
                此.写出("  store i64 " & unboxed & ", i64* " & varAddr)
                此.符号表[arg节点2.标识符名称] = varAddr
                此.变量类型表[arg节点2.标识符名称] = 内部类型
                k = k + 1
                续
            }
            
            此.写出("  store i64 " & argReg & ", i64* " & varAddr)
            此.写出("  call void @xt_retain(i64 " & argReg & ")")
            此.追踪对象(varAddr)
            此.符号表[arg节点2.标识符名称] = varAddr
            // 设置参数类型，如果是 "此" 则使用当前型
            若 arg节点2.标识符名称 == "此" 且 此.当前型名称 != "" {
                此.变量类型表[arg节点2.标识符名称] = "型:" & 此.当前型名称
            } 否 {
                此.变量类型表[arg节点2.标识符名称] = "i64"
            }
            k = k + 1
        }

        // 保存入口输出（entry 标签 + 参数 alloca），供后续入口 alloca 拼接
        设 入口输出列表 = []
        遍历 _e 于 此.结果输出列表 { 入口输出列表.追加(_e) }
        此.结果输出列表 = []

        // 注册返回类型注解，供调用处按需自动脱壳
        若 节点.返回类型 != "" {
            此.函数返回类型表[节点.函数名] = 此.映射类型注解(节点.返回类型)
        }
        
        此.编译语句(节点.函数体块)
        
        // 兜底返回
        若 非 此.最后是返回() {
            此.出作用域(真)
            此.写出("  ret i64 0")
        }
        此.写出("}")
        
        // 拼接函数体（入口 alloca 插入到 entry 块，保证 LLVM 支配性）
        设 _alloca文本 = 此.入口alloca列表.连接("")
        设 _主体文本 = 此.结果输出列表.连接("")
        设 函数体 = 入口输出列表.连接("") & _alloca文本 & _主体文本
        此.函数输出列表.追加(函数体)

        // W101: 检测当前函数内未使用的局部变量
        设 w101参数名列表 = {}
        遍历 w101p 于 节点.参数列表 { w101参数名列表[w101p.标识符名称] = 真 }
        遍历 w101变量名 于 此.变量类型表 {
            设 w101存址 = 此.符号表[w101变量名]
            若 w101存址 != 空 且 w101存址.截取(0, 1) != "@" 且 非 w101参数名列表.含?(w101变量名) {
                若 非 此.已用变量.含?(w101变量名) {
                    此.添加类型警告("W101", 节点.节点行, "变量 '" & w101变量名 & "' 在函数 '" & 节点.函数名 & "' 中声明但从未使用")
                }
            }
        }

        此.结果输出列表 = 之前的输出列表
        此.符号表 = 之前的符号表
        此.变量类型表 = 之前的类型表
        此.作用域栈 = 之前的作用域栈
        此.寄存器数 = 之前的寄存器计数
        此.是全局 = 之前的全局状态
        此.入口alloca列表 = 之前的入口alloca列表
    }

    函 编译型定义(节点) {
        设 旧型 = 此.当前型名称
        此.当前型名称 = 节点.类型名称

        // 收集弱引用字段到弱引用字段表
        设 弱字段 = {}
        遍历 属性 于 节点.最终属性列表 {
            若 属性.弱引用 { 弱字段[属性.声明名称] = 真 }
        }
        若 弱字段.键().长度 > 0 {
            此.弱引用字段表[节点.类型名称] = 弱字段
        }

        // 成员解析已在语义分析阶段完成，直接编译方法
        遍历 方法 于 节点.方法列表 {
            此.编译函数定义(方法)
        }

        此.当前型名称 = 旧型
    }

    函 编译实例化(节点) {
        设 类型名 = 节点.类型名称
        
        若 类型名 == "字节" {
            设 res = 此.符(此.取新寄存器())
            此.写出("  " & res & " = call i64 @xt_bytes_new(i64 16)")
            设 _r = [res, "i64"]
            返 _r
        }
        
        若 非 此.类型表.含?(类型名) {
            示("编译错误: [" & 节点.节点行 & ":" & 节点.节点列 & "] 未定义的型 '" & 类型名 & "'")
            终 1
        }
        设 型定义 = 此.类型表[类型名]
        
        设 arrReg = 此.符(此.取新寄存器())
        此.写出("  " & arrReg & " = call i64 @xt_dict_new(i64 16)")
        
        设 类型名Xt = 此.符(此.获取字符串对象(类型名))
        设 元键Xt = 此.符(此.获取字符串对象("__类型__"))
        
        此.写出("  call void @xt_dict_set(i64 " & arrReg & ", i64 " & 元键Xt & ", i64 " & 类型名Xt & ")")
        此.写出("  call void @xt_release(i64 " & 元键Xt & ")")
        此.写出("  call void @xt_release(i64 " & 类型名Xt & ")")

        设 idx = 0
        当 idx < 型定义.最终属性列表.长度 {
            设 属性 = 型定义.最终属性列表[idx]
            设 翻译值 = 此.编译表达式(属性.声明值)
            设 值Xt = 此.符(此.确保I64(翻译值[0], 翻译值[1]))

            设 键Xt = 此.符(此.获取字符串对象(属性.声明名称))
            若 属性.弱引用 {
                此.写出("  call void @xt_dict_set_weak(i64 " & arrReg & ", i64 " & 键Xt & ", i64 " & 值Xt & ")")
                此.写出("  call void @xt_dict_weak_init(i64 " & arrReg & ", i64 " & 键Xt & ", i64 " & 值Xt & ")")
            } 否 {
                此.写出("  call void @xt_dict_set(i64 " & arrReg & ", i64 " & 键Xt & ", i64 " & 值Xt & ")")
            }
            此.写出("  call void @xt_release(i64 " & 键Xt & ")")
            此.写出("  call void @xt_release(i64 " & 值Xt & ")")
            idx = idx + 1
        }

        设 mIdx = 0
        当 mIdx < 型定义.最终方法列表.长度 {
            设 方法 = 型定义.最终方法列表[mIdx]
            设 真实名 = 方法.原始函数名
            设 键Xt2 = 此.符(此.获取字符串对象(真实名))
            
            设 函指_raw = 此.符(此.取新寄存器())
            设 方法签名 = "i64 (i64"
            设 mArgIdx = 0
            当 mArgIdx < 方法.参数列表.长度 - 1 {
                方法签名 = 方法签名 & ", i64"
                mArgIdx = mArgIdx + 1
            }
            方法签名 = 方法签名 & ")*"
            
            此.写出("  " & 函指_raw & " = bitcast " & 方法签名 & " @\"" & 方法.函数名 & "\" to i8*")
            设 函指Obj = 此.符(此.取新寄存器())
            此.写出("  " & 函指Obj & " = call i64 @xt_func_new(i8* " & 函指_raw & ")")
            
            此.写出("  call void @xt_dict_set(i64 " & arrReg & ", i64 " & 键Xt2 & ", i64 " & 函指Obj & ")")
            此.写出("  call void @xt_release(i64 " & 函指Obj & ")")
            此.写出("  call void @xt_release(i64 " & 键Xt2 & ")")
            mIdx = mIdx + 1
        }
        
        设 构造名 = ""
        设 midx2 = 型定义.最终方法列表.长度 - 1
        当 midx2 >= 0 {
            若 型定义.最终方法列表[midx2].原始函数名 == "造" {
                构造名 = 型定义.最终方法列表[midx2].函数名
                断
            }
            midx2 = midx2 - 1
        }
        
        若 构造名 != "" {
            设 my参数结果列表 = ["i64 " & arrReg]
            设 my释放寄存器列表 = []
            设 argCount = 节点.构造参数.长度
            设 argIdx = 0
            当 argIdx < argCount {
                设 p参 = 节点.构造参数[argIdx]
                设 翻译参数 = 此.编译表达式(p参)
                设 xt_val = 此.符(此.确保I64(翻译参数[0], 翻译参数[1]))
                my参数结果列表.追加("i64 " & xt_val)
                my释放寄存器列表.追加(xt_val)
                argIdx = argIdx + 1
            }
            
            设 构造结果 = 此.符(此.取新寄存器())
            此.写出("  " & 构造结果 & " = call i64 @\"" & 构造名 & "\"(" & my参数结果列表.连接(", ") & ")")
            此.写出("  call void @xt_release(i64 " & 构造结果 & ")")
            遍历 r 于 my释放寄存器列表 { 此.写出("  call void @xt_release(i64 " & 此.符(r) & ")") }
        }
        返 [arrReg, "型:" & 类型名]
    }

    函 编译变量声明语句(语句) {
        设 翻译结果 = 此.编译表达式(语句.声明值)
        设 xt_val = 此.符(此.确保I64(翻译结果[0], 翻译结果[1]))
        若 翻译结果[1] == "raw_i64" {
            设 类型名 = "i64"
        } 否 {
            设 类型名 = 翻译结果[1]
        }

        若 语句.是解构 {
            // 解构赋值处理
            设 解构类型 = 语句.解构类型
            设 元素列表 = 语句.解构元素列表
            
            设 i = 0
            当 i < 元素列表.长度 {
                设 元素名 = 元素列表[i]
                设 提取值Reg = 此.符(此.取新寄存器())
                
                若 解构类型 == "数组" {
                    若 元素名.长度 > 3 且 元素名.截取(0, 3) == "..." {
                        设 真实名 = 此.符(元素名.截取(3, 元素名.长度))
                        设 索引Xt = 此.符(此.取新寄存器())
                        此.写出("  " & 索引Xt & " = or i64 " & (i * 2) & ", 1")
                        此.写出("  " & 提取值Reg & " = call i64 @xt_array_slice(i64 " & 此.符(xt_val) & ", i64 " & 索引Xt & ")")
                        此.注册局部变量(真实名, 提取值Reg, "i64")
                    } 否 {
                        设 索引Xt = 此.符(此.取新寄存器())
                        此.写出("  " & 索引Xt & " = or i64 " & (i * 2) & ", 1")
                        此.写出("  " & 提取值Reg & " = call i64 @xt_array_get(i64 " & 此.符(xt_val) & ", i64 " & 索引Xt & ")")
                        此.写出("  call void @xt_retain(i64 " & 提取值Reg & ")")
                        此.注册局部变量(元素名, 提取值Reg, "i64")
                    }
                } 抑 解构类型 == "字典" {
                    设 键Xt = 此.符(此.获取字符串对象(元素名))
                    此.写出("  " & 提取值Reg & " = call i64 @xt_dict_get(i64 " & 此.符(xt_val) & ", i64 " & 键Xt & ")")
                    此.写出("  call void @xt_retain(i64 " & 提取值Reg & ")")
                    此.写出("  call void @xt_release(i64 " & 键Xt & ")")
                    此.注册局部变量(元素名, 提取值Reg, "i64")
                }
                
                i = i + 1
            }
            此.写出("  call void @xt_release(i64 " & 此.符(xt_val) & ")")
            返 空
        }

        设 变量名 = 此.符(语句.声明名称)
        此.注册局部变量(变量名, xt_val, 类型名)

        若 语句.弱引用 {
            // 弱引用：注册槽位 + 释放表达式 load 的 xt_retain（弱引用不持有所有权）
            设 存址_弱 = 此.符号表[变量名]
            此.写出("  call void @xt_weak_init(i64* " & 存址_弱 & ", i64 " & 此.符(xt_val) & ")")
            此.写出("  call void @xt_release(i64 " & 此.符(xt_val) & ")")
            // 从作用域栈移除，防止出作用域double-free
            若 此.作用域栈.长度 > 0 {
                设 顶层_弱 = 此.作用域栈.长度 - 1
                设 过滤后_弱 = []
                设 变量组_弱 = 此.作用域栈[顶层_弱]
                设 i_弱 = 0
                当 i_弱 < 变量组_弱.长度 {
                    若 变量组_弱[i_弱] != 存址_弱 { 过滤后_弱.追加(变量组_弱[i_弱]) }
                    i_弱 = i_弱 + 1
                }
                此.作用域栈[顶层_弱] = 过滤后_弱
            }
            此.弱引用变量集[语句.声明名称] = 真
        } 否 {
            此.标记arena池(语句, 语句.声明名称)
        }
    }

    函 注册局部变量(变量名, xt_val, 类型名) {
        若 此.符号表.含?(变量名) {
            设 存址 = 此.符(此.符号表[变量名])
            
            若 此.是全局 {
                若 非 此.已定义全局.含?(变量名) {
                    此.函数输出列表.追加(存址 & " = global i64 0\n")
                    此.已定义全局[变量名] = 真
                }
                此.写出("  store i64 " & 此.符(xt_val) & ", i64* " & 存址)
            } 否 {
                若 存址.截取(0, 1) == "@" {
                    此.写出("  store i64 " & 此.符(xt_val) & ", i64* " & 存址)
                } 否 {
                    设 oldVal = 此.取新寄存器()
                    此.写出("  " & oldVal & " = load i64, i64* " & 存址)
                    此.写出("  call void @xt_release(i64 " & oldVal & ")")
                    此.写出("  store i64 " & 此.符(xt_val) & ", i64* " & 存址)
                }
            }
            此.变量类型表[变量名] = 类型名
        } 否 {
            若 此.是全局 {
                设 全局名 = "@\"" & 变量名 & "\""
                此.函数输出列表.追加(全局名 & " = global i64 0\n")
                此.写出("  store i64 " & 此.符(xt_val) & ", i64* " & 全局名)
                此.符号表[变量名] = 全局名
                此.已定义全局[变量名] = 真
                此.变量类型表[变量名] = 类型名
            } 否 {
                设 局部名 = "%\"" & 变量名 & "\""
                若 非 此.入口alloca已存在(变量名) {
                    此.入口alloca列表.追加("  " & 局部名 & " = alloca i64\n")
                    此.入口alloca列表.追加("  store i64 0, i64* " & 局部名 & "\n")
                }
                此.写出("  store i64 " & 此.符(xt_val) & ", i64* " & 局部名)
                此.追踪对象(局部名)
                此.符号表[变量名] = 局部名
                此.变量类型表[变量名] = 类型名
            }
        }
    }

    函 编译显示语句(语句) {
        设 翻译结果 = 此.编译表达式(语句.显示值)
        若 翻译结果 == 空 {
            返 空
        }
        设 寄存器 = 翻译结果[0]
        设 类型 = 翻译结果[1]
        设 转换结果 = 此.转为对象(寄存器, 类型)
        设 xt_val = 此.取新寄存器()
        此.写出("  " & xt_val & " = ptrtoint i8* " & 转换结果[0] & " to i64")
        此.写出("  call void @xt_print_value(i64 " & xt_val & ")")
        此.写出("  call void @xt_release(i64 " & xt_val & ")")
    }

    函 编译字符串拼接(节点) {
        // 编译时警告：如果显式使用了 空 值进行拼接
        若 节点.中缀左.节点类别 == "空值" 或 节点.中缀右.节点类别 == "空值" {
            示("编译警告: [" & 节点.节点行 & ":" & 节点.节点列 & "] 字符串拼接中包含明确的 '空' 值。玄铁会自动将其转换为 '空' 字符串。")
        }

        设 翻译左 = 此.编译表达式(节点.中缀左)
        设 翻译右 = 此.编译表达式(节点.中缀右)
        设 leftXtVal = 此.确保I64(翻译左[0], 翻译左[1])
        设 rightXtVal = 此.确保I64(翻译右[0], 翻译右[1])

        设 lStr = 此.取新寄存器()
        此.写出("  " & lStr & " = call %XTString* @xt_obj_to_string(i64 " & leftXtVal & ")")
        设 rStr = 此.取新寄存器()
        此.写出("  " & rStr & " = call %XTString* @xt_obj_to_string(i64 " & rightXtVal & ")")

        设 resReg = 此.取新寄存器()
        此.写出("  " & resReg & " = call %XTString* @xt_string_concat(%XTString* " & lStr & ", %XTString* " & rStr & ")")

        // 这里的释放逻辑是正确的：lStr 和 rStr 是 xt_obj_to_string 产生的 +1 引用，需要释放
        // 翻译左[0] 和 翻译右[0] 是原始表达式产生的值，也需要释放（如果是临时对象）
        此.写_释放_xt(翻译左[0], 翻译左[1])
        此.写_释放_xt(翻译右[0], 翻译右[1])

        设 lStrI64 = 此.取新寄存器()
        此.写出("  " & lStrI64 & " = ptrtoint %XTString* " & lStr & " to i64")
        此.写出("  call void @xt_release(i64 " & lStrI64 & ")")
        设 rStrI64 = 此.取新寄存器()
        此.写出("  " & rStrI64 & " = ptrtoint %XTString* " & rStr & " to i64")
        此.写出("  call void @xt_release(i64 " & rStrI64 & ")")

        设 resI64 = 此.取新寄存器()
        此.写出("  " & resI64 & " = ptrtoint %XTString* " & resReg & " to i64")
        设 _r = [resI64, "i64"]
        返 _r
    }

    函 是标量类型(类型) {
        若 类型 == "raw_i64" 或 类型 == "i1" 或 类型 == "double" { 返 真 }
        返 假
    }

    // 将玄铁类型注解映射为编译器内部类型标记
    函 映射类型注解(注解) {
        若 注解 == "整" { 返 "raw_i64" }
        若 注解 == "小数" { 返 "double" }
        若 注解 == "判" { 返 "i1" }
        返 "i64"
    }

    函 编译表达式(节点) {
        若 节点 == 空 { 返 ["0", "i64"] }
        匹配 节点.节点类别 {
            "整数" -> { 返 [节点.整数值, "raw_i64"] }
            "小数" -> {
                设 resReg = 此.取新寄存器()
                此.写出("  " & resReg & " = call i8* @xt_float_new(double " & 节点.小数值 & ")")
                设 xt_val = 此.取新寄存器()
                此.写出("  " & xt_val & " = ptrtoint i8* " & resReg & " to i64")
                设 _r = [xt_val, "i64"]
                返 _r
            }
            "布尔" -> {
                设 val = "2"
                若 节点.布尔值 { val = "4" }
                设 _r = [val, "i64"]
                返 _r
            }
            "空值" -> { 返 ["0", "i64"] }
            "字符串" -> {
                设 别名 = 此.符(此.加字符串(节点.字符串值))
                设 名字Reg = 此.符(此.取新寄存器())
                // 必须使用字节数
                设 字节数 = 节点.字符串值.字节数
                此.写出("  " & 名字Reg & " = getelementptr inbounds [" & (字节数 + 1) & " x i8], [" & (字节数 + 1) & " x i8]* @" & 别名 & ", i64 0, i64 0")
                设 对象寄存器 = 此.符(此.取新寄存器())
                此.写出("  " & 对象寄存器 & " = call %XTString* @xt_string_new(i8* " & 名字Reg & ")")
                设 xt_val = 此.符(此.取新寄存器())
                此.写出("  " & xt_val & " = ptrtoint %XTString* " & 对象寄存器 & " to i64")
                设 _resultArray = [xt_val, "i64"]
                返 _resultArray
            }
            "字符串插值" -> { 返 此.编译字符串插值(节点) }
            "标识符" -> {
                设 变量名 = 此.符(节点.标识符名称)
                
                // 0. 检查是否是模块别名 (Namespace)
                若 此.已访别名.含?(变量名) {
                    示("编译警告: [" & 节点.节点行 & ":" & 节点.节点列 & "] 模块别名 '" & 变量名 & "' 不能直接作为值使用。")
                    返 ["0", "i64"]
                }

                若 此.函数表.含?(变量名) {
                    设 _r = [变量名, "函数名"]
                    返 _r
                }
                若 此.符号表.含?(变量名) {
                    // 标记变量已被引用（W101检测用）
                    此.已用变量[变量名] = 真
                    设 存址 = 此.符(此.符号表[变量名])
                    设 寄存器 = 此.取新寄存器()
                    此.写出("  " & 寄存器 & " = load i64, i64* " & 存址)
                    
                    设 类型 = "i64"
                    若 存址.长度 > 0 且 存址.截取(0, 1) != "@" {
                        若 此.变量类型表.含?(变量名) {
                            类型 = 此.变量类型表[变量名]
                        }
                    }
                    若 变量名 == "此" 且 此.当前型名称 != "" {
                        类型 = "型:" & 此.当前型名称
                    }

                    若 非 此.是标量类型(类型) {
                        此.写出("  call void @xt_retain(i64 " & 寄存器 & ")")
                    }
                    返 [寄存器, 类型]
                } 否 {
                    匹配 变量名 {
                        "数组" -> { 返 ["11", "i64"] }
                        "字典" -> { 返 ["13", "i64"] }
                        "结果" -> { 返 ["17", "i64"] }
                        "文件" -> { 返 ["0", "i64"] }
                        "时" -> { 返 ["0", "i64"] }
                        "数学" -> { 返 ["0", "i64"] }
                        "库" -> { 返 ["0", "i64"] }
                        _ -> { 
                            示("编译错误: [" & 节点.节点行 & ":" & 节点.节点列 & "] 未知标识符 '" & 变量名 & "'")
                            终 1
                        }
                    }
                }
            }
            "整" -> {
                若 此.符号表.含?(节点.标识符名称) {
                    设 __存址 = 此.符(此.符号表[节点.标识符名称])
                    设 __寄存器 = 此.取新寄存器()
                    此.写出("  " & __寄存器 & " = load i64, i64* " & __存址)
                    设 _r = [__寄存器, "i64"]
                    返 _r
                }
                返 ["整", "整"]
            }
            "小数类型" -> { 返 ["小数", "小数类型"] }
            "字" -> {
                若 此.符号表.含?(节点.标识符名称) {
                    设 __存址 = 此.符(此.符号表[节点.标识符名称])
                    设 __寄存器 = 此.取新寄存器()
                    此.写出("  " & __寄存器 & " = load i64, i64* " & __存址)
                    设 _r = [__寄存器, "i64"]
                    返 _r
                }
                返 ["字", "字"]
            }
            "道" -> {
                若 此.符号表.含?(节点.标识符名称) {
                    设 __存址 = 此.符(此.符号表[节点.标识符名称])
                    设 __寄存器 = 此.取新寄存器()
                    此.写出("  " & __寄存器 & " = load i64, i64* " & __存址)
                    设 _r = [__寄存器, "i64"]
                    返 _r
                }
                返 ["道", "道"]
            }
            "字节" -> {
                若 此.符号表.含?(节点.标识符名称) {
                    设 __存址 = 此.符(此.符号表[节点.标识符名称])
                    设 __寄存器 = 此.取新寄存器()
                    此.写出("  " & __寄存器 & " = load i64, i64* " & __存址)
                    设 _r = [__寄存器, "i64"]
                    返 _r
                }
                返 ["19", "i64"]
            }
            "任务" -> {
                若 此.符号表.含?(节点.标识符名称) {
                    设 __存址 = 此.符(此.符号表[节点.标识符名称])
                    设 __寄存器 = 此.取新寄存器()
                    此.写出("  " & __寄存器 & " = load i64, i64* " & __存址)
                    设 _r = [__寄存器, "i64"]
                    返 _r
                }
                返 ["21", "i64"]
            }
            "中缀" -> {
                若 节点.中缀运算符 == "且" { 返 此.编译逻辑且(节点) }
                若 节点.中缀运算符 == "或" { 返 此.编译逻辑或(节点) }
                若 节点.中缀运算符 == "=" { 返 此.编译赋值(节点) }
                若 节点.中缀运算符 == "&" { 返 此.编译字符串拼接(节点) }
                返 此.编译中缀(节点)
            }
            "前缀" -> {
                设 翻译右 = 此.编译表达式(节点.右节点)
                若 节点.操作符 == "非" {
                    设 cond = 此.生成布尔条件(翻译右[0], 翻译右[1])
                    设 res = 此.取新寄存器()
                    此.写出("  " & res & " = xor i1 " & cond & ", 1")
                    设 _r = [res, "i1"]
                    返 _r
                } 抑 节点.操作符 == "-" {
                    若 翻译右[1] == "raw_i64" {
                        设 res = 此.取新寄存器()
                        此.写出("  " & res & " = sub i64 0, " & 此.符(翻译右[0]))
                        设 _r = [res, "raw_i64"]
                        返 _r
                    }
                    设 val = 此.确保I64(翻译右[0], 翻译右[1])
                    // 强度削减优化：对于标记指针，-(x>>1<<1|1) 等价于 (2 - x) | 1
                    设 neg = 此.取新寄存器()
                    此.写出("  " & neg & " = sub i64 2, " & val)
                    设 res = 此.取新寄存器()
                    此.写出("  " & res & " = or i64 " & neg & ", 1")
                    此.写_释放_xt(翻译右[0], 翻译右[1])
                    设 _r = [res, "i64"]
                    返 _r
                } 抑 节点.操作符 == "取反" {
                    若 翻译右[1] == "raw_i64" {
                        设 res = 此.取新寄存器()
                        此.写出("  " & res & " = xor i64 " & 此.符(翻译右[0]) & ", -1")
                        设 _r = [res, "raw_i64"]
                        返 _r
                    }
                    设 val = 此.确保RawI64(翻译右[0], 翻译右[1])
                    设 notVal = 此.取新寄存器()
                    此.写出("  " & notVal & " = xor i64 " & val & ", -1")
                    设 res = 此.取新寄存器()
                    // 重新装箱：(notVal << 1) | 1
                    设 shifted = 此.取新寄存器()
                    此.写出("  " & shifted & " = shl i64 " & notVal & ", 1")
                    此.写出("  " & res & " = or i64 " & shifted & ", 1")
                    此.写_释放_xt(翻译右[0], 翻译右[1])
                    设 _r = [res, "i64"]
                    返 _r
                }
                返 ["0", "i64"]
            }
            "调用表达式" -> { 返 此.编译调用表达式(节点) }
            "成员访问" -> {
                若 节点.左表达式.节点类别 == "标识符" {
                    设 标识符名 = 此.符(节点.左表达式.标识符名称)
                    设 潜在名 = 标识符名 & "." & 节点.成员名称
                    
                    // 1. 检查是否是跨模块的变量
                    若 此.符号表.含?(潜在名) {
                        设 存址 = 此.符号表[潜在名]
                        设 寄存器 = 此.取新寄存器()
                        此.写出("  " & 寄存器 & " = load i64, i64* " & 存址)
                        // 跨模块变量目前统一视为非标量，执行 retain
                        此.写出("  call void @xt_retain(i64 " & 寄存器 & ")")
                        设 _r = [寄存器, "i64"]
                        返 _r
                    }
                    
                    // 2. 检查是否是跨模块的函数
                    若 此.函数表.含?(潜在名) {
                        // 特殊处理：如果是不带括号访问的内置常量（如 数学.PI）
                        若 潜在名 == "数学.PI" 或 潜在名 == "数学.E" {
                            设 真实名 = 此.符号表[潜在名]
                            设 res = 此.取新寄存器()
                            此.写出("  " & res & " = call i64 " & 真实名 & "()")
                            设 _r = [res, "i64"]
                            返 _r
                        }
                        设 _r = [潜在名, "函数名"]
                        返 _r
                    }
                    
                    // 3. 检查是否是跨模块的类型（实例化场景）
                    若 此.类型表.含?(潜在名) {
                        设 _r = [潜在名, "类型名"]
                        返 _r
                    }

                    // 4. 如果左侧明确是模块别名，但没找到对应成员，直接报错并终止
                    若 此.已访别名.含?(标识符名) {
                        示("编译错误: [" & 节点.节点行 & ":" & 节点.节点列 & "] 模块 '" & 标识符名 & "' 中未找到成员 '" & 节点.成员名称 & "'")
                        终 1
                    }
                }
                
                设 翻译左 = 此.编译表达式(节点.左表达式)
                设 对象寄存器 = 此.确保I64(翻译左[0], 翻译左[1])
                设 左类型 = 翻译左[1]
                
                // 访问控制检查
                此.检查访问权限(左类型, 节点.成员名称, 节点)
                
                若 节点.成员名称 == "长度" 或 节点.成员名称 == "大小" 或 节点.成员名称 == "字节数" {
                    设 objPtr = 此.符(此.取新寄存器())
                    此.写出("  " & objPtr & " = inttoptr i64 " & 此.符(对象寄存器) & " to %XTObject*")
                    设 typeIdPtr = 此.符(此.取新寄存器())
                    此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & objPtr & ", i32 0, i32 2")
                    设 typeId = 此.符(此.取新寄存器())
                    此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
                    
                    设 resAddr = 此.符(此.取新寄存器())
                    此.写出("  " & resAddr & " = alloca i64")
                    此.写出("  store i64 0, i64* " & resAddr)
                    
                    设 strLabel = 此.标(此.取新标签("len.str"))
                    设 arrLabel = 此.标(此.取新标签("len.arr"))
                    设 dictLabel = 此.标(此.取新标签("len.dict"))
                    设 mergeLabel = 此.标(此.取新标签("len.merge"))
                    
                    设 isStr = 此.符(此.取新寄存器())
                    此.写出("  " & isStr & " = icmp eq i32 " & typeId & ", 3")
                    此.写出("  br i1 " & isStr & ", label %" & strLabel & ", label %" & arrLabel)
                    
                    此.写出(strLabel & ":")
                    设 sLen = 此.符(此.取新寄存器())
                    此.写出("  " & sLen & " = call i64 @xt_string_byte_length(i64 " & 此.符(对象寄存器) & ")")
                    此.写出("  store i64 " & sLen & ", i64* " & resAddr)
                    此.写出("  br label %" & mergeLabel)
                    
                    此.写出(arrLabel & ":")
                    设 isArr = 此.符(此.取新寄存器())
                    此.写出("  " & isArr & " = icmp eq i32 " & typeId & ", 5")
                    此.写出("  br i1 " & isArr & ", label %" & arrLabel & ".true, label %" & dictLabel)
                    此.写出(arrLabel & ".true:")
                    设 aLen = 此.符(此.取新寄存器())
                    此.写出("  " & aLen & " = call i64 @xt_array_length(i64 " & 此.符(对象寄存器) & ")")
                    此.写_存储_xt(aLen, "raw_i64", resAddr)
                    此.写出("  br label %" & mergeLabel)
                    此.写出(dictLabel & ":")
                    设 isDict = 此.符(此.取新寄存器())
                    此.写出("  " & isDict & " = icmp eq i32 " & typeId & ", 6")
                    此.写出("  br i1 " & isDict & ", label %" & dictLabel & ".true, label %" & mergeLabel)
                    此.写出(dictLabel & ".true:")
                    设 dVal = 此.符(此.取新寄存器())
                    此.写出("  " & dVal & " = call i64 @xt_dict_size(i64 " & 此.符(对象寄存器) & ")")
                    此.写_存储_xt(dVal, "raw_i64", resAddr)
                    此.写出("  br label %" & mergeLabel)
                    
                    此.写出(mergeLabel & ":")
                    设 finalVal = 此.符(此.取新寄存器())
                    此.写出("  " & finalVal & " = load i64, i64* " & resAddr)
                    此.写出("  call void @xt_release(i64 " & 此.符(对象寄存器) & ")")
                    设 _r = [finalVal, "i64"]
                    返 _r
                }
                
                若 节点.成员名称 == "字符数" {
                    设 resAddr = 此.符(此.取新寄存器())
                    此.写出("  " & resAddr & " = alloca i64")
                    此.写出("  store i64 0, i64* " & resAddr)
                    
                    设 count = 此.符(此.取新寄存器())
                    此.写出("  " & count & " = call i64 @xt_string_char_count(i64 " & 此.符(对象寄存器) & ")")
                    此.写出("  store i64 " & count & ", i64* " & resAddr)
                    
                    设 finalVal = 此.符(此.取新寄存器())
                    此.写出("  " & finalVal & " = load i64, i64* " & resAddr)
                    此.写出("  call void @xt_release(i64 " & 此.符(对象寄存器) & ")")
                    设 _r = [finalVal, "i64"]
                    返 _r
                }
                
                若 节点.成员名称 == "成功" {
                    设 resPtr = 此.符(此.取新寄存器())
                    此.写出("  " & resPtr & " = inttoptr i64 " & 此.符(对象寄存器) & " to %XTResult*")
                    设 isSuccPtr = 此.符(此.取新寄存器())
                    此.写出("  " & isSuccPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 3")
                    设 isSuccI32 = 此.符(此.取新寄存器())
                    此.写出("  " & isSuccI32 & " = load i32, i32* " & isSuccPtr)
                    设 isSucc = 此.符(此.取新寄存器())
                    此.写出("  " & isSucc & " = icmp ne i32 " & isSuccI32 & ", 0")
                    设 resI64 = 此.符(此.取新寄存器())
                    此.写出("  " & resI64 & " = select i1 " & isSucc & ", i64 4, i64 2")
                    此.写出("  call void @xt_release(i64 " & 此.符(对象寄存器) & ")")
                    设 _r = [resI64, "i64"]
                    返 _r
                }
                
                若 节点.成员名称 == "值" {
                    设 resPtr = 此.符(此.取新寄存器())
                    此.写出("  " & resPtr & " = inttoptr i64 " & 此.符(对象寄存器) & " to %XTResult*")
                    设 valPtrPtr = 此.符(此.取新寄存器())
                    此.写出("  " & valPtrPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 5")
                    设 valPtr = 此.符(此.取新寄存器())
                    此.写出("  " & valPtr & " = load i64, i64* " & valPtrPtr)
                    此.写出("  call void @xt_retain(i64 " & valPtr & ")")
                    此.写出("  call void @xt_release(i64 " & 此.符(对象寄存器) & ")")
                    设 _r = [valPtr, "i64"]
                    返 _r
                }
                
                若 节点.成员名称 == "错误" {
                    设 resPtr = 此.取新寄存器()
                    此.写出("  " & resPtr & " = inttoptr i64 " & 对象寄存器 & " to %XTResult*")
                    设 errPtrPtr = 此.取新寄存器()
                    此.写出("  " & errPtrPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 6")
                    设 errPtr = 此.取新寄存器()
                    此.写出("  " & errPtr & " = load i64, i64* " & errPtrPtr)
                    此.写出("  call void @xt_retain(i64 " & errPtr & ")")
                    此.写出("  call void @xt_release(i64 " & 对象寄存器 & ")")
                    设 _r = [errPtr, "i64"]
                    返 _r
                }

                // 通用成员访问
                设 键Xt = 此.获取字符串对象(节点.成员名称)
                设 结果寄存器 = 此.取新寄存器()
                此.写出("  " & 结果寄存器 & " = call i64 @xt_dict_get(i64 " & 对象寄存器 & ", i64 " & 键Xt & ")")
                此.写出("  call void @xt_retain(i64 " & 结果寄存器 & ")")
                此.写出("  call void @xt_release(i64 " & 对象寄存器 & ")")
                此.写出("  call void @xt_release(i64 " & 键Xt & ")")
                设 _r = [结果寄存器, "i64"]
                返 _r
            }
            "数组字面量" -> {
                设 alen = 节点.元素列表.长度
                设 arrReg = 此.取新寄存器()
                此.写出("  " & arrReg & " = call i64 @xt_array_new(i64 " & alen & ")")
                设 idx = 0
                当 idx < alen {
                    设 翻译元素 = 此.编译表达式(节点.元素列表[idx])
                    设 元素Xt = 此.确保I64(翻译元素[0], 翻译元素[1])
                    此.写出("  call void @xt_array_append(i64 " & arrReg & ", i64 " & 元素Xt & ")")
                    此.写出("  call void @xt_release(i64 " & 元素Xt & ")")
                    idx = idx + 1
                }
                设 _r = [arrReg, "i64"]
                返 _r
            }
            "索引表达式" -> {
                设 翻译左 = 此.编译表达式(节点.左表达式)
                设 对象寄存器 = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译索引 = 此.编译表达式(节点.索引)
                设 索引寄存器 = 此.确保I64(翻译索引[0], 翻译索引[1])
                
                设 objPtr = 此.取新寄存器()
                此.写出("  " & objPtr & " = inttoptr i64 " & 对象寄存器 & " to %XTObject*")
                设 typeIdPtr = 此.取新寄存器()
                此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & objPtr & ", i32 0, i32 2")
                设 typeId = 此.取新寄存器()
                此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
                
                设 isDict = 此.取新寄存器()
                此.写出("  " & isDict & " = icmp eq i32 " & typeId & ", 6")
                设 isStr = 此.取新寄存器()
                此.写出("  " & isStr & " = icmp eq i32 " & typeId & ", 3")

                设 dictLabel = 此.取新标签("idx.dict")
                设 strLabel = 此.取新标签("idx.str")
                设 arrLabel = 此.取新标签("idx.arr")
                设 mergeLabel = 此.取新标签("idx.merge")

                设 resAddr = 此.取新寄存器()
                此.写出("  " & resAddr & " = alloca i64")
                此.写出("  store i64 0, i64* " & resAddr)

                此.写出("  br i1 " & isDict & ", label %" & dictLabel & ", label %" & strLabel)

                此.写出(dictLabel & ":")
                设 dRes = 此.取新寄存器()
                此.写出("  " & dRes & " = call i64 @xt_dict_get(i64 " & 对象寄存器 & ", i64 " & 索引寄存器 & ")")
                此.写_存储_xt(dRes, "i64", resAddr)
                此.写出("  br label %" & mergeLabel)

                此.写出(strLabel & ":")
                此.写出("  br i1 " & isStr & ", label %" & strLabel & "_real, label %" & arrLabel)
                此.写出(strLabel & "_real:")
                设 sIdxRaw = 此.取新寄存器()
                此.写出("  " & sIdxRaw & " = ashr i64 " & 索引寄存器 & ", 1")
                设 sRes = 此.取新寄存器()
                此.写出("  " & sRes & " = call i64 @xt_string_get_char(i64 " & 对象寄存器 & ", i64 " & sIdxRaw & ")")
                此.写_存储_xt(sRes, "i64", resAddr)
                此.写出("  br label %" & mergeLabel)

                此.写出(arrLabel & ":")
                设 aRes = 此.取新寄存器()
                此.写出("  " & aRes & " = call i64 @xt_array_get(i64 " & 对象寄存器 & ", i64 " & 索引寄存器 & ")")
                此.写_存储_xt(aRes, "i64", resAddr)
                此.写出("  br label %" & mergeLabel)
                
                此.写出(mergeLabel & ":")
                设 finalVal = 此.取新寄存器()
                此.写出("  " & finalVal & " = load i64, i64* " & resAddr)
                此.写出("  call void @xt_release(i64 " & 对象寄存器 & ")")
                此.写出("  call void @xt_release(i64 " & 索引寄存器 & ")")
                设 _r = [finalVal, "i64"]
                返 _r
            }
            "字典字面量" -> {
                设 arrReg = 此.取新寄存器()
                此.写出("  " & arrReg & " = call i64 @xt_dict_new(i64 16)")
                设 列表 = 节点.键值对列表
                遍历 对 于 列表 {
                    设 翻译键 = 此.编译表达式(对[0])
                    设 键Xt = 此.确保I64(翻译键[0], 翻译键[1])
                    设 翻译值 = 此.编译表达式(对[1])
                    设 值Xt = 此.确保I64(翻译值[0], 翻译值[1])
                    此.写出("  call void @xt_dict_set(i64 " & arrReg & ", i64 " & 键Xt & ", i64 " & 值Xt & ")")
                    此.写出("  call void @xt_release(i64 " & 键Xt & ")")
                    此.写出("  call void @xt_release(i64 " & 值Xt & ")")
                }
                设 _r = [arrReg, "i64"]
                返 _r
            }
            "实例化" -> { 返 此.编译实例化(节点) }
            "引入" -> { 返 此.编译引入(节点) }
            "序列化" -> { 返 此.编译序列化(节点) }
            "反序列化" -> { 返 此.编译反序列化(节点) }
            "异步" -> { 返 此.编译异步(节点) }
            "核心原语" -> {
                设 类型 = 节点.原语类型
                设 结果寄存器 = 此.取新寄存器()
                设 参数声明 = []
                设 释放列表 = []
                遍历 p 于 节点.参数列表 {
                    设 翻译参数 = 此.编译表达式(p)
                    设 xt_val = 此.确保I64(翻译参数[0], 翻译参数[1])
                    参数声明.追加("i64 " & xt_val)
                    释放列表.追加(xt_val)
                }
                
                设 函数名 = ""
                匹配 类型 {
                    "求" -> { 函数名 = "xt_http_request" }
                    "听" -> { 函数名 = "xt_listen" }
                    "连" -> { 函数名 = "xt_connect" }
                    "执" -> { 函数名 = "xt_execute" }
                    "输" -> { 函数名 = "xt_input" }
                }
                
                此.写出("  " & 结果寄存器 & " = call i64 @\"" & 函数名 & "\"(" & 参数声明.连接(", ") & ")")
                遍历 r 于 释放列表 { 此.写出("  call void @xt_release(i64 " & r & ")") }
                设 _r = [结果寄存器, "i64"]
                返 _r
            }
            "等待" -> { 返 此.编译等待(节点) }
            "中缀" -> {
                若 节点.中缀运算符 == "且" { 返 此.编译逻辑且(节点) }
                若 节点.中缀运算符 == "或" { 返 此.编译逻辑或(节点) }
                若 节点.中缀运算符 == "=" { 返 此.编译赋值(节点) }
                若 节点.中缀运算符 == "&" { 返 此.编译字符串拼接(节点) }
                返 此.编译中缀(节点)
            }
            "并行" -> { 返 此.编译并行(节点) }
            "匿名函数" -> { 返 此.编译匿名函数(节点) }
            "范围" -> { 返 此.编译范围(节点) }
            "问号后缀" -> { 返 此.编译问号后缀(节点) }
            _ -> { 返 ["0", "i64"] }
        }
    }

    函 编译范围(节点) {
        设 翻译左 = 此.编译表达式(节点.起始节点)
        设 翻译右 = 此.编译表达式(节点.结束节点)
        设 leftXtVal = 此.确保I64(翻译左[0], 翻译左[1])
        设 rightXtVal = 此.确保I64(翻译右[0], 翻译右[1])

        设 结果寄存器 = 此.取新寄存器()
        此.写出("  " & 结果寄存器 & " = call i64 @xt_array_range(i64 " & leftXtVal & ", i64 " & rightXtVal & ")")

        此.写_释放_xt(翻译左[0], 翻译左[1])
        此.写_释放_xt(翻译右[0], 翻译右[1])

        设 _r = [结果寄存器, "i64"]
        返 _r
    }

    函 编译问号后缀(节点) {
        设 翻译左 = 此.编译表达式(节点.左节点)
        设 leftXtVal = 此.确保I64(翻译左[0], 翻译左[1])

        // --- 安全增强：检查是否为真实的 Result 对象 (type_id == 8) ---
        设 objPtr = 此.取新寄存器()
        此.写出("  " & objPtr & " = inttoptr i64 " & leftXtVal & " to %XTObject*")
        
        设 typeIdPtr = 此.取新寄存器()
        此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & objPtr & ", i32 0, i32 2")
        设 typeId = 此.取新寄存器()
        此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
        
        设 isResult = 此.取新寄存器()
        此.写出("  " & isResult & " = icmp eq i32 " & typeId & ", 8") // XT_TYPE_RESULT = 8
        
        设 checkLabel = 此.取新标签("qm.check")
        设 panicLabel = 此.取新标签("qm.panic")
        设 trueLabel_final = 此.取新标签("qm.true")
        设 falseLabel_final = 此.取新标签("qm.false")
        设 endLabel = 此.取新标签("qm.end")
        
        设 resAddr = 此.取新寄存器()
        此.写出("  " & resAddr & " = alloca i64")
        
        此.写出("  br i1 " & isResult & ", label %" & checkLabel & ", label %" & panicLabel)
        
        此.写出(panicLabel & ":")
        设 msg1 = 此.获取字符串对象("运行时错误: '?' 操作符仅能作用于 '结果' 类型")
        此.写_out("  call void @xt_print_value(i64 " & msg1 & ")")
        此.写出("  call void @xt_release(i64 " & msg1 & ")")
        此.写出("  call void @exit(i32 1)")
        此.写出("  unreachable")

        此.写出(checkLabel & ":")
        设 resPtr = 此.取新寄存器()
        此.写出("  " & resPtr & " = inttoptr i64 " & leftXtVal & " to %XTResult*")
        
        // 提取 is_success
        设 succPtr = 此.取新寄存器()
        此.写出("  " & succPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 3")
        设 isSuccess = 此.取新寄存器()
        此.写出("  " & isSuccess & " = load i32, i32* " & succPtr)
        
        设 cond = 此.取新寄存器()
        此.写出("  " & cond & " = icmp ne i32 " & isSuccess & ", 0")
        
        此.写出("  br i1 " & cond & ", label %" & trueLabel_final & ", label %" & falseLabel_final)
        
        此.写出(trueLabel_final & ":")
        // 如果成功，提取 value 并作为表达式结果
        设 valPtr = 此.取新寄存器()
        此.写出("  " & valPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 5")
        设 finalVal = 此.取新寄存器()
        此.写出("  " & finalVal & " = load i64, i64* " & valPtr)
        此.写出("  call void @xt_retain(i64 " & finalVal & ")")
        此.写出("  store i64 " & finalVal & ", i64* " & resAddr)
        此.写出("  call void @xt_release(i64 " & leftXtVal & ")")
        此.写出("  br label %" & endLabel)
        
        此.写出(falseLabel_final & ":")
        // 如果失败，直接将该 Result 对象作为函数返回值并退出
        此.出作用域(真)
        若 此.是全局 {
            设 raw = 此.确保RawI64(leftXtVal, "i64")
            设 i32Reg = 此.取新寄存器()
            此.写出("  " & i32Reg & " = trunc i64 " & raw & " to i32")
            此.写出("  ret i32 " & i32Reg)
        } 否 {
            此.写出("  ret i64 " & leftXtVal)
        }
        设 dummyLabel = 此.取新标签("qm.dummy")
        此.写出("  br label %" & dummyLabel)
        此.写出(dummyLabel & ":")
        此.写出("  store i64 0, i64* " & resAddr)
        此.写出("  br label %" & endLabel)
        
        此.写出(endLabel & ":")
        设 extVal = 此.取新寄存器()
        此.写出("  " & extVal & " = load i64, i64* " & resAddr)
        设 _r = [extVal, "i64"]
        返 _r
    }

    函 获取字符串对象(内容) {
        设 别名 = 此.符(此.加字符串(内容))
        设 名字Reg = 此.符(此.取新寄存器())
        // 必须使用字节数，否则涉及中文时长度会错位导致 LLVM 报错
        设 字节数 = 内容.字节数
        此.写出("  " & 名字Reg & " = getelementptr inbounds [" & (字节数 + 1) & " x i8], [" & (字节数 + 1) & " x i8]* @" & 别名 & ", i64 0, i64 0")
        设 键Obj = 此.符(此.取新寄存器())
        此.写出("  " & 键Obj & " = call %XTString* @xt_string_new(i8* " & 名字Reg & ")")
        设 键Xt = 此.符(此.取新寄存器())
        此.写出("  " & 键Xt & " = ptrtoint %XTString* " & 键Obj & " to i64")
        返 键Xt
    }

    函 查找成员可见性(型名称, 成员名) {
        若 型名称 == "" { 返 假 }
        若 非 此.类型表.含?(型名称) { 返 假 }
        设 定义 = 此.类型表[型名称]
        若 定义 == 空 { 返 假 }
        
        若 定义.节点类别 != "型定义" {
            返 假
        }
        
        // 1. 检查当前类是否定义了它
        遍历 属性 于 定义.属性列表 {
            若 属性.声明名称 == 成员名 { 
                此.查到可见性 = 属性.可见性
                此.查到定义类 = 型名称
                返 真 
            }
        }
        遍历 方法 于 定义.方法列表 {
            若 方法.原始函数名 == 成员名 { 
                此.查到可见性 = 方法.可见性
                此.查到定义类 = 型名称
                返 真 
            }
        }
        
        // 2. 如果没找到且有父类，递归查找
        若 定义.父类名称 != "" {
            若 定义.父类名称 == 型名称 {
                示("错误: 型 '" & 型名称 & "' 存在循环继承")
                返 假
            }
            返 此.查找成员可见性(定义.父类名称, 成员名)
        }
        
        返 假
    }

    函 是子类?(子类名, 父类名) {
        若 子类名 == 父类名 { 返 真 }
        若 非 此.类型表.含?(子类名) { 返 假 }
        设 定义 = 此.类型表[子类名]
        若 定义.父类名称 == "" { 返 假 }
        返 此.是子类?(定义.父类名称, 父类名)
    }

    函 检查访问权限(左类型, 成员名, 节点) {
        若 左类型.长度 < 2 { 返 空 }
        若 左类型.截取(0, 2) != "型:" { 返 空 }
        设 目标型 = 左类型.截取(2, 左类型.长度)
        
        此.查到可见性 = "公"
        此.查到定义类 = ""
        
        若 此.查找成员可见性(目标型, 成员名) {
            设 可见性 = 此.查到可见性
            设 定义类 = 此.查到定义类
            
            匹配 可见性 {
                "私" -> {
                    若 此.当前型名称 != 定义类 {
                        示("编译错误: [" & 节点.节点行 & ":" & 节点.节点列 & "] 成员 '" & 成员名 & "' 是私有的，只能在型 '" & 定义类 & "' 内部访问")
                        终 1
                    }
                }
                "护" -> {
                    若 此.当前型名称 == "" {
                        示("编译错误: [" & 节点.节点行 & ":" & 节点.节点列 & "] 成员 '" & 成员名 & "' 是受保护的，不能在全局范围访问")
                        终 1
                    } 否 {
                        若 非 此.是子类?(此.当前型名称, 定义类) {
                            示("编译错误: [" & 节点.节点行 & ":" & 节点.节点列 & "] 成员 '" & 成员名 & "' 是受保护的，只能在型 '" & 定义类 & "' 及其子类中访问")
                            终 1
                        }
                    }
                }
            }
        }
    }

    函 编译引入(节点) {
        设 路径 = 节点.路径
        若 此.已访引入.含?(路径) { 返 ["0", "i64"] }
        // 防止自引用：若引入路径与主文件相同，跳过
        若 路径 == 此.主文件路径 { 返 ["0", "i64"] }
        此.已访引入[路径] = 真
        
        // 别名预注册：即使文件读取失败，也要防止别名被当作普通函数
        若 节点.别名 != "" { 此.已访别名[节点.别名] = 真 }

        设 程序 = 空
        若 此.程序缓存.含?(路径) {
            程序 = 此.程序缓存[路径]
        } 否 {
            设 读结果 = 文件.读(路径)
            若 非 读结果.成功 {
                示("编译错误: 无法引入模块文件")
                示("  引入路径: " & 路径)
                终 1
            }
            设 代码 = 读结果.值
            设 子词法 = 造 词法分析器(代码)
            设 子解析 = 造 语法分析器(子词法)
            程序 = 子解析.解析程序()
            若 程序 == 空 { 返 ["0", "i64"] }
            此.程序缓存[路径] = 程序
        }
        
        若 节点.别名 != "" {
            // 命名空间隔离模式
            设 别名 = 节点.别名
            此.已访别名[别名] = 真
            设 旧符号表 = 此.符号表
            设 旧类型表 = 此.类型表
            设 旧函数表 = 此.函数表
            此.符号表 = {}
            此.类型表 = {}
            此.函数表 = {}
            
            // 继承原有全局符号
            遍历 k1 于 旧符号表 {
                设 v1 = 旧符号表[k1]
                若 v1.长度 > 0 且 v1.截取(0, 1) == "@" { 此.符号表[k1] = v1 }
            }
            遍历 k2 于 旧类型表 { 此.类型表[k2] = 旧类型表[k2] }
            遍历 k2f 于 旧函数表 { 此.函数表[k2f] = 真 }
            
            遍历 子语句 于 程序.程序语句列表 {
                此.编译语句(子语句)
            }
            
            // 将新产生的符号加上前缀并回填
            遍历 k3 于 此.符号表 {
                旧符号表[别名 & "." & k3] = 此.符号表[k3]
            }
            遍历 k3f 于 此.函数表 {
                旧函数表[别名 & "." & k3f] = 真
            }
            遍历 k4 于 此.类型表 {
                旧类型表[别名 & "." & k4] = 此.类型表[k4]
            }
            此.符号表 = 旧符号表
            此.类型表 = 旧类型表
            此.函数表 = 旧函数表
        } 否 {
            // 全局合并模式
            遍历 子语句2 于 程序.程序语句列表 {
                此.编译语句(子语句2)
            }
        }
        
        返 ["0", "i64"]
    }

    函 编译序列化(节点) {
        设 翻译目标 = 此.编译表达式(节点.目标)
        设 目标Xt = 此.确保I64(翻译目标[0], 翻译目标[1])
        设 res = 此.取新寄存器()
        此.写出("  " & res & " = call %XTString* @xt_json_serialize(i64 " & 目标Xt & ")")
        设 resI64 = 此.取新寄存器()
        此.写出("  " & resI64 & " = ptrtoint %XTString* " & res & " to i64")
        此.写出("  call void @xt_release(i64 " & 目标Xt & ")")
        设 _r = [resI64, "i64"]
        返 _r
    }

    函 编译反序列化(节点) {
        设 翻译内容 = 此.编译表达式(节点.字符串内容)
        设 内容Xt = 此.确保I64(翻译内容[0], 翻译内容[1])
        设 strPtr = 此.取新寄存器()
        此.写出("  " & strPtr & " = inttoptr i64 " & 内容Xt & " to %XTString*")
        设 res = 此.取新寄存器()
        此.写出("  " & res & " = call i64 @xt_json_deserialize(%XTString* " & strPtr & ")")
        此.写出("  call void @xt_release(i64 " & 内容Xt & ")")
        设 _r = [res, "i64"]
        返 _r
    }

    函 编译异步(节点) {
        // 简化版异步：目前仅生成一个标识性的注释和编译块
        // 实际实现需要协程支持，目前降级为同步执行
        此.写出("; --- 开始异步块 (降级同步执行) ---")
        此.编译语句(节点.异步块)
        此.写出("; --- 结束异步块 ---")
        返 ["0", "i64"]
    }

    函 编译等待(节点) {
        // 简化版等待：目前直接编译内部任务并返回结果
        此.写出("; --- 开始等待任务 (降级同步执行) ---")
        设 res = 此.编译表达式(节点.任务对象)
        此.写出("; --- 结束等待任务 ---")
        返 res
    }

    函 编译并行(节点) {
        // 简化版并行：目前直接同步执行块
        此.写出("; --- 开始并行块 (降级同步执行) ---")
        此.编译语句(节点.并行块)
        此.写出("; --- 结束并行块 ---")
        返 ["0", "i64"]
    }


    函 编译尝试捕捉(节点) {
        设 tryLabel = 此.取新标签("try.begin")
        设 catchLabel = 此.取新标签("try.catch")
        设 endLabel = 此.取新标签("try.end")

        此.写出("; --- 尝试块 ---")
        此.写出("  br label %" & tryLabel)
        此.写出(tryLabel & ":")
        此.进作用域()
        此.编译语句(节点.尝试块)
        此.出作用域(假)
        此.写出("  br label %" & endLabel)
        
        此.写出("; --- 捕捉块 (" & 节点.错误变量名 & ") ---")
        此.写出(catchLabel & ":")
        此.进作用域()
        
        设 errVar = 节点.错误变量名
        设 errAddr = "%\"" & errVar & "\""
        此.写出("  " & errAddr & " = alloca i64")
        
        // 创建模拟的结构化错误对象 (字典)
        设 errDict = 此.取新寄存器()
        此.写出("  " & errDict & " = call i64 @xt_dict_new(i64 8)")
        设 msgKey = 此.获取字符串对象("消息")
        设 msgVal = 此.获取字符串对象("运行时异常: 未定义错误")
        此.写出("  call void @xt_dict_set(i64 " & errDict & ", i64 " & msgKey & ", i64 " & msgVal & ")")
        此.写出("  call void @xt_release(i64 " & msgKey & ")")
        此.写出("  call void @xt_release(i64 " & msgVal & ")")
        
        此.写出("  store i64 " & errDict & ", i64* " & errAddr)
        此.追踪对象(errAddr)
        设 oldAddr = ""
        若 此.符号表.含?(errVar) { oldAddr = 此.符号表[errVar] }
        此.符号表[errVar] = errAddr
        
        此.编译语句(节点.捕捉块)
        
        // 恢复符号表
        若 oldAddr != "" { 此.符号表[errVar] = oldAddr } 否 { 此.符号表.删(errVar) }
        
        此.出作用域(假)
        此.写出("  br label %" & endLabel)
        
        此.写出(endLabel & ":")
    }

    函 收集捕获变量(节点, _外符号表, _外类型表, _已收集) {
        若 节点 == 空 { 返 空 }
        匹配 节点.节点类别 {
            "块" -> { 遍历 _子 于 节点.块语句列表 { 此.收集捕获变量(_子, _外符号表, _外类型表, _已收集) } }
            "表达式语句" -> { 此.收集捕获变量(节点.语句表达式, _外符号表, _外类型表, _已收集) }
            "变量声明" -> { 此.收集捕获变量(节点.声明值, _外符号表, _外类型表, _已收集) }
            "返回语句" -> { 若 节点.返回值 != 空 { 此.收集捕获变量(节点.返回值, _外符号表, _外类型表, _已收集) } }
            "若语句" -> {
                此.收集捕获变量(节点.若条件, _外符号表, _外类型表, _已收集)
                此.收集捕获变量(节点.若结果块, _外符号表, _外类型表, _已收集)
                遍历 _分支 于 节点.抑分支列表 { 此.收集捕获变量(_分支[0], _外符号表, _外类型表, _已收集); 此.收集捕获变量(_分支[1], _外符号表, _外类型表, _已收集) }
                若 节点.若否则块 != 空 { 此.收集捕获变量(节点.若否则块, _外符号表, _外类型表, _已收集) }
            }
            "当语句" -> { 此.收集捕获变量(节点.当条件, _外符号表, _外类型表, _已收集); 此.收集捕获变量(节点.当块, _外符号表, _外类型表, _已收集) }
            "无限循环" -> { 此.收集捕获变量(节点.循环块, _外符号表, _外类型表, _已收集) }
            "遍历循环" -> { 此.收集捕获变量(节点.迭代目标, _外符号表, _外类型表, _已收集); 此.收集捕获变量(节点.循环块, _外符号表, _外类型表, _已收集) }
            "中缀" -> { 此.收集捕获变量(节点.中缀左, _外符号表, _外类型表, _已收集); 此.收集捕获变量(节点.中缀右, _外符号表, _外类型表, _已收集) }
            "前缀" -> { 此.收集捕获变量(节点.右节点, _外符号表, _外类型表, _已收集) }
            "调用表达式" -> {
                此.收集捕获变量(节点.函数表达式, _外符号表, _外类型表, _已收集)
                遍历 _参 于 节点.调用参数 { 此.收集捕获变量(_参, _外符号表, _外类型表, _已收集) }
            }
            "成员访问" -> { 此.收集捕获变量(节点.左表达式, _外符号表, _外类型表, _已收集) }
            "索引表达式" -> { 此.收集捕获变量(节点.左表达式, _外符号表, _外类型表, _已收集); 此.收集捕获变量(节点.索引, _外符号表, _外类型表, _已收集) }
            "问号后缀" -> { 此.收集捕获变量(节点.左节点, _外符号表, _外类型表, _已收集) }
            "字符串插值" -> { 遍历 _片 于 节点.插值片段 { 此.收集捕获变量(_片, _外符号表, _外类型表, _已收集) } }
            "标识符" -> {
                设 _闭包变量名 = 节点.标识符名称
                若 非 _已收集.含?(_闭包变量名) 且 _外符号表.含?(_闭包变量名) {
                    设 _外存址 = _外符号表[_闭包变量名]
                    若 _外存址 != 空 且 _外存址.长度 > 0 且 _外存址.截取(0, 1) != "@" {
                        _已收集[_闭包变量名] = _外存址
                        若 _外类型表.含?(_闭包变量名) { _已收集[_闭包变量名 & "_type"] = _外类型表[_闭包变量名] }
                    }
                }
            }
        }
    }

    函 编译匿名函数(节点) {
        // 简化：目前将匿名函数编译为一个临时的全局函数
        设 临时函数名 = 此.取新标签("anon_func")

        设 之前的输出列表 = 此.结果输出列表
        设 之前的符号表 = 此.符号表
        设 之前的类型表 = 此.变量类型表
        设 之前的作用域栈 = 此.作用域栈
        设 之前的寄存器计数 = 此.寄存器数
        设 之前的全局状态 = 此.是全局

        此.结果输出列表 = []
        此.符号表 = {}
        此.变量类型表 = {}
        // 复制全局变量
        遍历 键 于 之前的符号表 {
            设 存址 = 之前的符号表[键]
            若 存址 != 空 且 存址.长度 > 0 {
                若 存址.截取(0, 1) == "@" { 此.符号表[键] = 存址 }
            }
        }
        // 闭包捕获：扫描匿名函数体，收集外层局部变量
        设 _闭包捕获变量 = {}
        此.收集捕获变量(节点.函数体块, 之前的符号表, 之前的类型表, _闭包捕获变量)

        // 为每个捕获变量创建全局桥接 + 在外层函数生成 store 指令（切换上下文前）
        设 _捕获全局映射 = {}
        遍历 _捕获键 于 _闭包捕获变量 {
            若 _捕获键.包含?("_type") { 续 }
            设 _外存址2 = _闭包捕获变量[_捕获键]
            设 _全局名 = "@\"closure_" & 临时函数名 & "_" & _捕获键 & "\""
            此.全局声明列表.追加(_全局名 & " = global i64 0")
            // 生成 load+store 到外层函数的输出列表（用唯一后缀避免寄存器冲突）
            设 _外值2 = "%\"capture_" & _捕获键 & "\""
            之前的输出列表.追加("  " & _外值2 & " = load i64, i64* " & _外存址2)
            之前的输出列表.追加("  store i64 " & _外值2 & ", i64* " & _全局名)
            _捕获全局映射[_捕获键] = _全局名
        }
        此.作用域栈 = []
        此.寄存器数 = 0
        此.是全局 = 假

        设 参数声明 = []
        遍历 arg 于 节点.参数列表 {
            参数声明.追加("i64 %\"" & arg.标识符名称 & "_arg\"")
        }

        此.写出("define i64 @\"" & 临时函数名 & "\"(" & 参数声明.连接(", ") & ") {")
        此.写出("entry:")
        此.进作用域()
        // 闭包捕获：从全局桥接加载到闭包内新 alloca
        遍历 _捕获键2 于 _闭包捕获变量 {
            若 _捕获键2.包含?("_type") { 续 }
            设 _全局名2 = _捕获全局映射[_捕获键2]
            设 _内地址 = "%\"" & _捕获键2 & "\""
            此.写出("  " & _内地址 & " = alloca i64")
            设 _外值3 = 此.取新寄存器()
            此.写出("  " & _外值3 & " = load i64, i64* " & _全局名2)
            此.写出("  store i64 " & _外值3 & ", i64* " & _内地址)
            此.追踪对象(_内地址)
            此.符号表[_捕获键2] = _内地址
            设 _类型键2 = _捕获键2 & "_type"
            若 _闭包捕获变量.含?(_类型键2) { 此.变量类型表[_捕获键2] = _闭包捕获变量[_类型键2] }
        }
        遍历 arg2 于 节点.参数列表 {
            设 变量名 = arg2.标识符名称
            此.写出("  %\"" & 变量名 & "\" = alloca i64")
            此.写出("  store i64 %\"" & 变量名 & "_arg\", i64* %\"" & 变量名 & "\"")
            此.追踪对象("%\"" & 变量名 & "\"")
            此.符号表[变量名] = "%\"" & 变量名 & "\""
        }
        
        此.编译语句(节点.函数体块)

        // 闭包可变捕获：将捕获变量的当前值写回全局桥接，确保下次调用可见
        遍历 _捕获键3 于 _闭包捕获变量 {
            若 _捕获键3.包含?("_type") { 续 }
            设 _全局名3 = _捕获全局映射[_捕获键3]
            设 _内地址3 = "%\"" & _捕获键3 & "\""
            设 _当前值 = 此.取新寄存器()
            此.写出("  " & _当前值 & " = load i64, i64* " & _内地址3)
            此.写出("  store i64 " & _当前值 & ", i64* " & _全局名3)
        }

        若 非 此.最后是返回() {
            此.出作用域(真)
            此.写出("  ret i64 0")
        }
        此.写出("}")
        
        此.函数输出列表.追加(此.结果输出列表.连接(""))
        
        此.结果输出列表 = 之前的输出列表
        此.符号表 = 之前的符号表
        此.变量类型表 = 之前的类型表
        此.作用域栈 = 之前的作用域栈
        此.寄存器数 = 之前的寄存器计数
        此.是全局 = 之前的全局状态
        
        // 创建函数对象并返回
        设 funcObj = 此.取新寄存器()
        设 签名 = "i64 ("
        设 m = 0
        当 m < 节点.参数列表.长度 {
            签名 = 签名 & "i64"
            若 m < 节点.参数列表.长度 - 1 { 签名 = 签名 & ", " }
            m = m + 1
        }
        签名 = 签名 & ")*"
        此.写出("  " & funcObj & " = call i64 @xt_func_new(i8* bitcast (" & 签名 & " @\"" & 临时函数名 & "\" to i8*))")
        设 _r = [funcObj, "i64"]
        返 _r
    }

    函 执行动态调用(函指Xt, 参数列表) {
        设 函指Ptr = 此.取新寄存器()
        此.写出("  " & 函指Ptr & " = inttoptr i64 " & 函指Xt & " to %XTFunction*")
        设 函指_raw_ptr = 此.取新寄存器()
        此.写出("  " & 函指_raw_ptr & " = getelementptr %XTFunction, %XTFunction* " & 函指Ptr & ", i32 0, i32 3")
        设 函指_raw = 此.取新寄存器()
        此.写出("  " & 函指_raw & " = load i8*, i8** " & 函指_raw_ptr)
        设 调用签名 = "i64 ("
        设 k = 0
        当 k < 参数列表.长度 {
            调用签名 = 调用签名 & "i64"
            若 k < 参数列表.长度 - 1 { 调用签名 = 调用签名 & ", " }
            k = k + 1
        }
        调用签名 = 调用签名 & ")*"
        设 函指强转 = 此.取新寄存器()
        此.写出("  " & 函指强转 & " = bitcast i8* " & 函指_raw & " to " & 调用签名)
        设 结果寄存器 = 此.取新寄存器()
        此.写出("  " & 结果寄存器 & " = call i64 " & 函指强转 & "(" & 参数列表.连接(", ") & ")")
        返 结果寄存器
    }

    函 展开限定名(节点) {
        若 节点.节点类别 == "标识符" { 返 节点.标识符名称 }
        若 节点.节点类别 == "成员访问" {
            设 左 = 此.展开限定名(节点.左表达式)
            若 左 != "" { 返 左 & "." & 节点.成员名称 }
        }
        返 ""
    }

    函 编译调用表达式(节点) {
        设 函数表达式 = 节点.函数表达式

        // --- P0: 优先处理类名静态调用 (如 按钮.渲染(此)) ---
        若 函数表达式.节点类别 == "成员访问" {
            设 左节点 = 函数表达式.左表达式
            若 左节点.节点类别 == "标识符" {
                设 类名 = 左节点.标识符名称
                若 此.类型表.含?(类名) {
                    设 类信息 = 此.类型表[类名]
                    设 成员名 = 函数表达式.成员名称
                    设 函名 = ""
                    遍历 方法项 于 类信息.最终方法列表 {
                        若 方法项.原始函数名 == 成员名 {
                            函名 = "@\"" & 方法项.函数名 & "\""
                            断
                        }
                    }

                    若 函名 != "" {
                        设 参数结果 = []
                        设 释放寄存器 = []
                        遍历 p参数 于 节点.调用参数 {
                            设 翻译参 = 此.编译表达式(p参数)
                            设 xtVal = 此.确保I64(翻译参[0], 翻译参[1])
                            参数结果.追加("i64 " & xtVal)
                            释放寄存器.追加(xtVal)
                        }
                        设 res = 此.取新寄存器()
                        此.写出("  " & res & " = call i64 " & 函名 & "(" & 参数结果.连接(", ") & ")")
                        遍历 r_static 于 释放寄存器 { 此.写出("  call void @xt_release(i64 " & r_static & ")") }
                        设 _r = [res, "i64"]
                        返 _r
                    }
                }
            }
        }
        
        // 尝试解析为完整的限定名（处理多级命名空间）
        设 完整名 = 此.展开限定名(函数表达式)
        若 完整名 != "" {
            若 此.函数表.含?(完整名) {
                设 真实名 = 此.符号表[完整名]
                若 真实名 != 空 且 真实名 != "" {
                    // 特殊处理内置变参函数：数学.最大值, 数学.最小值
                    若 完整名 == "数学.最大值" 或 完整名 == "数学.最小值" {
                        设 alen = 节点.调用参数.长度
                        设 arrReg = 此.取新寄存器()
                        此.写出("  " & arrReg & " = call i64 @xt_array_new(i64 " & alen & ")")
                        遍历 p_math 于 节点.调用参数 {
                            设 翻译p = 此.编译表达式(p_math)
                            设 pXt = 此.确保I64(翻译p[0], 翻译p[1])
                            此.写出("  call void @xt_array_append(i64 " & arrReg & ", i64 " & pXt & ")")
                            此.写_释放_xt(翻译p[0], 翻译p[1])
                        }
                        设 res_math = 此.取新寄存器()
                        此.写出("  " & res_math & " = call i64 " & 真实名 & "(i64 " & arrReg & ")")
                        此.写出("  call void @xt_release(i64 " & arrReg & ")")
                        设 _r = [res_math, "i64"]
                        返 _r
                    }

                    设 my参数结果列表 = []
                    设 my释放寄存器列表 = []
                    遍历 arg 于 节点.调用参数 {
                        设 翻译 = 此.编译表达式(arg)
                        设 xtVal = 此.确保I64(翻译[0], 翻译[1])
                        my参数结果列表.追加("i64 " & xtVal)
                        my释放寄存器列表.追加(xtVal)
                    }
                    设 res = 此.取新寄存器()
                    此.写出("  " & res & " = call i64 " & 真实名 & "(" & my参数结果列表.连接(", ") & ")")
                    遍历 r_call 于 my释放寄存器列表 { 此.写出("  call void @xt_release(i64 " & r_call & ")") }

                    若 节点.推导类型 == "整" {
                        设 rawRes = 此.取新寄存器()
                        此.写出("  " & rawRes & " = ashr i64 " & res & ", 1")
                        设 _r = [rawRes, "raw_i64"]
                        返 _r
                    }
                    若 此.函数返回类型表.含?(完整名) {
                        设 retTy = 此.函数返回类型表[完整名]
                        若 retTy == "raw_i64" {
                            设 rawRes = 此.取新寄存器()
                            此.写出("  " & rawRes & " = ashr i64 " & res & ", 1")
                            设 _r = [rawRes, "raw_i64"]
                            返 _r
                        }
                    }
                    设 _r = [res, "i64"]
                    返 _r
                }
            }
        }
        
        // 处理内建工厂和转换函数
        匹配 函数表达式.节点类别 {
            "整" -> {
                设 翻译参数 = 此.编译表达式(节点.调用参数[0])
                设 xtVal = 此.确保I64(翻译参数[0], 翻译参数[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_convert_to_int(i64 " & xtVal & ")")
                此.写出("  call void @xt_release(i64 " & xtVal & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            "小数类型" -> {
                设 翻译参数 = 此.编译表达式(节点.调用参数[0])
                设 xtVal = 此.确保I64(翻译参数[0], 翻译参数[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_convert_to_float(i64 " & xtVal & ")")
                此.写出("  call void @xt_release(i64 " & xtVal & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            "字" -> {
                设 翻译参数 = 此.编译表达式(节点.调用参数[0])
                设 xtVal = 此.确保I64(翻译参数[0], 翻译参数[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_convert_to_string(i64 " & xtVal & ")")
                此.写出("  call void @xt_release(i64 " & xtVal & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            "道" -> {
                设 初始容量 = "16"
                若 节点.调用参数.长度 > 0 {
                    设 翻译容量 = 此.编译表达式(节点.调用参数[0])
                    初始容量 = 此.确保RawI64(翻译容量[0], 翻译容量[1])
                }
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_channel_new(i64 " & 初始容量 & ")")
                设 _r = [res, "i64"]
                返 _r
            }
        }
        
        若 函数表达式.节点类别 == "标识符" {
            设 全局函数名 = 函数表达式.标识符名称
            若 全局函数名 == "成功" 或 全局函数名 == "失败" {
                设 isSuccess = "1"
                若 全局函数名 == "失败" { isSuccess = "0" }
                设 翻译参数 = 此.编译表达式(节点.调用参数[0])
                设 参数对象 = 此.转为对象(翻译参数[0], 翻译参数[1])
                设 objReg = 参数对象[0]
                设 resPtr = 此.取新寄存器()
                若 全局函数名 == "成功" {
                    此.写出("  " & resPtr & " = call i8* @xt_result_new(i32 " & isSuccess & ", i8* " & objReg & ", i8* null)")
                } 否 {
                    此.写出("  " & resPtr & " = call i8* @xt_result_new(i32 " & isSuccess & ", i8* null, i8* " & objReg & ")")
                }
                设 xtVal = 此.确保I64(翻译参数[0], 翻译参数[1])
                此.写出("  call void @xt_release(i64 " & xtVal & ")")
                设 resI64 = 此.取新寄存器()
                此.写出("  " & resI64 & " = ptrtoint i8* " & resPtr & " to i64")
                设 _r = [resI64, "i64"]
                返 _r
            }
        }
        若 函数表达式.节点类别 == "成员访问" {
            设 成员名 = 函数表达式.成员名称
            设 左节点 = 函数表达式.左表达式
            
            设 翻译左 = 此.编译表达式(左节点)
            设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
            设 左类型 = 翻译左[1]
            
            // 访问控制检查
            此.检查访问权限(左类型, 成员名, 节点)

            若 成员名 == "截取" {
                设 strPtr = 此.取新寄存器()
                此.写出("  " & strPtr & " = inttoptr i64 " & 对象Xt & " to %XTString*")
                设 翻译始 = 此.编译表达式(节点.调用参数[0])
                设 始Raw = 此.确保RawI64(翻译始[0], 翻译始[1])
                设 终Raw = 此.取新寄存器()
                若 节点.调用参数.长度 > 1 {
                    设 翻译终 = 此.编译表达式(节点.调用参数[1])
                    终Raw = 此.确保RawI64(翻译终[0], 翻译终[1])
                } 否 {
                    设 lenXt = 此.取新寄存器()
                    此.写出("  " & lenXt & " = call i64 @xt_string_byte_length(i64 " & 对象Xt & ")")
                    此.写出("  " & 终Raw & " = ashr i64 " & lenXt & ", 1")
                }
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call %XTString* @xt_string_substring(%XTString* " & strPtr & ", i64 " & 始Raw & ", i64 " & 终Raw & ")")
                设 resI64 = 此.取新寄存器()
                此.写出("  " & resI64 & " = ptrtoint %XTString* " & res & " to i64")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                设 _r = [resI64, "i64"]
                返 _r
            }
            若 成员名 == "追加" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译元 = 此.编译表达式(节点.调用参数[0])
                设 元Xt = 此.确保I64(翻译元[0], 翻译元[1])
                
                // 根据类型调用追加 (Array vs Bytes)
                设 objPtr = 此.取新寄存器()
                此.写出("  " & objPtr & " = inttoptr i64 " & 对象Xt & " to %XTObject*")
                设 typeIdPtr = 此.取新寄存器()
                此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & objPtr & ", i32 0, i32 2")
                设 typeId = 此.取新寄存器()
                此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
                
                设 isArr = 此.取新寄存器()
                此.写出("  " & isArr & " = icmp eq i32 " & typeId & ", 5")
                设 arrLabel = 此.取新标签("append.arr")
                设 bytesLabel = 此.取新标签("append.bytes")
                设 endLabel = 此.取新标签("append.end")
                此.写出("  br i1 " & isArr & ", label %" & arrLabel & ", label %" & bytesLabel)
                
                此.写出(arrLabel & ":")
                此.写出("  call void @xt_array_append(i64 " & 对象Xt & ", i64 " & 元Xt & ")")
                此.写出("  br label %" & endLabel)
                
                此.写出(bytesLabel & ":")
                设 rawByte = 此.取新寄存器()
                此.写出("  " & rawByte & " = ashr i64 " & 元Xt & ", 1")
                设 truncByte = 此.取新寄存器()
                此.写出("  " & truncByte & " = trunc i64 " & rawByte & " to i8")
                此.写出("  call void @xt_bytes_append(i64 " & 对象Xt & ", i8 " & truncByte & ")")
                此.写出("  br label %" & endLabel)
                
                此.写出(endLabel & ":")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 元Xt & ")")
                返 ["0", "i64"]
            }
            若 成员名 == "删" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译参 = 此.编译表达式(节点.调用参数[0])
                设 参Xt = 此.确保I64(翻译参[0], 翻译参[1])
                
                设 objPtr = 此.取新寄存器()
                此.写出("  " & objPtr & " = inttoptr i64 " & 对象Xt & " to %XTObject*")
                设 typeIdPtr = 此.取新寄存器()
                此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & objPtr & ", i32 0, i32 2")
                设 typeId = 此.取新寄存器()
                此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
                
                设 isArr = 此.取新寄存器()
                此.写出("  " & isArr & " = icmp eq i32 " & typeId & ", 5")
                设 arrLabel = 此.取新标签("del.arr")
                设 dictLabel = 此.取新标签("del.dict")
                设 endLabel = 此.取新标签("del.end")
                此.写出("  br i1 " & isArr & ", label %" & arrLabel & ", label %" & dictLabel)
                
                此.写出(arrLabel & ":")
                此.写出("  call void @xt_array_remove(i64 " & 对象Xt & ", i64 " & 参Xt & ")")
                此.写出("  br label %" & endLabel)
                
                此.写出(dictLabel & ":")
                此.写出("  call void @xt_dict_remove(i64 " & 对象Xt & ", i64 " & 参Xt & ")")
                此.写出("  br label %" & endLabel)
                
                此.写出(endLabel & ":")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 参Xt & ")")
                返 ["0", "i64"]
            }
            若 成员名 == "插" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译索引 = 此.编译表达式(节点.调用参数[0])
                设 索引Xt = 此.确保I64(翻译索引[0], 翻译索引[1])
                设 翻译值 = 此.编译表达式(节点.调用参数[1])
                设 值Xt = 此.确保I64(翻译值[0], 翻译值[1])
                此.写出("  call void @xt_array_insert(i64 " & 对象Xt & ", i64 " & 索引Xt & ", i64 " & 值Xt & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 索引Xt & ")")
                此.写出("  call void @xt_release(i64 " & 值Xt & ")")
                返 ["0", "i64"]
            }
            若 成员名 == "找" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译参 = 此.编译表达式(节点.调用参数[0])
                设 参Xt = 此.确保I64(翻译参[0], 翻译参[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_array_find(i64 " & 对象Xt & ", i64 " & 参Xt & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 参Xt & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            若 成员名 == "键" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_dict_keys(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            若 成员名 == "值" {
                // 如果是 Result 已经处理过了，这里是通用的字典 .值()
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_dict_values(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            若 成员名 == "分割" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译参 = 此.编译表达式(节点.调用参数[0])
                设 参Xt = 此.确保I64(翻译参[0], 翻译参[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_string_split(i64 " & 对象Xt & ", i64 " & 参Xt & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 参Xt & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            若 成员名 == "替换" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译参1 = 此.编译表达式(节点.调用参数[0])
                设 参1Xt = 此.确保I64(翻译参1[0], 翻译参1[1])
                设 翻译参2 = 此.编译表达式(节点.调用参数[1])
                设 参2Xt = 此.确保I64(翻译参2[0], 翻译参2[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_string_replace(i64 " & 对象Xt & ", i64 " & 参1Xt & ", i64 " & 参2Xt & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 参1Xt & ")")
                此.写出("  call void @xt_release(i64 " & 参2Xt & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            若 成员名 == "字符" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译索引 = 此.编译表达式(节点.调用参数[0])
                设 索引Raw = 此.确保RawI64(翻译索引[0], 翻译索引[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_string_get_char(i64 " & 对象Xt & ", i64 " & 索引Raw & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 索引Raw & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            若 成员名 == "字节" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译索引 = 此.编译表达式(节点.调用参数[0])
                设 索引Raw = 此.确保RawI64(翻译索引[0], 翻译索引[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_string_get_byte(i64 " & 对象Xt & ", i64 " & 索引Raw & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 索引Raw & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            若 成员名 == "连接" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译隔 = 此.编译表达式(节点.调用参数[0])
                设 隔Xt = 此.确保I64(翻译隔[0], 翻译隔[1])
                设 隔Str = 此.取新寄存器()
                此.写出("  " & 隔Str & " = inttoptr i64 " & 隔Xt & " to %XTString*")
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call %XTString* @xt_array_join(i64 " & 对象Xt & ", %XTString* " & 隔Str & ")")
                设 resI64 = 此.取新寄存器()
                此.写出("  " & resI64 & " = ptrtoint %XTString* " & res & " to i64")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 隔Xt & ")")
                设 _r = [resI64, "i64"]
                返 _r
            }
            若 成员名 == "解包" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 resAddr = 此.取新寄存器()
                此.写出("  " & resAddr & " = alloca i64")
                此.写出("  store i64 0, i64* " & resAddr)
                设 resPtr = 此.取新寄存器()
                此.写出("  " & resPtr & " = inttoptr i64 " & 对象Xt & " to %XTResult*")
                设 isSuccPtr = 此.取新寄存器()
                此.写出("  " & isSuccPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 3")
                设 isSuccI32 = 此.取新寄存器()
                此.写出("  " & isSuccI32 & " = load i32, i32* " & isSuccPtr)
                设 isSucc = 此.取新寄存器()
                此.写出("  " & isSucc & " = icmp ne i32 " & isSuccI32 & ", 0")
                设 valPtrPtr = 此.取新寄存器()
                此.写出("  " & valPtrPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 5")
                设 errPtrPtr = 此.取新寄存器()
                此.写出("  " & errPtrPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 6")
                设 valPtr = 此.取新寄存器()
                此.写出("  " & valPtr & " = load i64, i64* " & valPtrPtr)
                设 errPtr = 此.取新寄存器()
                此.写出("  " & errPtr & " = load i64, i64* " & errPtrPtr)
                设 resReg = 此.取新寄存器()
                此.写出("  " & resReg & " = select i1 " & isSucc & ", i64 " & valPtr & ", i64 " & errPtr)
                此.写_存储_xt(resReg, "i64", resAddr)
                设 finalVal = 此.取新寄存器()
                此.写出("  " & finalVal & " = load i64, i64* " & resAddr)
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                设 _r = [finalVal, "i64"]
                返 _r
            }
            若 成员名 == "接着" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 resPtr = 此.取新寄存器()
                此.写出("  " & resPtr & " = inttoptr i64 " & 对象Xt & " to %XTResult*")
                设 isSuccPtr = 此.取新寄存器()
                此.写出("  " & isSuccPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 3")
                设 isSuccI32 = 此.取新寄存器()
                此.写出("  " & isSuccI32 & " = load i32, i32* " & isSuccPtr)
                设 isSucc = 此.取新寄存器()
                此.写出("  " & isSucc & " = icmp ne i32 " & isSuccI32 & ", 0")
                
                设 thenLabel = 此.取新标签("res.then")
                设 mergeLabel = 此.取新标签("res.merge")
                设 resAddr = 此.取新寄存器()
                此.写出("  " & resAddr & " = alloca i64")
                此.写出("  store i64 " & 对象Xt & ", i64* " & resAddr)
                
                此.写出("  br i1 " & isSucc & ", label %" & thenLabel & ", label %" & mergeLabel)
                
                此.写出(thenLabel & ":")
                设 valPtrPtr = 此.取新寄存器()
                此.写出("  " & valPtrPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 5")
                设 val = 此.取新寄存器()
                此.写出("  " & val & " = load i64, i64* " & valPtrPtr)
                
                设 翻译参 = 此.编译表达式(节点.调用参数[0])
                设 函指Xt = 此.确保I64(翻译参[0], 翻译参[1])
                
                设 callbackRes = 此.执行动态调用(函指Xt, ["i64 " & val])
                此.写出("  store i64 " & callbackRes & ", i64* " & resAddr)
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 函指Xt & ")")
                此.写出("  br label %" & mergeLabel)
                
                此.写出(mergeLabel & ":")
                设 finalVal = 此.取新寄存器()
                此.写出("  " & finalVal & " = load i64, i64* " & resAddr)
                设 _r = [finalVal, "i64"]
                返 _r
            }
            若 成员名 == "否则" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 resPtr = 此.取新寄存器()
                此.写出("  " & resPtr & " = inttoptr i64 " & 对象Xt & " to %XTResult*")
                设 isSuccPtr = 此.取新寄存器()
                此.写出("  " & isSuccPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 3")
                设 isSuccI32 = 此.取新寄存器()
                此.写出("  " & isSuccI32 & " = load i32, i32* " & isSuccPtr)
                设 isFail = 此.取新寄存器()
                此.写出("  " & isFail & " = icmp eq i32 " & isSuccI32 & ", 0")
                
                设 failLabel = 此.取新标签("res.fail")
                设 mergeLabel = 此.取新标签("res.merge")
                设 resAddr = 此.取新寄存器()
                此.写出("  " & resAddr & " = alloca i64")
                此.写出("  store i64 " & 对象Xt & ", i64* " & resAddr)
                
                此.写出("  br i1 " & isFail & ", label %" & failLabel & ", label %" & mergeLabel)
                
                此.写出(failLabel & ":")
                设 errPtrPtr = 此.取新寄存器()
                此.写出("  " & errPtrPtr & " = getelementptr %XTResult, %XTResult* " & resPtr & ", i32 0, i32 6")
                设 err = 此.取新寄存器()
                此.写出("  " & err & " = load i64, i64* " & errPtrPtr)
                
                设 翻译参 = 此.编译表达式(节点.调用参数[0])
                设 函指Xt = 此.确保I64(翻译参[0], 翻译参[1])
                
                设 callbackRes = 此.执行动态调用(函指Xt, ["i64 " & err])
                此.写出("  store i64 " & callbackRes & ", i64* " & resAddr)
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 函指Xt & ")")
                此.写出("  br label %" & mergeLabel)
                
                此.写出(mergeLabel & ":")
                设 finalVal = 此.取新寄存器()
                此.写出("  " & finalVal & " = load i64, i64* " & resAddr)
                设 _r = [finalVal, "i64"]
                返 _r
            }

            若 成员名 == "含?" 或 成员名 == "包含?" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译参 = 此.编译表达式(节点.调用参数[0])
                设 参Xt = 此.确保I64(翻译参[0], 翻译参[1])

                // 读取 type_id 做类型分派
                设 objPtr = 此.取新寄存器()
                此.写出("  " & objPtr & " = inttoptr i64 " & 对象Xt & " to %XTObject*")
                设 typeIdPtr = 此.取新寄存器()
                此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & objPtr & ", i32 0, i32 2")
                设 typeId = 此.取新寄存器()
                此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
                设 isStr = 此.取新寄存器()
                此.写出("  " & isStr & " = icmp eq i32 " & typeId & ", 3")
                设 strLabel = 此.标(此.取新标签("contains.str"))
                设 dictLabel = 此.标(此.取新标签("contains.dict"))
                设 mergeLabel_c = 此.标(此.取新标签("contains.merge"))
                此.写出("  br i1 " & isStr & ", label %" & strLabel & ", label %" & dictLabel)

                此.写出(strLabel & ":")
                设 s1Ptr = 此.取新寄存器()
                此.写出("  " & s1Ptr & " = inttoptr i64 " & 对象Xt & " to %XTString*")
                设 argI8Ptr = 此.取新寄存器()
                此.写出("  " & argI8Ptr & " = inttoptr i64 " & 参Xt & " to i8*")
                设 s2Ptr = 此.取新寄存器()
                此.写出("  " & s2Ptr & " = bitcast i8* " & argI8Ptr & " to %XTString*")
                设 sRes = 此.取新寄存器()
                此.写出("  " & sRes & " = call i32 @xt_string_contains(%XTString* " & s1Ptr & ", %XTString* " & s2Ptr & ")")
                设 sCond = 此.取新寄存器()
                此.写出("  " & sCond & " = icmp ne i32 " & sRes & ", 0")
                设 sResI64 = 此.取新寄存器()
                此.写出("  " & sResI64 & " = select i1 " & sCond & ", i64 4, i64 2")
                此.写出("  br label %" & mergeLabel_c)

                此.写出(dictLabel & ":")
                设 dRes = 此.取新寄存器()
                此.写出("  " & dRes & " = call i32 @xt_dict_contains(i64 " & 对象Xt & ", i64 " & 参Xt & ")")
                设 dCond = 此.取新寄存器()
                此.写出("  " & dCond & " = icmp ne i32 " & dRes & ", 0")
                设 dResI64 = 此.取新寄存器()
                此.写出("  " & dResI64 & " = select i1 " & dCond & ", i64 4, i64 2")
                此.写出("  br label %" & mergeLabel_c)

                此.写出(mergeLabel_c & ":")
                设 resI64 = 此.取新寄存器()
                此.写出("  " & resI64 & " = phi i64 [ " & sResI64 & ", %" & strLabel & " ], [ " & dResI64 & ", %" & dictLabel & " ]")

                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 参Xt & ")")
                设 _r = [resI64, "i64"]
                返 _r
            }
            
            若 成员名 == "发" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译参 = 此.编译表达式(节点.调用参数[0])
                设 参Xt = 此.确保I64(翻译参[0], 翻译参[1])
                此.写出("  call void @xt_channel_send(i64 " & 对象Xt & ", i64 " & 参Xt & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 参Xt & ")")
                返 ["0", "i64"]
            }
            若 成员名 == "收" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = call i64 @xt_channel_receive(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                设 _r = [res, "i64"]
                返 _r
            }
            若 成员名 == "追加" {
                设 翻译左 = 此.编译表达式(左节点)
                设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
                设 翻译元 = 此.编译表达式(节点.调用参数[0])
                设 元Xt = 此.确保I64(翻译元[0], 翻译元[1])
                
                // 根据类型调用追加 (Array vs Bytes)
                设 objPtr = 此.取新寄存器()
                此.写出("  " & objPtr & " = inttoptr i64 " & 对象Xt & " to %XTObject*")
                设 typeIdPtr = 此.取新寄存器()
                此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & objPtr & ", i32 0, i32 2")
                设 typeId = 此.取新寄存器()
                此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
                
                设 isArr = 此.取新寄存器()
                此.写出("  " & isArr & " = icmp eq i32 " & typeId & ", 5")
                设 arrLabel = 此.取新标签("append.arr")
                设 bytesLabel = 此.取新标签("append.bytes")
                设 endLabel = 此.取新标签("append.end")
                此.写出("  br i1 " & isArr & ", label %" & arrLabel & ", label %" & bytesLabel)
                
                此.写出(arrLabel & ":")
                此.写出("  call void @xt_array_append(i64 " & 对象Xt & ", i64 " & 元Xt & ")")
                此.写出("  br label %" & endLabel)
                
                此.写出(bytesLabel & ":")
                设 rawByte = 此.取新寄存器()
                此.写出("  " & rawByte & " = ashr i64 " & 元Xt & ", 1")
                设 truncByte = 此.取新寄存器()
                此.写出("  " & truncByte & " = trunc i64 " & rawByte & " to i8")
                此.写出("  call void @xt_bytes_append(i64 " & 对象Xt & ", i8 " & truncByte & ")")
                此.写出("  br label %" & endLabel)
                
                此.写出(endLabel & ":")
                此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
                此.写出("  call void @xt_release(i64 " & 元Xt & ")")
                返 ["0", "i64"]
            }
            设 翻译左 = 此.编译表达式(左节点)
            设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
            设 键Xt = 此.获取字符串对象(成员名)
            设 函指Xt = 此.取新寄存器()
            此.写出("  " & 函指Xt & " = call i64 @xt_dict_get(i64 " & 对象Xt & ", i64 " & 键Xt & ")")
            此.写出("  call void @xt_retain(i64 " & 函指Xt & ")")
            此.写出("  call void @xt_release(i64 " & 键Xt & ")")
            设 my参数结果列表 = ["i64 " & 对象Xt]
            设 my释放寄存器列表 = [对象Xt, 函指Xt]
            遍历 p参数1 于 节点.调用参数 {
                设 翻译参数 = 此.编译表达式(p参数1)
                设 xt_val = 此.确保I64(翻译参数[0], 翻译参数[1])
                my参数结果列表.追加("i64 " & xt_val)
                my释放寄存器列表.追加(xt_val)
            }
            设 结果寄存器 = 此.执行动态调用(函指Xt, my参数结果列表)
            遍历 r3 于 my释放寄存器列表 { 此.写出("  call void @xt_release(i64 " & r3 & ")") }
            设 _r = [结果寄存器, "i64"]
            返 _r
        }
        设 翻译函数 = 此.编译表达式(函数表达式)
        设 函指 = 翻译函数[0]
        设 函类 = 翻译函数[1]
        
        设 参数声明 = []
        设 my释放寄存器列表2 = []
        遍历 p参数2 于 节点.调用参数 {
            设 翻译参数 = 此.编译表达式(p参数2)
            设 xt_val = 此.确保I64(翻译参数[0], 翻译参数[1])
            参数声明.追加("i64 " & xt_val)
            my释放寄存器列表2.追加(xt_val)
        }
        设 结果寄存器 = 此.取新寄存器()
        若 函类 == "函数名" 或 函类 == "未知标识符" 或 函类 == "标识符" {
            // 如果是“未知标识符”，仅在调用场景下尝试作为外部函数名
            设 实际函数名 = "@\"" & 函指 & "\""
            // 针对 printf 等外部函数，将第一个参数（格式化字符串）转为 i8*
            设 final参数声明 = []
            若 函指 == "printf" 且 参数声明.长度 > 0 {
                设 firstArg = 参数声明[0]
                // firstArg 格式是 "i64 %tN"
                设 reg = firstArg.截取(4, firstArg.长度)
                
                设 sPtr = 此.取新寄存器()
                此.写出("  " & sPtr & " = inttoptr i64 " & reg & " to %XTString*")
                设 dataPtrPtr = 此.取新寄存器()
                此.写出("  " & dataPtrPtr & " = getelementptr %XTString, %XTString* " & sPtr & ", i32 0, i32 3")
                设 realData = 此.取新寄存器()
                此.写出("  " & realData & " = load i8*, i8** " & dataPtrPtr)
                final参数声明.追加("i8* " & realData)
                
                设 i = 1
                当 i < 参数声明.长度 {
                    final参数声明.追加(参数声明[i])
                    i = i + 1
                }
            } 否 {
                final参数声明 = 参数声明
            }

            若 函指 == "printf" {
                设 resI32 = 此.取新寄存器()
                设 fmtObjReg = my释放寄存器列表2[0]
                设 sPtr = 此.取新寄存器()
                此.写出("  " & sPtr & " = inttoptr i64 " & fmtObjReg & " to %XTString*")
                
                设 valReg = "i64 0"
                若 my释放寄存器列表2.长度 > 1 {
                    valReg = "i64 " & my释放寄存器列表2[1]
                }

                此.写出("  " & resI32 & " = call i32 (%XTString*, ...) @xt_ffi_printf(%XTString* " & sPtr & ", " & valReg & ")")
                此.写出("  " & 结果寄存器 & " = sext i32 " & resI32 & " to i64")
            } 否 {
                此.写出("  " & 结果寄存器 & " = call i64 " & 实际函数名 & "(" & final参数声明.连接(", ") & ")")
                
                若 节点.推导类型 == "整" {
                    设 rawRes = 此.取新寄存器()
                    此.写出("  " & rawRes & " = ashr i64 " & 结果寄存器 & ", 1")
                    设 _r = [rawRes, "raw_i64"]
                    返 _r
                }
                若 此.函数返回类型表.含?(函指) {
                    设 retTy = 此.函数返回类型表[函指]
                    若 retTy == "raw_i64" {
                        设 rawRes = 此.取新寄存器()
                        此.写出("  " & rawRes & " = ashr i64 " & 结果寄存器 & ", 1")
                        设 _r = [rawRes, "raw_i64"]
                        返 _r
                    }
                }
            }
        } 否 {
            设 函指Xt = 此.确保I64(函指, 函类)
            my释放寄存器列表2.追加(函指Xt)
            结果寄存器 = 此.执行动态调用(函指Xt, 参数声明)
        }
        遍历 r4 于 my释放寄存器列表2 { 此.写出("  call void @xt_release(i64 " & r4 & ")") }
        设 _r = [结果寄存器, "i64"]
        返 _r
    }

    函 编译中缀(节点) {
        设 翻译左 = 此.编译表达式(节点.中缀左)
        设 左寄存器 = 翻译左[0]
        设 左类型 = 翻译左[1]
        
        设 翻译右 = 此.编译表达式(节点.中缀右)
        设 右寄存器 = 翻译右[0]
        设 右类型 = 翻译右[1]
        
        // 1. 尝试运算符重载
        设 魔术方法 = ""
        匹配 节点.中缀运算符 {
            "+" -> { 魔术方法 = "_加_" }
            "-" -> { 魔术方法 = "_减_" }
            "*" -> { 魔术方法 = "_乘_" }
            "/" -> { 魔术方法 = "_除_" }
            "%" -> { 魔术方法 = "_模_" }
            "==" -> { 魔术方法 = "_等_" }
        }
        
        若 魔术方法 != "" {
            // 标量快速路径：已知不是堆对象，直接走原生指令
            若 此.是标量类型(左类型) 且 此.是标量类型(右类型) {
                返 此.编译内建中缀(节点, 左寄存器, 左类型, 右寄存器, 右类型)
            }
            // == 和 != 对非标量类型直接走内建路径（xt_eq），
            // 避免运算符重载产生的内联 alloca 在 3+ 若/抑 条件下导致运行时堆损坏
            若 节点.中缀运算符 == "==" 或 节点.中缀运算符 == "!=" {
                返 此.编译内建中缀(节点, 左寄存器, 左类型, 右寄存器, 右类型)
            }
            设 键Xt = 此.获取字符串对象(魔术方法)
            设 左Xt = 此.确保I64(左寄存器, 左类型)
            
            // 安全检查：只有指针对象才能进行动态分发
            设 isPtr = 此.取新寄存器()
            此.写出("  " & isPtr & " = and i64 " & 左Xt & ", 1")
            设 isRealPtr = 此.取新寄存器()
            此.写出("  " & isRealPtr & " = icmp eq i64 " & isPtr & ", 0")
            
            设 checkLabel = 此.取新标签("op.check")
            设 fallbackLabel = 此.取新标签("op.fallback")
            设 overloadLabel = 此.取新标签("op.overload")
            设 mergeLabel = 此.取新标签("op.merge")
            
            设 resAddr = 此.取新寄存器()
            此.写出("  " & resAddr & " = alloca i64")
            此.写出("  store i64 0, i64* " & resAddr)
            
            此.写出("  br i1 " & isRealPtr & ", label %" & checkLabel & ", label %" & fallbackLabel)
            
            此.写出(checkLabel & ":")
            设 函指Xt = 此.取新寄存器()
            此.写出("  " & 函指Xt & " = call i64 @xt_dict_get(i64 " & 左Xt & ", i64 " & 键Xt & ")")
            
            设 isFunc = 此.取新寄存器()
            此.写出("  " & isFunc & " = icmp ne i64 " & 函指Xt & ", 0")
            此.写出("  br i1 " & isFunc & ", label %" & overloadLabel & ", label %" & fallbackLabel)
            
            此.写出(overloadLabel & ":")
            设 右Xt = 此.确保I64(右寄存器, 右类型)
            设 my参数 = ["i64 " & 左Xt, "i64 " & 右Xt]
            此.写出("  call void @xt_retain(i64 " & 函指Xt & ")")
            设 ovRes = 此.执行动态调用(函指Xt, my参数)
            此.写_存储_xt(ovRes, "i64", resAddr)
            此.写出("  call void @xt_release(i64 " & 函指Xt & ")")
            此.写出("  call void @xt_release(i64 " & 右Xt & ")")
            此.写出("  br label %" & mergeLabel)
            
            此.写出(fallbackLabel & ":")
            设 fbRes = 此.编译内建中缀(节点, 左寄存器, 左类型, 右寄存器, 右类型)
            此.写_存储_xt(fbRes[0], fbRes[1], resAddr)
            此.写出("  br label %" & mergeLabel)
            
            此.写出(mergeLabel & ":")
            设 finalVal = 此.取新寄存器()
            此.写出("  " & finalVal & " = load i64, i64* " & resAddr)
            
            此.写出("  call void @xt_release(i64 " & 键Xt & ")")
            此.写出("  call void @xt_release(i64 " & 左Xt & ")")
            设 _r = [finalVal, "i64"]
            返 _r
        }
        
        返 此.编译内建中缀(节点, 左寄存器, 左类型, 右寄存器, 右类型)
    }

    函 编译内建中缀(节点, 左寄存器, 左类型, 右寄存器, 右类型) {
        // --- 静态优化路径 ---
        若 节点.中缀左.推导类型 == "整" 且 节点.中缀右.推导类型 == "整" {
            设 指令 = ""
            匹配 节点.中缀运算符 {
                "+" -> { 指令 = "add" }
                "-" -> { 指令 = "sub" }
                "*" -> { 指令 = "mul" }
                "/" -> { 指令 = "sdiv" }
                "%" -> { 指令 = "srem" }
                "位与" -> { 指令 = "and" }
                "位或" -> { 指令 = "or" }
                "异或" -> { 指令 = "xor" }
                "左移" -> { 指令 = "shl" }
                "右移" -> { 指令 = "ashr" }
                "<" -> { 指令 = "icmp slt" }
                ">" -> { 指令 = "icmp sgt" }
                "<=" -> { 指令 = "icmp sle" }
                ">=" -> { 指令 = "icmp sge" }
                "==" -> { 指令 = "icmp eq" }
                "!=" -> { 指令 = "icmp ne" }
            }
            若 指令 != "" {
                设 左原 = 此.确保RawI64(左寄存器, 左类型)
                设 右原 = 此.确保RawI64(右寄存器, 右类型)
                设 res = 此.取新寄存器()
                此.写出("  " & res & " = " & 指令 & " i64 " & 左原 & ", " & 右原)
                
                // 修复：如果指令是 icmp，返回 i1 类型
                若 指令.包含?("icmp") { 返 [res, "i1"] }
                设 _r = [res, "raw_i64"]
                返 _r
            }
        }

        设 指令 = ""
        匹配 节点.中缀运算符 {
            "+" -> { 指令 = "add" }
            "-" -> { 指令 = "sub" }
            "*" -> { 指令 = "mul" }
            "/" -> { 指令 = "sdiv" }
            "%" -> { 指令 = "srem" }
            "<" -> { 指令 = "icmp slt" }
            ">" -> { 指令 = "icmp sgt" }
            "<=" -> { 指令 = "icmp sle" }
            ">=" -> { 指令 = "icmp sge" }
            "位与" -> { 指令 = "and" }
            "位或" -> { 指令 = "or" }
            "异或" -> { 指令 = "xor" }
            "左移" -> { 指令 = "shl" }
            "右移" -> { 指令 = "ashr" }
            "==" -> {
                设 左Xt = 此.确保I64(左寄存器, 左类型)
                设 右Xt = 此.确保I64(右寄存器, 右类型)
                设 左Obj = 此.取新寄存器()
                设 右Obj = 此.取新寄存器()
                此.写出("  " & 左Obj & " = inttoptr i64 " & 左Xt & " to i8*")
                此.写出("  " & 右Obj & " = inttoptr i64 " & 右Xt & " to i8*")
                设 eqRes = 此.取新寄存器()
                此.写出("  " & eqRes & " = call i32 @xt_eq(i8* " & 左Obj & ", i8* " & 右Obj & ")")
                设 cond = 此.取新寄存器()
                此.写出("  " & cond & " = icmp ne i32 " & eqRes & ", 0")
                此.写出("  call void @xt_release(i64 " & 左Xt & ")")
                设 _r = [cond, "i1"]
                返 _r
            }
            "!=" -> {
                设 新节点_neq = 造 中缀表达式节点(空, 节点.中缀左, 节点.中缀右)
                新节点_neq.中缀运算符 = "=="
                设 res_eq = 此.编译内建中缀(新节点_neq, 左寄存器, 左类型, 右寄存器, 右类型)
                设 res_neq = 此.取新寄存器()
                此.写出("  " & res_neq & " = xor i1 " & res_eq[0] & ", 1")
                设 _r = [res_neq, "i1"]
                返 _r
            }
        }
        
        若 指令 == "" { 返 ["0", "i64"] }
        
        设 左原 = 此.确保RawI64(左寄存器, 左类型)
        设 右原 = 此.确保RawI64(右寄存器, 右类型)
        设 res = 此.取新寄存器()
        此.写出("  " & res & " = " & 指令 & " i64 " & 左原 & ", " & 右原)
        此.写_释放_xt(左寄存器, 左类型)
        此.写_释放_xt(右寄存器, 右类型)
        
        // 修复：如果指令是 icmp，返回 i1 类型
        若 指令.包含?("icmp") { 返 [res, "i1"] }
        设 _r = [res, "raw_i64"]
        返 _r
    }

    函 编译逻辑且(节点) {
        设 翻译左 = 此.编译表达式(节点.中缀左)
        设 cond1 = 此.生成布尔条件(翻译左[0], 翻译左[1])
        设 resAddr = 此.取新寄存器()
        此.写出("  " & resAddr & " = alloca i1")
        此.写出("  store i1 0, i1* " & resAddr)
        设 trueLabel = 此.取新标签("and.true")
        设 endLabel = 此.取新标签("and.end")
        此.写出("  br i1 " & cond1 & ", label %" & trueLabel & ", label %" & endLabel)
        此.写出(trueLabel & ":")
        设 翻译右 = 此.编译表达式(节点.中缀右)
        设 cond2 = 此.生成布尔条件(翻译右[0], 翻译右[1])
        此.写出("  store i1 " & cond2 & ", i1* " & resAddr)
        此.写出("  br label %" & endLabel)
        此.写出(endLabel & ":")
        设 finalCond = 此.取新寄存器()
        此.写出("  " & finalCond & " = load i1, i1* " & resAddr)
        设 _r = [finalCond, "i1"]
        返 _r
    }

    函 编译逻辑或(节点) {
        设 翻译左 = 此.编译表达式(节点.中缀左)
        设 cond1 = 此.生成布尔条件(翻译左[0], 翻译左[1])
        设 resAddr = 此.取新寄存器()
        此.写出("  " & resAddr & " = alloca i1")
        此.写出("  store i1 1, i1* " & resAddr)
        设 falseLabel = 此.取新标签("or.false")
        设 endLabel = 此.取新标签("or.end")
        此.写出("  br i1 " & cond1 & ", label %" & endLabel & ", label %" & falseLabel)
        此.写出(falseLabel & ":")
        设 翻译右 = 此.编译表达式(节点.中缀右)
        设 cond2 = 此.生成布尔条件(翻译右[0], 翻译右[1])
        此.写出("  store i1 " & cond2 & ", i1* " & resAddr)
        此.写出("  br label %" & endLabel)
        此.写出(endLabel & ":")
        设 finalCond = 此.取新寄存器()
        此.写出("  " & finalCond & " = load i1, i1* " & resAddr)
        设 _r = [finalCond, "i1"]
        返 _r
    }

    函 编译赋值(节点) {
        设 翻译右 = 此.编译表达式(节点.中缀右)
        设 xt_val = 此.确保I64(翻译右[0], 翻译右[1])
        设 类型右 = 翻译右[1]

        若 节点.中缀左.节点类别 == "标识符" {
            设 变量名 = 节点.中缀左.标识符名称
            若 此.符号表.含?(变量名) {
                设 存址 = 此.符号表[变量名]

                // 弱引用变量：直接 store，跳过 release+retain
                若 此.弱引用变量集.含?(变量名) {
                    此.写出("  call void @xt_weak_init(i64* " & 存址 & ", i64 " & xt_val & ")")
                    此.写出("  store i64 " & xt_val & ", i64* " & 存址)
                    若 类型右 == "raw_i64" { 此.变量类型表[变量名] = "i64" } 否 { 此.变量类型表[变量名] = 类型右 }
                    设 _r = [xt_val, "i64"]
                    返 _r
                }

                // 获取旧变量类型
                设 类型旧 = "i64"
                若 此.变量类型表.含?(变量名) { 类型旧 = 此.变量类型表[变量名] }

                若 非 此.是标量类型(类型旧) {
                    设 oldVal = 此.取新寄存器()
                    此.写出("  " & oldVal & " = load i64, i64* " & 存址)
                    此.写出("  call void @xt_release(i64 " & oldVal & ")")
                }
                // 标量和非标量统一存 tagged 值；非标量额外 retain
                若 此.是标量类型(类型右) {
                    此.写出("  store i64 " & xt_val & ", i64* " & 存址)
                } 否 {
                    此.写出("  store i64 " & xt_val & ", i64* " & 存址)
                    此.写出("  call void @xt_retain(i64 " & xt_val & ")")
                }
                // 更新变量类型
                若 类型右 == "raw_i64" {
                    此.变量类型表[变量名] = "i64"
                } 否 {
                    此.变量类型表[变量名] = 类型右
                }
                // 检测是否被赋值为 Arena 池
                若 节点.中缀右.节点类别 == "调用表达式" {
                    设 调用 = 节点.中缀右
                    若 调用.函数表达式.节点类别 == "标识符" {
                        若 调用.函数表达式.标识符名称 == "xt_arena_new" {
                            此.arena池变量[存址] = 真
                        }
                    }
                }
            }
        } 抑 节点.中缀左.节点类别 == "索引表达式" {
            设 翻译左 = 此.编译表达式(节点.中缀左.左表达式)
            设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
            设 翻译索引 = 此.编译表达式(节点.中缀左.索引)
            设 索引Xt = 此.确保I64(翻译索引[0], 翻译索引[1])

            // 读取 type_id 做类型分派：字典走 xt_dict_set，数组走 xt_array_set
            设 objPtr = 此.取新寄存器()
            此.写出("  " & objPtr & " = inttoptr i64 " & 对象Xt & " to %XTObject*")
            设 typeIdPtr = 此.取新寄存器()
            此.写出("  " & typeIdPtr & " = getelementptr %XTObject, %XTObject* " & objPtr & ", i32 0, i32 2")
            设 typeId = 此.取新寄存器()
            此.写出("  " & typeId & " = load i32, i32* " & typeIdPtr)
            设 isDict = 此.取新寄存器()
            此.写出("  " & isDict & " = icmp eq i32 " & typeId & ", 6")
            设 dictLabel = 此.标(此.取新标签("idx_asg.dict"))
            设 arrLabel = 此.标(此.取新标签("idx_asg.arr"))
            设 mergeLabel_ia = 此.标(此.取新标签("idx_asg.merge"))
            此.写出("  br i1 " & isDict & ", label %" & dictLabel & ", label %" & arrLabel)

            此.写出(dictLabel & ":")
            此.写出("  call void @xt_dict_set(i64 " & 对象Xt & ", i64 " & 索引Xt & ", i64 " & xt_val & ")")
            此.写出("  br label %" & mergeLabel_ia)

            此.写出(arrLabel & ":")
            此.写出("  call void @xt_array_set(i64 " & 对象Xt & ", i64 " & 索引Xt & ", i64 " & xt_val & ")")
            此.写出("  br label %" & mergeLabel_ia)

            此.写出(mergeLabel_ia & ":")
            此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
            此.写出("  call void @xt_release(i64 " & 索引Xt & ")")
        } 抑 节点.中缀左.节点类别 == "成员访问" {
            设 翻译左 = 此.编译表达式(节点.中缀左.左表达式)
            设 对象Xt = 此.确保I64(翻译左[0], 翻译左[1])
            设 左类型 = 翻译左[1]
            
            // 访问控制检查
            此.检查访问权限(左类型, 节点.中缀左.成员名称, 节点)

            设 键Xt = 此.获取字符串对象(节点.中缀左.成员名称)
            // 检查是否弱引用字段
            设 是弱字段 = 假
            若 左类型.包含?("型:") {
                设 型名 = 左类型.替换("型:", "")
                若 此.弱引用字段表.含?(型名) 且 此.弱引用字段表[型名].含?(节点.中缀左.成员名称) {
                    是弱字段 = 真
                }
            }
            若 是弱字段 {
                此.写出("  call void @xt_dict_set_weak(i64 " & 对象Xt & ", i64 " & 键Xt & ", i64 " & xt_val & ")")
                此.写出("  call void @xt_dict_weak_init(i64 " & 对象Xt & ", i64 " & 键Xt & ", i64 " & xt_val & ")")
            } 否 {
                此.写出("  call void @xt_dict_set(i64 " & 对象Xt & ", i64 " & 键Xt & ", i64 " & xt_val & ")")
            }
            此.写出("  call void @xt_release(i64 " & 对象Xt & ")")
            此.写出("  call void @xt_release(i64 " & 键Xt & ")")
        }
        设 _r = [xt_val, "i64"]
        返 _r
    }

    函 编译表达式语句(语句) {
        设 翻译结果 = 此.编译表达式(语句.语句表达式)
        此.写_释放_xt(翻译结果[0], 翻译结果[1])
    }

    函 确保I64(寄存器, 类型) {
        设 regStr = 此.符(寄存器)
        若 类型 == "i64" { 返 regStr }
        若 类型.长度 >= 2 {
            若 类型.截取(0, 2) == "型:" { 返 regStr }
        }
        若 类型 == "raw_i64" {
            设 shifted = 此.取新寄存器()
            此.写出("  " & shifted & " = shl i64 " & regStr & ", 1")
            设 newReg = 此.取新寄存器()
            此.写出("  " & newReg & " = or i64 " & shifted & ", 1")
            返 newReg
        }
        若 类型 == "i1" 或 类型 == "判" {
            设 res = 此.取新寄存器()
            此.写出("  " & res & " = select i1 " & regStr & ", i64 4, i64 2")
            返 res
        }
        若 类型 == "函数名" {
            设 res = 此.取新寄存器()
            此.写出("  " & res & " = ptrtoint i64 (i64, ...)* @\"" & regStr & "\" to i64")
            返 res
        }
        设 res2 = 此.取新寄存器()
        此.写出("  " & res2 & " = ptrtoint " & 类型 & " " & regStr & " to i64")
        返 res2
    }

    函 确保RawI64(寄存器, 类型) {
        设 regStr = 此.符(寄存器)
        若 类型 == "raw_i64" { 返 regStr }
        设 xtVal = 此.确保I64(regStr, 类型)
        设 res = 此.取新寄存器()
        此.写出("  " & res & " = ashr i64 " & xtVal & ", 1")
        返 res
    }

    函 转为对象(寄存器, 类型) {
        设 regStr = 此.符(寄存器)
        若 类型 == "i64" {
            设 res = 此.取新寄存器()
            此.写出("  " & res & " = inttoptr i64 " & regStr & " to i8*")
            设 _r = [res, "i8*"]
            返 _r
        }
        设 xtVal = 此.确保I64(regStr, 类型)
        设 res2 = 此.取新寄存器()
        此.写出("  " & res2 & " = inttoptr i64 " & xtVal & " to i8*")
        设 _r = [res2, "i8*"]
        返 _r
    }

    函 编译字符串插值(节点) {
        设 片段列表 = 节点.插值片段列表
        若 片段列表.长度 == 0 { 返 此.编译表达式(造 字符串节点(造 标记("字符串", "", 节点.节点行, 节点.节点列))) }

        // 编译时警告：如果插值片段中包含明确的 空 值
        遍历 片段 于 片段列表 {
            若 片段.节点类别 == "空值" {
                示("编译警告: [" & 节点.节点行 & ":" & 节点.节点列 & "] 字符串插值中包含明确的 '空' 值。玄铁会自动将其转换为 '空' 字符串。")
                断
            }
        }

        设 res = 此.编译表达式(片段列表[0])
        设 resI64 = 此.确保I64(res[0], res[1])
        设 currentStr = 此.取新寄存器()
        此.写出("  " & currentStr & " = call %XTString* @xt_obj_to_string(i64 " & resI64 & ")")
        此.写_释放_xt(res[0], res[1])
        
        设 i = 1
        当 i < 片段列表.长度 {
            设 nextPart = 此.编译表达式(片段列表[i])
            设 nextI64 = 此.确保I64(nextPart[0], nextPart[1])
            设 nextStr = 此.取新寄存器()
            此.写出("  " & nextStr & " = call %XTString* @xt_obj_to_string(i64 " & nextI64 & ")")
            此.写_释放_xt(nextPart[0], nextPart[1])
            设 combined = 此.取新寄存器()
            此.写出("  " & combined & " = call %XTString* @xt_string_concat(%XTString* " & currentStr & ", %XTString* " & nextStr & ")")
            设 cStrI64 = 此.取新寄存器()
            此.写出("  " & cStrI64 & " = ptrtoint %XTString* " & currentStr & " to i64")
            此.写出("  call void @xt_release(i64 " & cStrI64 & ")")
            设 nStrI64 = 此.取新寄存器()
            此.写出("  " & nStrI64 & " = ptrtoint %XTString* " & nextStr & " to i64")
            此.写出("  call void @xt_release(i64 " & nStrI64 & ")")
            currentStr = combined
            i = i + 1
        }
        设 finalI64 = 此.取新寄存器()
        此.写出("  " & finalI64 & " = ptrtoint %XTString* " & currentStr & " to i64")
        设 _r = [finalI64, "i64"]
        返 _r
    }

    函 写_释放_xt(寄存器, 类型) {
        若 非 此.是标量类型(类型) 且 类型 != "函数名" {
            设 xt = 此.确保I64(寄存器, 类型)
            此.写出("  call void @xt_release(i64 " & xt & ")")
        }
    }

    函 写_存储_xt(寄存器, 类型, 地址寄存器) {
        设 xtVal = 此.确保I64(寄存器, 类型)
        若 非 此.是标量类型(类型) {
            此.写出("  call void @xt_retain(i64 " & xtVal & ")")
        }
        此.写出("  store i64 " & xtVal & ", i64* " & 地址寄存器)
    }

    // --- 静态类型推导系统 ---

    函 生成原生程序(ir, 输出路径, 平台, 架构, 优化等级, 链接方式) {
        设 时间戳 = 时.毫秒()
        设 ll路径 = "DEBUG_temp_" & 时间戳 & ".ll"
        设 o路径 = "DEBUG_temp_" & 时间戳 & ".o"
        
        设 写结果 = 文件.写(ll路径, ir)
        若 非 写结果.成功 {
            返 失败("无法写入临时 IR 文件: " & ll路径)
        }
        
        // 构建目标三元组
        设 目标三元组 = ""
        若 平台 == "windows" {
            若 架构 == "amd64" {
                目标三元组 = "x86_64-w64-windows-gnu"
            } 否 {
                目标三元组 = 架构 & "-w64-windows-gnu"
            }
        } 抑 平台 == "linux" {
            若 架构 == "amd64" {
                目标三元组 = "x86_64-linux-gnu"
            } 抑 架构 == "arm64" {
                目标三元组 = "aarch64-linux-gnu"
            } 否 {
                目标三元组 = 架构 & "-linux-gnu"
            }
        } 否 {
            目标三元组 = 架构 & "-" & 平台
        }

        // 调用 clang 生成对象文件
        设 clang指令 = "clang -target " & 目标三元组 & " " & 优化等级 & " -c \"" & ll路径 & "\" -o \"" & o路径 & "\""
        设 clang结果 = 执(clang指令)
        若 非 clang结果.成功 {
             执("cmd /c del /q \"" & ll路径 & "\" 2>nul")
             返 失败("无法执行 Clang: " & clang结果.错误)
        }
        
        // 寻找运行时
        设 rtFile = "runtime\\xt_runtime.c"
        若 非 文件.存在?(rtFile) {
            rtFile = "..\\runtime\\xt_runtime.c"
        }

        // 调用 gcc 进行链接
        若 文件.存在?(输出路径) {
            执("cmd /c del /q \"" & 输出路径 & "\" 2>nul")
        }

        设 链接指令 = ""
        若 链接方式 == "静态" {
            链接指令 = "gcc -static \"" & o路径 & "\" \"" & rtFile & "\" -o \"" & 输出路径 & "\""
        } 否 {
            链接指令 = "gcc \"" & o路径 & "\" \"" & rtFile & "\" -o \"" & 输出路径 & "\""
        }
        
        设 gcc结果 = 执(链接指令)
        若 非 gcc结果.成功 {
             // 执("cmd /c del /q \"" & ll路径 & "\" \"" & o路径 & "\" 2>nul")
             返 失败("无法执行 GCC: " & gcc结果.错误)
        }

        // 清理
        // 执("cmd /c del /q \"" & ll路径 & "\" \"" & o路径 & "\" 2>nul")
        返 成功(输出路径)
    }

    函 添加类型警告(警告码, 行号, 上下文) {
        设 警告码表 = {
            "W001": { "类别": "隐式类型", "子类": "变量未标注", "默认等级": "宽松", "消息": "变量声明缺少显式类型注解，编译器已推断类型" },
            "W002": { "类别": "隐式类型", "子类": "参数未标注", "默认等级": "警告", "消息": "函数参数缺少显式类型注解" },
            "W003": { "类别": "隐式类型", "子类": "返回值未标注", "默认等级": "警告", "消息": "函数缺少返回类型注解" },
            "W401": { "类别": "循环引用", "子类": "", "默认等级": "警告", "消息": "两个类型的字段互相强引用，可能形成循环引用导致内存泄漏" },
            "W101": { "类别": "未使用变量", "子类": "", "默认等级": "宽松", "消息": "声明的变量未被使用，建议删除" }
        }
        设 信息 = 警告码表[警告码]
        设 原始等级 = 信息["默认等级"]

        // 根据严格度确定最终等级
        设 最终等级 = 原始等级
        若 此.严格度 == "严格" {
            若 原始等级 == "宽松" { 最终等级 = "警告" }
            抑 原始等级 == "警告" { 最终等级 = "错误" }
        } 抑 此.严格度 == "禁止" {
            最终等级 = "错误"
        }

        // 若提升为错误，直接终止编译
        若 最终等级 == "错误" {
            设 描述 = 信息["消息"]
            设 详情 = "[" & 警告码 & "] " & 描述
            若 上下文 != "" { 详情 = 详情 & "（" & 上下文 & "）" }
            详情 = 详情 & " —— 在当前严格度 [" & 此.严格度 & "] 下，此警告已提升为错误"
            示("编译错误: " & 详情)
            终 1
        }

        // 若为宽松级且未提升，静默跳过
        若 最终等级 == "宽松" { 返 空 }

        // 警告级：正常输出
        设 类别 = 信息["类别"]
        设 子类 = 信息["子类"]
        设 描述 = 信息["消息"]

        设 输出 = ""
        输出 = 输出 & "警告 [" & 警告码 & "]：第 " & 行号 & " 行"
        输出 = 输出 & "\n"
        输出 = 输出 & "  类别: " & 类别
        若 子类 != "" { 输出 = 输出 & "（" & 子类 & "）" }
        输出 = 输出 & "\n"
        输出 = 输出 & "  " & 描述
        若 上下文 != "" { 输出 = 输出 & "\n  上下文: " & 上下文 }
        输出 = 输出 & "\n  此警告在当前严格度 [" & 此.严格度 & "] 下不会中断编译。"
        若 此.严格度 == "默认" { 输出 = 输出 & "\n  可通过 --严格 将此警告提升为错误。" }
        此.警告列表.追加(输出)
    }

    函 提取引用类型名(注解) {
        若 注解 == "" { 返 "" }
        设 清理 = 注解
        // 剥离可空修饰符 ?（从尾部）
        若 清理.字节数 > 0 且 清理.截取(清理.字节数-1, 清理.字节数) == "?" {
            清理 = 清理.截取(0, 清理.字节数-1)
        }
        // 数组<型名> → 提取型名（数组=6字节UTF-8）
        若 清理.字节数 >= 6 且 清理.截取(0, 6) == "数组" {
            若 清理.包含?("<") 且 清理.包含?(">") {
                设 始 = 0 ; 设 止 = 0
                设 kk = 0 ; 当 kk < 清理.字节数 { 若 清理.截取(kk, kk+1) == "<" { 始 = kk ; 断 } ; kk = kk + 1 }
                设 kk2 = 清理.字节数 - 1 ; 当 kk2 >= 0 { 若 清理.截取(kk2, kk2+1) == ">" { 止 = kk2 ; 断 } ; kk2 = kk2 - 1 }
                若 始 > 0 且 止 > 始 { 返 清理.截取(始+1, 止) }
            }
            返 ""
        }
        // 字典<K, V> → 提取 V（value 类型，字典=6字节UTF-8）
        若 清理.字节数 >= 6 且 清理.截取(0, 6) == "字典" {
            若 清理.包含?(",") 且 清理.包含?(">") {
                设 逗号位 = 0 ; 设 终2 = 0
                设 kk3 = 0 ; 当 kk3 < 清理.字节数 { 若 清理.截取(kk3, kk3+1) == "," { 逗号位 = kk3 ; 断 } ; kk3 = kk3 + 1 }
                设 kk4 = 清理.字节数 - 1 ; 当 kk4 >= 0 { 若 清理.截取(kk4, kk4+1) == ">" { 终2 = kk4 ; 断 } ; kk4 = kk4 - 1 }
                若 逗号位 > 0 且 终2 > 逗号位 {
                    设 v型 = 清理.截取(逗号位+1, 终2)
                    // 去除首尾空格
                    当 v型.字节数 > 0 且 v型.截取(0,1) == " " { v型 = v型.截取(1, v型.字节数) }
                    返 v型
                }
            }
            返 ""
        }
        // 直接型名（在类型表中才算）
        若 此.类型表.含?(清理) { 返 清理 }
        返 ""
    }
}
