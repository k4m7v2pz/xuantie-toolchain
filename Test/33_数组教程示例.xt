// Test/33_数组教程示例.xt
// 对应语言参考手册 6.3.7 节的完整示例
引 "../lib/数组/数组.xt" 予 A

示("--- 数组高阶方法完整示例 ---")

设 数据 = [5, 2, 8, 2, 1, 9, 3]

// 1. 去重 -> 排序 -> 过滤偶数 -> 映射平方
设 去重数据 = A.去重(数据)
A.排序(去重数据, 函(a, b) { 返 a - b })
示("去重排序后: " & 去重数据.连接(", "))

设 偶数 = A.过滤(去重数据, 函(x) { 返 x % 2 == 0 })
示("偶数: " & 偶数.连接(", "))

设 平方 = A.映射(偶数, 函(x) { 返 x * x })
示("平方: " & 平方.连接(", "))

// 2. 统计
设 总和 = A.归纳(数据, 0, 函(累计, x) { 返 累计 + x })
设 有大值 = A.存在?(数据, 函(x) { 返 x > 7 })
示("总和: #{总和}, 存在>7: #{有大值}")

示("--- 数组高阶方法完整示例 结束 ---")
