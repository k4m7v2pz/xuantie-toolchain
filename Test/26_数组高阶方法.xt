// Test/26_数组高阶方法.xt
// 纯玄铁实现的数组高阶标准库测试

引 "../lib/数组/数组.xt" 予 A

示("--- 26_数组高阶方法 开始 ---")

// 1. 映射（map）
设 数字 = [1, 2, 3, 4, 5]
设 平方 = A.映射(数字, 函(x) { 返 x * x })
示("映射平方: #{平方[0]},#{平方[4]}")

// 2. 过滤（filter）
设 偶数 = A.过滤(数字, 函(x) { 返 x % 2 == 0 })
示("过滤偶数长度: #{偶数.长度}")
示("过滤偶数[0]: #{偶数[0]}")

// 3. 归纳（reduce）
设 总和 = A.归纳(数字, 0, 函(累计, x) { 返 累计 + x })
示("归纳总和: #{总和}")

// 4. 查找（find）
设 大值 = A.查找(数字, 函(x) { 返 x > 3 })
示("查找>3: #{大值}")

设 找不到 = A.查找(数字, 函(x) { 返 x > 100 })
示("查找>100: #{找不到 == 空}")

// 5. 每个?（every）
设 全正 = A.每个?(数字, 函(x) { 返 x > 0 })
示("每个>0: #{全正}")

设 全偶数 = A.每个?(数字, 函(x) { 返 x % 2 == 0 })
示("每个偶数: #{全偶数}")

// 6. 存在?（some）
设 有大 = A.存在?(数字, 函(x) { 返 x > 4 })
示("存在>4: #{有大}")

// 7. 排序
设 乱序 = [3, 1, 4, 1, 5]
A.排序(乱序, 函(a, b) { 返 a - b })
示("排序后[0]: #{乱序[0]}")
示("排序后[4]: #{乱序[4]}")

// 8. 去重
设 去重后 = A.去重([1, 2, 2, 3, 3, 3])
示("去重长度: #{去重后.长度}")

// 9. 反转
设 反转后 = A.反转([1, 2, 3])
示("反转[0]: #{反转后[0]}")

示("--- 26_数组高阶方法 结束 ---")
