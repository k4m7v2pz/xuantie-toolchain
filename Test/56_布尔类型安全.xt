// Test 56 — 布尔类型安全 (C5 XT_FALSE/XT_TRUE 段错误)
// 验证：布尔值传递给各种函数不会导致崩溃（修复前会段错误）

示("=== Test 56: 布尔类型安全 ===")

// 场景1: 布尔值传递给字符串函数（修复前将 0x2/0x4 当指针解引用）
// 使用类型转换间接测试——整(真)/整(假) 走 xt_to_int

// 场景2: 布尔值在条件判断中
若 真 { 示("PASS: 真条件正确") } 否 { 示("FAIL: 真条件错误") }
若 非 假 { 示("PASS: 假条件正确") } 否 { 示("FAIL: 假条件错误") }

// 场景3: 布尔值在数组中
设 boolArr = [真, 假, 真]
若 boolArr[0] == 真 且 boolArr[1] == 假 { 示("PASS: 布尔数组正确") } 否 { 示("FAIL: 布尔数组") }

// 场景4: 布尔值在字典中
设 boolDict = {"yes": 真, "no": 假}
若 boolDict["yes"] == 真 且 boolDict["no"] == 假 { 示("PASS: 布尔字典正确") } 否 { 示("FAIL: 布尔字典") }

// 场景5: 布尔值比较
若 真 == 真 且 假 == 假 且 真 != 假 { 示("PASS: 布尔比较正确") } 否 { 示("FAIL: 布尔比较") }

// 场景6: 布尔值打印（走 xt_obj_to_string → xt_print_value）
示("布尔打印测试: 真=" & 真.转字() & " 假=" & 假.转字())

// 场景7: 布尔值在遍历循环中
设 count = 0
遍历 v 于 boolArr {
    若 v == 真 { count = count + 1 }
}
若 count == 2 { 示("PASS: 布尔遍历正确") } 否 { 示("FAIL: 布尔遍历") }

// 场景8: 非/且/或 逻辑运算
若 非 假 且 真 或 假 { 示("PASS: 逻辑运算正确") } 否 { 示("FAIL: 逻辑运算") }

示("=== Test 56 完成 ===")
