// Test 53 — 数组大规模操作 (C4 Arena/malloc 混合扩容)
// 验证：数组在大规模追加时不会因 realloc arena 内存而崩溃

示("=== Test 53: 数组大规模操作 ===")

// 创建数组并反复追加（测试扩容路径）
设 arr = []
设 i = 0
当 i < 100 {
    arr.追加(i)
    i = i + 1
}

若 arr.长度 == 100 { 示("PASS: 100次追加, 长度=" & arr.长度.转字()) } 否 { 示("FAIL: 长度错误") }

// 验证索引访问
若 arr[0] == 0 且 arr[50] == 50 且 arr[99] == 99 { 示("PASS: 索引访问正确") } 否 { 示("FAIL: 索引访问错误") }

// 大规模删除（测试缩容路径）
设 removed = 0
i = 0
当 i < 50 {
    arr.删(0)
    i = i + 1
}
若 arr.长度 == 50 { 示("PASS: 50次删除后长度=" & arr.长度.转字()) } 否 { 示("FAIL: 删除后长度=" & arr.长度.转字()) }
若 arr[0] == 50 { 示("PASS: 删除后第一个元素=" & arr[0].转字()) } 否 { 示("FAIL: 删除后第一个元素错误") }

// 插入测试（测试中间扩容）
设 arr2 = [1, 2, 3]
arr2.插(1, 99)
若 arr2[1] == 99 且 arr2.长度 == 4 { 示("PASS: 插入正确") } 否 { 示("FAIL: 插入错误") }

// 数组包含测试
若 arr2.含?(99) { 示("PASS: 包含测试正确") } 否 { 示("FAIL: 包含测试错误") }

// 空数组操作（边界）
设 empty = []
若 empty.长度 == 0 { 示("PASS: 空数组长度=0") } 否 { 示("FAIL: 空数组") }
empty.追加("first")
若 empty.长度 == 1 且 empty[0] == "first" { 示("PASS: 空数组追加正确") } 否 { 示("FAIL: 空数组追加") }

示("=== Test 53 完成 ===")
