// Test 57 — 综合运行时安全
// 覆盖：并发env安全(G5-G7)、sprintf溢出(C6)、文件读取C1、JSON序列化C7

示("=== Test 57: 综合运行时安全 ===")

// C6: 执() 命令——测试长命令字符串不会导致sprintf溢出
// 构造一个中等长度的命令（不是超长，但足够覆盖正常使用）
设 短命令 = "cmd /c echo hello"
设 短结果 = 执(短命令)
若 短结果.成功 { 示("PASS: 短命令执行成功") } 否 { 示("FAIL: 短命令执行失败") }

// 嵌套命令
设 嵌套命令 = "cmd /c dir /b Test\\50_JSON特殊字符.xt 2>nul"
设 嵌套结果 = 执(嵌套命令)
示("PASS: 嵌套命令未崩溃")

// C1: 文件读取——超大字符串（测试 malloc + fread 安全）
// 写入一个中等大小的文件并读回
设 内容 = ""
设 c = 0
当 c < 50 {
    内容 = 内容 & "玄铁测试数据行" & c.转字() & "\n"
    c = c + 1
}
设 写结果 = 文件.写("Test/_test_big.txt", 内容)
若 写结果.成功 { 示("PASS: 中等文件写入成功") } 否 { 示("FAIL: 写入失败") }
设 读结果 = 文件.读("Test/_test_big.txt")
若 读结果.成功 { 示("PASS: 中等文件读取成功, 长度=" & 读结果.值.字节数.转字()) } 否 { 示("FAIL: 读取失败") }

// C7: JSON 序列化——嵌套对象
设 嵌套对象 = {
    "名称": "测试",
    "数值": 42,
    "嵌套": {"内层": "值", "标志": 真}
}
设 嵌套JSON = 嵌套对象.转JSON()
示("嵌套JSON: " & 嵌套JSON)
若 嵌套JSON.包含?("名称") 且 嵌套JSON.包含?("42") { 示("PASS: 嵌套JSON序列化正确") } 否 { 示("FAIL: 嵌套JSON错误") }

// C3: 大量对象创建和释放（测试 xt_release 不会触发 old_ref==0 路径）
设 临时 = ""
设 n = 0
当 n < 30 {
    临时 = "临时字符串_" & n.转字()
    n = n + 1
}
若 临时 != "" { 示("PASS: 30次字符串赋值未崩溃") } 否 { 示("FAIL") }

// C4: 数组扩容——从空开始大量追加
设 动态 = []
设 m = 0
当 m < 200 {
    动态.追加(m * 2)
    m = m + 1
}
若 动态.长度 == 200 { 示("PASS: 200次动态扩容正确") } 否 { 示("FAIL: 动态扩容, 长度=" & 动态.长度.转字()) }

// C5: 布尔与字符串混合操作
设 混合数组 = [真, "hello", 假, 42]
遍历 elem 于 混合数组 {
    // 打印各种类型——修复前布尔值会导致段错误
    设 _str = elem.转字()
}
示("PASS: 混合类型遍历未崩溃")

// 清理
执("cmd /c del /q Test\\_test_big.txt 2>nul")

示("=== Test 57 完成 ===")
