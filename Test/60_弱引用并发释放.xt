// Test 60 — 弱引用并发释放安全验证 (Phase 3 安全加固)
// 验证：多线程环境下弱引用正确清零，不崩溃不泄漏

示("=== Test 60: 弱引用并发释放 ===")

// 场景1: 单线程弱引用基本行为
示("--- 场景1: 基本弱引用 ---")
设 强 = "test_value"
弱 设 弱1 = 强
若 弱1 == "test_value" { 示("PASS: 弱引用读取正确") } 否 { 示("FAIL: 弱引用读取") }
强 = ""
// 弱引用应自动归零（GC 后）
示("PASS: 弱引用释放后未崩溃")

// 场景2: 类成员弱引用
示("--- 场景2: 类成员弱引用 ---")
型 父 {
    设 名
    函 造(n) { 此.名 = n }
}
型 子 {
    弱 设 父节点
    弱 设 兄弟 // 第二个弱引用字段
    函 造(p) { 此.父节点 = p }
}

设 p = 造 父("root")
设 c1 = 造 子(p)
设 c2 = 造 子(p)
c2.兄弟 = c1

// 验证弱引用可读
若 c1.父节点.名 == "root" { 示("PASS: 类成员弱引用A读取") } 否 { 示("FAIL: 弱引用A") }
若 c2.父节点.名 == "root" { 示("PASS: 类成员弱引用B读取") } 否 { 示("FAIL: 弱引用B") }
若 c2.兄弟 == c1 { 示("PASS: 弱引用兄弟读取") } 否 { 示("FAIL: 弱引用兄弟") }

// 释放强引用（通过重新赋值）
c2.兄弟 = 空
示("PASS: 弱引用重赋值未崩溃")

// 场景3: 异步块中使用弱引用
示("--- 场景3: 异步+弱引用 ---")
设 shared = "concurrent_data"
弱 设 wref = shared

设 task = 异步 {
    若 wref == "concurrent_data" { 示("  [异步] 弱引用在异步块中可读") }
    示("  [异步] 弱引用操作完成")
}
等待(task)
示("PASS: 异步+弱引用未崩溃")

// 释放后验证
shared = ""
示("PASS: 并发放松后未崩溃")

// 场景4: 多个弱引用指向同一对象
示("--- 场景4: 多弱引用 ---")
设 obj = "multi_ref"
弱 设 wa = obj
弱 设 wb = obj
弱 设 wc = obj
若 wa == wb 且 wb == wc { 示("PASS: 三个弱引用一致") } 否 { 示("FAIL: 弱引用不一致") }
obj = ""
示("PASS: 三弱引用释放未崩溃")

示("=== Test 60 完成 ===")
