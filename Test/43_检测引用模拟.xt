型 模拟型 {
    设 提取引用类型名
    函 造() { 此.提取引用类型名 = "测试" }
    函 模拟检测(程序节点) {
        设 型列表 = {}
        遍历 语句 于 程序节点 {
            若 语句 > 0 {
                型列表[语句] = 语句
            }
        }
        遍历 型名A 于 型列表 {
            设 型A = 型列表[型名A]
            遍历 属性 于 程序节点 {
                设 目标B = 此.提取引用类型名
                若 目标B == "" { 续 }
                设 型B = 目标B
                遍历 属性B 于 程序节点 {
                    设 目标A = 型A
                    若 目标A == 型名A {
                        示("循环: #{目标B} #{型名A}")
                    }
                }
            }
        }
    }
}

设 obj = 造 模拟型()
obj.模拟检测([1, 2, 3])
