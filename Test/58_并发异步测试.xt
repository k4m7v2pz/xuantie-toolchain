// Test 58 - 并发异步测试 (Phase 2/3 新特性)
// 验证：异步块在独立线程执行，等待可获得结果

示("=== Test 58: 并发异步测试 ===")

// 简单的异步任务
设 task = 异步 {
    示("  [异步] 任务执行中...")
}
等待(task)
示("PASS: 异步任务提交并等待完成")

// 带副作用的任务
设 counter = 0
设 t2 = 异步 {
    counter = 42
}
等待(t2)
若 counter == 42 { 示("PASS: 异步任务修改全局变量成功") } 否 { 示("FAIL: counter=" & counter.转字()) }

// 多个异步任务
设 a = 0
设 b = 0
设 ta = 异步 { a = 10 }
设 tb = 异步 { b = 20 }
等待(ta)
等待(tb)
若 a == 10 且 b == 20 { 示("PASS: 两个异步任务正确执行") } 否 { 示("FAIL: a=" & a.转字() & " b=" & b.转字()) }

示("=== Test 58 完成 ===")
