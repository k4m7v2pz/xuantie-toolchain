// Test/15_综合测试.xt
// 综合压力测试：大规模循环、复杂对象结构、ARC 内存释放验证

示("--- 15_综合测试 开始 ---")

// 1. 大规模对象创建与销毁 (压力测试 ARC)
函 压力测试() {
    设 i = 0
    当 i < 10000 {
        // 创建大量临时对象
        设 临时 = {"id": i, "数据": [i, i+1]}
        若 i % 2000 == 0 {
            示(" -> 已处理 #{i} 个临时对象")
        }
        i = i + 1
    }
}

示("正在启动 ARC 压力测试...")
设 开始 = 时.毫秒()
压力测试()
设 耗时 = 时.毫秒() - 开始
示("压力测试完成，耗时: #{耗时} 毫秒")

// 2. 深度递归综合
函 深度计算(n, s) {
    若 n <= 0 { 返 s }
    返 深度计算(n - 1, s & ".")
}
示("深度字符串递归验证: #{深度计算(10, "").长度}")

// 3. 复杂逻辑组合 (OOP + FP + Async)
型 任务管理器 {
    设 队列
    函 造() { 此.队列 = [] }
    函 添加(f) { 此.队列.追加(f) }
    函 批量执行() {
        遍历 项 于 此.队列 {
            // 异步块暂不支持捕获外部变量（Phase 3 已知局限）
            异步 { 示("综合任务执行中...") }
        }
    }
}

设 管理器 = 造 任务管理器()
管理器.添加(函() { 示("综合任务 A 执行") })
管理器.添加(函() { 示("综合任务 B 执行") })
管理器.批量执行()

示("--- 15_综合测试 结束 ---")
