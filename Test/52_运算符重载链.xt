// Test 52 — 运算符重载链式调用 (H25 右操作数泄漏)
// 验证：反复触发运算符重载不会导致内存泄漏或崩溃

示("=== Test 52: 运算符重载链 ===")

// 定义可加类型测试 _加_ 重载
型 向量 {
    设 x
    设 y
    函 造(ax, ay) {
        此.x = ax
        此.y = ay
    }
    函 _加_(other) {
        返 造 向量(此.x + other.x, 此.y + other.y)
    }
    函 _等_(other) {
        返 此.x == other.x 且 此.y == other.y
    }
    函 转字() {
        返 "向量(" & 此.x.转字() & "," & 此.y.转字() & ")"
    }
}

// 创建两个向量并反复加法
设 v1 = 造 向量(1, 2)
设 v2 = 造 向量(3, 4)

// 单次加法
设 v3 = v1 + v2
若 v3.x == 4 且 v3.y == 6 { 示("PASS: 单次加法正确") } 否 { 示("FAIL: 单次加法错误, " & v3.转字()) }

// 链式加法（多次触发运算符重载）
设 total = 造 向量(0, 0)
设 k = 0
当 k < 20 {
    total = total + 造 向量(1, 1)
    k = k + 1
}
若 total.x == 20 且 total.y == 20 { 示("PASS: 20次链式加法正确") } 否 { 示("FAIL: 链式加法, " & total.转字()) }

// 嵌套表达式中的运算符重载
设 a = 造 向量(1, 0)
设 b = 造 向量(0, 1)
设 c = 造 向量(2, 3)
设 result = a + b + c
若 result.x == 3 且 result.y == 4 { 示("PASS: 嵌套表达式正确") } 否 { 示("FAIL: 嵌套表达式") }

// 在条件中触发重载（测试 alloca 路径）
设 v4 = 造 向量(5, 5)
设 v5 = 造 向量(5, 5)
若 v4 == v5 { 示("PASS: 条件中==重载正确") } 否 { 示("FAIL: ==重载") }
若 非 (v4 != v5) { 示("PASS: 条件中!=重载正确") } 否 { 示("FAIL: !=重载") }

示("=== Test 52 完成 ===")
