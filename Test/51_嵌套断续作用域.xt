// Test 51 — 断/续在嵌套若块中的作用域释放 (H23)
// 验证：嵌套若块中的断/续正确释放所有层级的ARC变量

示("=== Test 51: 嵌套断续作用域 ===")

// 场景1: 两层嵌套若中的断，内层创建对象
设 outer = 0
当 outer < 5 {
    设 obj1 = "level1_" & outer.转字()
    若 outer > 0 {
        设 obj2 = "level2_" & outer.转字()
        若 outer > 2 {
            示("  断于 outer=" & outer.转字())
            断
        }
    }
    outer = outer + 1
}
若 outer == 3 { 示("PASS: 嵌套断正确退出") } 否 { 示("FAIL: outer=" & outer.转字() & " 预期 3") }

// 场景2: 嵌套若中的续
设 found = 0
设 i = 0
当 i < 10 {
    若 i > 1 {
        设 inner = "inner_" & i.转字()
        若 i < 5 {
            i = i + 1
            续
        }
    }
    found = found + 1
    i = i + 1
}
若 found >= 5 { 示("PASS: 嵌套续正确工作, found=" & found.转字()) } 否 { 示("FAIL: found=" & found.转字()) }

// 场景3: 三层嵌套中的断
设 depth = 0
设 j = 0
当 j < 10 {
    设 a = "a"
    若 j > 0 {
        设 b = "b"
        若 j > 1 {
            设 c = "c"
            若 j > 3 {
                断
            }
        }
    }
    j = j + 1
}
若 j == 4 { 示("PASS: 三层嵌套断正确, j=" & j.转字()) } 否 { 示("FAIL: j=" & j.转字()) }

示("=== Test 51 完成 ===")
