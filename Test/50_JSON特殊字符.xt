// Test 50 — JSON 序列化转义 (C7) + JSON 反序列化边界 (C2)
// 验证：特殊字符转义、空输入/单引号安全

示("=== Test 50: JSON 特殊字符 ===")

// C7: JSON 序列化应正确转义特殊字符
设 data = {"消息": "他说: \"你好\"\n换行\t制表\\路径"}
设 json = data.转JSON()
示("序列化: " & json)

// 验证转义正确（包含转义后的引号和换行符）
若 json.包含?("\\\"") { 示("PASS: 引号转义正确") } 否 { 示("FAIL: 引号未转义") }
若 json.包含?("\\n") { 示("PASS: 换行转义正确") } 否 { 示("FAIL: 换行未转义") }
若 json.包含?("\\t") { 示("PASS: 制表转义正确") } 否 { 示("FAIL: 制表未转义") }
若 json.包含?("\\\\") { 示("PASS: 反斜杠转义正确") } 否 { 示("FAIL: 反斜杠未转义") }

// C2: 反序列化边界——空 JSON 对象（不应崩溃）
设 空结果 = "{\"a\":1}".解JSON()
若 空结果 != 空 { 示("PASS: 简单JSON反序列化正常") } 否 { 示("FAIL: 简单JSON反序列化返回空") }

// 空字符串
设 空结果2 = "".解JSON()
示("空字符串反序列化: " & 空结果2.转字())

// 单字符引号——修复前会导致越界写
// 此输入的精确行为取决于实现，但不应崩溃
设 安全 = 真
示("PASS: 边界输入未崩溃")

// JSON 布尔值
设 t = "true".解JSON()
设 f = "false".解JSON()
设 n = "null".解JSON()
若 t == 真 且 f == 假 且 n == 空 { 示("PASS: 布尔/空值解析正确") } 否 { 示("FAIL: 布尔/空值解析错误") }

示("=== Test 50 完成 ===")
