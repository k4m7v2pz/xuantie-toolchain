// Test/38_深层嵌套此.xt
型 测试类 {
    设 值
    函 造(v) { 此.值 = v }
    函 深层访问() {
        设 列表1 = [1, 2]
        设 列表2 = ["a", "b"]
        设 列表3 = [真, 假]
        遍历 a 于 列表1 {
            遍历 b 于 列表2 {
                遍历 c 于 列表3 {
                    示("此.值=#{此.值} a=#{a} b=#{b} c=#{c}")
                }
            }
        }
    }
}

设 obj = 造 测试类(42)
obj.深层访问()
