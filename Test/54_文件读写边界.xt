// Test 54 — 文件读写边界条件 (C1 ftell + C6 sprintf)
// 验证：空文件、不存在文件、大文件的读取不崩溃

示("=== Test 54: 文件读写边界 ===")

// 空文件创建和读取
设 空路径 = "Test/_test_empty.txt"
设 写空 = 文件.写(空路径, "")
若 写空.成功 { 示("PASS: 空文件写入成功") } 否 { 示("FAIL: 空文件写入失败") }

设 读空 = 文件.读(空路径)
若 读空.成功 { 示("PASS: 空文件读取成功, 内容长度=" & 读空.值.字节数.转字()) } 否 { 示("FAIL: 空文件读取失败") }

// 单行文件
设 单行路径 = "Test/_test_line.txt"
设 写单行 = 文件.写(单行路径, "hello")
若 写单行.成功 { 示("PASS: 单行写入成功") } 否 { 示("FAIL: 写入失败") }
设 读单行 = 文件.读(单行路径)
若 读单行.成功 且 读单行.值 == "hello" { 示("PASS: 单行读取正确") } 否 { 示("FAIL: 单行读取") }

// 中文字符文件
设 中文路径 = "Test/_test_cn.txt"
设 写中文 = 文件.写(中文路径, "玄铁渲染库")
若 写中文.成功 { 示("PASS: 中文写入成功") } 否 { 示("FAIL: 中文写入失败") }
设 读中文 = 文件.读(中文路径)
若 读中文.成功 且 读中文.值 == "玄铁渲染库" { 示("PASS: 中文读取正确") } 否 { 示("FAIL: 中文读取错误") }

// 文件不存在
设 读无 = 文件.读("Test/_nonexistent_file_xyz.xt")
若 非 读无.成功 { 示("PASS: 不存在的文件读取失败（预期）") } 否 { 示("FAIL: 不应成功读取不存在文件") }

// 文件存在检查
若 文件.存在?(单行路径) { 示("PASS: 文件存在检查正确") } 否 { 示("FAIL: 文件应存在") }
若 非 文件.存在?("Test/_nonexistent_file_xyz.xt") { 示("PASS: 不存在文件检查正确") } 否 { 示("FAIL: 文件不应存在") }

// 清理
执("cmd /c del /q Test\\_test_empty.txt Test\\_test_line.txt Test\\_test_cn.txt 2>nul")

示("=== Test 54 完成 ===")
