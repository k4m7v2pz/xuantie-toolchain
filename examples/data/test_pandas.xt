// test_pandas.xt
引 "./tiedata.xt"

示("=== 玄铁 '铁数' (TieData) 类 Pandas 演示 ===")

// 1. 模拟 CSV 数据
设 原始文本 = "姓名,年龄,部门
张三,25,技术部
李四,30,市场部
王五,22,技术部
赵六,35,财务部"

// 2. 初始化数据帧
设 df = 创建数据帧()
df.从文本(原始文本)


// 3. 展示数据
df.展示(5)

// 4. 筛选：只看技术部
示("\n[操作] 筛选部门为 '技术部' 的员工:")
设 技术部 = df.筛选("部门", "技术部")
技术部.展示(5)

// 5. 统计：计算技术部年龄总和
设 年龄总计 = 技术部.求和("年龄")
示("\n[统计] 技术部员工年龄总和: #{年龄总计}")

示("\n演示结束！")
